def test_conditional_acm_permissions(tmp_path):
    """Example 25: ACM record-level rules can hide a field only for specific rows."""
    creator = DataSetCreator()
    creator.add_question("department", ["HR", "IT"], generation_strategy="exhaustive")
    creator.add_question("salary_band", ["A", "B"], generation_strategy="exhaustive")

    acm = AccessControlManager(name="conditional_acm")
    acm.add_role("viewer")
    acm.define_permissions("department", {AccessControlManager.PERMISSION_VIEW_ONLY: ["viewer"]})
    acm.define_permissions("salary_band", {AccessControlManager.PERMISSION_VIEW_ONLY: ["viewer"]})
