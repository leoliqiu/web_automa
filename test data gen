def test_complex_bracketed_logic_relationships(tmp_path):
    """Example 2: nested AND/OR conditions produce the expected age, membership, and discount values."""
    creator = DataSetCreator()
    creator.add_question(key="age", possible_answers=[0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55, 60, 65, 70])
    creator.add_question(key="is_student", possible_answers=[True, False])
    creator.add_question(key="has_disability", possible_answers=[True, False])
    creator.add_question(
        key="age_group",
        if_conditions=[
            {"age < 13": "child"},
            {"age >= 13 AND age < 20": "teen"},
            {"age >= 20 AND age < 65": "adult"},
            {"age >= 65": "senior"},
            {"default_value": "adult"},
        ],
        possible_answers=["child", "teen", "adult", "senior"],
    )
    creator.add_question(
        key="membership",
        if_conditions=[
            {"age_group == 'child'": "free"},
            {"age_group == 'teen' AND is_student == True": "free"},
            {"age_group == 'senior'": "basic"},
            {"default_value": "premium"},
        ],
        possible_answers=["free", "basic", "premium"],
    )
    creator.add_logic(
        target_question="discount",
        rules=[
            {"(age_group == 'child') OR (age < 18 AND membership == 'free')": "30%"},
            {"(age_group == 'senior' AND membership == 'free') OR (has_disability == True)": "25%"},
            {"(membership == 'premium') AND (is_student == False)": "20%"},
            {"(is_student == True) AND (age_group == 'teen')": "15%"},
            {"(age_group == 'senior' AND membership == 'basic')": "10%"},
            {"default_value": "0%"},
        ],
        possible_values=["0%", "10%", "15%", "20%", "25%", "30%"],
        position=5,
    )
    creator.add_question(
        key="special_offer",
        if_conditions=[
            {"age_group == 'child' AND membership == 'free'": "Free toy"},
            {"age_group == 'teen' AND is_student == True": "Student pack"},
            {"age_group == 'senior' AND membership == 'basic'": "Senior wellness kit"},
            {"membership == 'premium'": "Premium gift"},
            {"default_value": "No offer"},
        ],
        possible_answers=["No offer", "Free toy", "Student pack", "Senior wellness kit", "Premium gift"],
    )

    dataset = creator.generate_dataset_with_generator(str(tmp_path / 'complex_bracketed_logic.csv'))

    assert not dataset.empty
    for _, row in dataset.iterrows():
        age = row['age']
        if age < 13:
            assert row['age_group'] == 'child'
        elif age < 20:
            assert row['age_group'] == 'teen'
        elif age < 65:
            assert row['age_group'] == 'adult'
        else:
            assert row['age_group'] == 'senior'

        if row['age_group'] == 'child':
            assert row['membership'] == 'free'
        elif row['age_group'] == 'teen' and row['is_student']:
            assert row['membership'] == 'free'
        elif row['age_group'] == 'senior':
            assert row['membership'] == 'basic'


