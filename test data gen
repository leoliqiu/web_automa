def test_all_features_combined(tmp_path):
    """Example 16: base questions, logic, grouping, and skip behavior work together in one dataset."""
    creator = DataSetCreator()
    creator.add_question("age", [15, 25, 70])
    creator.add_question("member", [True, False])
    creator.add_question(
        "status",
        if_conditions=[
            {"age < 18": "Junior"},
            {"age >= 65": "Senior"},
            {"default_value": "Adult"},
        ],
    )
    creator.add_logic(
        "discount",
        rules=[
            {"status == 'Junior'": "50%"},
            {"status == 'Senior' AND member == True": "30%"},
            {"default_value": "0%"},
        ],
    )
    creator.add_question("color", ["Red", "Blue"], group="prefs")
    creator.add_question("size", ["S", "L"], group="prefs")
    creator.add_question("notes", ["Text"], skip=True)

    dataset = creator.generate_dataset_with_generator(str(tmp_path / "test_all_features.csv"))

    for _, row in dataset.iterrows():
        if row["age"] < 18:
            assert row["status"] == "Junior"
        elif row["age"] >= 65:
            assert row["status"] == "Senior"
        else:
            assert row["status"] == "Adult"

        if row["status"] == "Junior":
            assert row["discount"] == "50%"
        elif row["status"] == "Senior" and row["member"]:
            assert row["discount"] == "30%"
        else:
            assert row["discount"] == "0%"

        assert row["color"] in ["Red", "Blue"]
        assert row["size"] in ["S", "L"]
        assert row["notes"] == "SKIP"


def test_dependency_with_if_condition(tmp_path):
    """Example 17: dependency checks run before if_conditions so skipped rows stay skipped."""
    creator = DataSetCreator()
    creator.logging = True
    creator.add_question("q1", ["Yes", "No", "Maybe"])
    creator.add_question(
        "q2",
        possible_answers=["Option1", "Option2", "Option3"],
        default_value="Option3",
        dependency="q1 != 'Maybe'",
        if_conditions=[
            {"q1 == 'Yes'": "Option1"},
            {"q1 == 'No'": "Option2"},
        ],
    )

    test_data = [
        {"q1": "Yes", "expected": "Option1"},
        {"q1": "No", "expected": "Option2"},
        {"q1": "Maybe", "expected": "SKIP"},
        {"q1": "Yes", "expected": "Option1"},
        {"q1": "No", "expected": "Option2"},
    ]

    dataset = creator.generate_dataset_with_generator(str(tmp_path / "test_dependency_with_if.csv"))

    for test_case in test_data:
        q1_val = test_case["q1"]
        expected = test_case["expected"]
        matches = dataset[dataset["q1"] == q1_val]
        assert len(matches) > 0, f"No rows with q1={q1_val} found"
        for _, row in matches.iterrows():
            assert row["q2"] == expected, f"For q1={q1_val}, expected q2={expected}, got {row['q2']}"


def test_role_specific_acm_export(tmp_path):
    """Example 18: role-specific ACM export hides restricted columns while keeping visible ones."""
    creator = DataSetCreator()
    creator.add_question("employee_id", [101, 102])
    creator.add_question("department", ["HR", "IT"])
    creator.add_question("salary_band", ["A", "B"])
    creator.add_question("manager_note", ["review", "approved"])

    acm = AccessControlManager(name="role_export_acm")
    for role in ["admin", "viewer", "guest"]:
        acm.add_role(role)

    acm.define_permissions("employee_id", {
        AccessControlManager.PERMISSION_UPDATABLE: ["admin"],
        AccessControlManager.PERMISSION_VIEW_ONLY: ["viewer", "guest"],
    })
    acm.define_permissions("department", {
        AccessControlManager.PERMISSION_UPDATABLE: ["admin"],
        AccessControlManager.PERMISSION_VIEW_ONLY: ["viewer", "guest"],
    })
    acm.define_permissions("salary_band", {
        AccessControlManager.PERMISSION_UPDATABLE: ["admin"],
        AccessControlManager.PERMISSION_VIEW_ONLY: ["viewer"],
        AccessControlManager.PERMISSION_HIDDEN: ["guest"],
    })
    acm.define_permissions("manager_note", {
        AccessControlManager.PERMISSION_UPDATABLE: ["admin"],
        AccessControlManager.PERMISSION_HIDDEN: ["viewer", "guest"],
    })

    viewer_file = tmp_path / "role_viewer_export.csv"
    guest_file = tmp_path / "role_guest_export.csv"

    viewer_dataset = creator.export_role_specific_dataset("viewer", acm, str(viewer_file))
    guest_dataset = creator.export_role_specific_dataset("guest", acm, str(guest_file))

    assert viewer_file.exists()
    assert guest_file.exists()

    assert "employee_id" in viewer_dataset.columns
    assert "department" in viewer_dataset.columns
    assert "salary_band" in viewer_dataset.columns
    assert "manager_note" not in viewer_dataset.columns

    assert "employee_id" in guest_dataset.columns
    assert "department" in guest_dataset.columns
    assert "salary_band" not in guest_dataset.columns
    assert "manager_note" not in guest_dataset.columns


