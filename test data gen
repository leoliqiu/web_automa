def test_advanced_condition_builder_composition(tmp_path):
    """Example 31: advanced ConditionBuilder compositions can express reusable business rules clearly."""
    creator = DataSetCreator()
    creator.add_base_question("age", [16, 22, 35, 70], generation_strategy="exhaustive")
    creator.add_base_question("member", [True, False], generation_strategy="exhaustive")
    creator.add_base_question("income", [20000, 50000, 90000], generation_strategy="exhaustive")
    creator.add_base_question("region", ["urban", "rural"], generation_strategy="exhaustive")

    is_minor = ConditionBuilder.less_than("age", 18)
    is_senior = ConditionBuilder.greater_equal("age", 65)
    is_member = ConditionBuilder.equals("member", True)
    low_income = ConditionBuilder.less_than("income", 30000)
    urban_region = ConditionBuilder.equals("region", "urban")

    high_discount = ConditionBuilder.or_conditions(
        ConditionBuilder.and_conditions(is_minor, is_member),
        ConditionBuilder.and_conditions(is_senior, urban_region),
        low_income,
    )

    creator.add_logic(
        "discount_level",
        rules=[
            {high_discount: "high"},
            {ConditionBuilder.and_conditions(is_member, urban_region): "medium"},
            {"default_value": "none"},
        ],
        possible_values=["none", "medium", "high"],
        ui_role="calculation",
    )

    dataset = creator.generate_dataset_with_generator(str(tmp_path / "advanced_condition_builder.csv"))

    assert not dataset.empty
    for _, row in dataset.iterrows():
        expected = "none"
        if ((row["age"] < 18 and row["member"]) or
                (row["age"] >= 65 and row["region"] == "urban") or
                (row["income"] < 30000)):
            expected = "high"
        elif row["member"] and row["region"] == "urban":
            expected = "medium"
        assert row["discount_level"] == expected


def test_risk_assessment_scorecard(tmp_path):
    """Example 32: a risk scorecard can combine multiple factors into a final risk level."""
    creator = DataSetCreator()
    creator.add_base_question("age", [19, 30, 72], generation_strategy="exhaustive")
    creator.add_base_question("smoker", [True, False], generation_strategy="exhaustive")
    creator.add_base_question("bmi", [22, 29, 36], generation_strategy="exhaustive")
    creator.add_base_question("chronic_condition", [True, False], generation_strategy="exhaustive")

    creator.add_logic(
        "risk_points",
        rules=[
            {
                ConditionBuilder.or_conditions(
                    ConditionBuilder.greater_equal("age", 70),
                    ConditionBuilder.equals("chronic_condition", True),
                ): 3
            },
