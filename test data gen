def test_base_questions(tmp_path):
    """Example 7: base questions without dependencies generate values from their allowed answer sets."""
    creator = DataSetCreator()
    creator.add_question("q1", ["Yes", "No"], default_value="Yes")
    creator.add_question("q2", ["High", "Medium", "Low"], default_value="Medium")

    dataset = creator.generate_dataset_with_generator(str(tmp_path / "test_base_questions.csv"))

    assert set(dataset.columns) == {"q1", "q2"}
    assert set(dataset["q1"].unique()).issubset({"Yes", "No"})
    assert set(dataset["q2"].unique()).issubset({"High", "Medium", "Low"})


def test_dependency_questions(tmp_path):
    """Example 8: dependency rules force dependent questions to become SKIP when the condition is false."""
    creator = DataSetCreator()
    creator.add_question("q1", ["Yes", "No"])
    creator.add_question("q2", ["High", "Low"], dependency="q1 == 'Yes'")

    dataset = creator.generate_dataset_with_generator(str(tmp_path / "test_dependency_questions.csv"))

    for _, row in dataset.iterrows():
        if row["q1"] == "Yes":
            assert row["q2"] in ["High", "Low"]
        else:
            assert row["q2"] == "SKIP"


