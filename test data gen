    dataset = creator.generate_dataset_with_generator(str(tmp_path / "conditional_acm.csv"), acm=acm)
    acm_view = json.loads((tmp_path / "acm_conditional_acm.json").read_text(encoding="utf-8"))
    assert any(
        record["data"]["department"] == "IT" and record["permissions"]["viewer"]["salary_band"] == AccessControlManager.PERMISSION_HIDDEN
        for record in acm_view.values()
    )
    assert any(
        record["data"]["department"] == "HR" and record["permissions"]["viewer"]["salary_band"] == AccessControlManager.PERMISSION_VIEW_ONLY
        for record in acm_view.values()
    )
    assert not dataset.empty


