"""


@dataclass
class RecordedStep:
    step: int
    event_id: str
    type: str
    page_url: str
    timestamp: str
    selector: str
    label: str
    tag_name: str
    input_type: str
    value: str
    checked: bool | None
    key: str
    option_text: str
    href: str
    class_name: str
    title: str
    xpath: str
    selector_mode: bool | None
    selected_options: str
    frame_path: str
    locator_suggestions: list[str]
    playwright_locators: list[str]
    primary_playwright_locator: str
    screenshot_path: str
    element_screenshot_path: str
    click_report_path: str
    deferred_action: bool
    freeze_mode: bool | None
    received_at: float


class RecorderApp:
    def __init__(
        self,
        start_url: str,
        chrome_path: Path,
        user_data_dir: Path | None = None,
        freeze_delay_ms: int = 1600,
        emit_html_report: bool = False,
        emit_playwright_export: bool = False,
        capture_step_artifacts: bool = False,
    ) -> None:
        self.start_url = start_url
        self.chrome_path = chrome_path
        self.user_data_dir = user_data_dir
        self.freeze_delay_ms = freeze_delay_ms
        self.emit_html_report = emit_html_report
        self.emit_playwright_export = emit_playwright_export
        self.capture_step_artifacts = capture_step_artifacts
        self.started_at = datetime.now(timezone.utc)
        self.steps: list[RecordedStep] = []
        self.next_step = 1
        self.stop_event = threading.Event()
        self.browser = None
        self.context = None
        self._tracked_pages: set[int] = set()
        self._wired_pages: set[int] = set()
        self._page_lock = threading.Lock()
        self._pending_events: list[tuple[dict[str, Any], Page | None]] = []
        self._processed_event_ids: set[str] = set()
        self._close_requested = False

    @staticmethod
    def _unique_nonempty(values: list[str]) -> list[str]:
        result: list[str] = []
        seen: set[str] = set()
        for value in values:
            normalized = (value or "").strip()
            if not normalized or normalized in seen:
                continue
            seen.add(normalized)
            result.append(normalized)
        return result

    @staticmethod
    def _is_playwright_locator_suggestion(value: str) -> bool:
        return value.startswith("Playwright ")

    def _extract_playwright_locators(
        self,
        locator_suggestions: list[str],
        selector: str,
        xpath: str,
    ) -> list[str]:
        locators: list[str] = []
        for suggestion in locator_suggestions:
            if not self._is_playwright_locator_suggestion(suggestion):
                continue
            _label, separator, expression = suggestion.partition(": ")
            if separator and expression:
                locators.append(expression)

        if selector:
            locators.append(f"page.locator({selector!r})")
        if xpath:
            locators.append(f"page.locator({('xpath=' + xpath)!r})")
        return self._unique_nonempty(locators)

    def _generic_locator_suggestions(self, step: RecordedStep) -> list[str]:
        return [
            suggestion
            for suggestion in step.locator_suggestions
            if not self._is_playwright_locator_suggestion(suggestion)
        ]

    def _derived_playwright_locators_from_step(self, step: RecordedStep) -> list[str]:
        locators = self._unique_nonempty(
            [step.primary_playwright_locator, *step.playwright_locators]
        )
        if locators:
            return locators

        derived: list[str] = []
        if step.tag_name == "a" and step.label:
            derived.append(f"page.get_by_role('link', name={step.label!r}, exact=True)")
            derived.append(f"page.get_by_role('link', name={step.label!r})")
        if step.tag_name == "button" and step.label:
            derived.append(f"page.get_by_role('button', name={step.label!r}, exact=True)")
            derived.append(f"page.get_by_role('button', name={step.label!r})")
        if step.input_type in {"checkbox", "radio"} and step.label:
            derived.append(f"page.get_by_label({step.label!r})")
        if step.tag_name in {"input", "textarea", "select"} and step.label:
            derived.append(f"page.get_by_label({step.label!r})")
        if step.title:
            derived.append(f"page.get_by_title({step.title!r})")
        if step.href and step.tag_name:
            derived.append(f"page.locator({f'{step.tag_name}[href={step.href!r}]'!r})")
            if step.label:
                derived.append(
                    f"page.locator({f'{step.tag_name}[href={step.href!r}]'!r}).filter(has_text={step.label!r})"
                )
            href_parts = urlsplit(step.href)
            relative_href = href_parts.path
            if href_parts.query:
                relative_href += f"?{href_parts.query}"
            if href_parts.fragment:
                relative_href += f"#{href_parts.fragment}"
            if relative_href and relative_href != step.href:
                derived.append(f"page.locator({f'{step.tag_name}[href={relative_href!r}]'!r})")
                derived.append(f"page.locator({f'{step.tag_name}[href$={relative_href!r}]'!r})")
                if step.label:
                    derived.append(
                        f"page.locator({f'{step.tag_name}[href={relative_href!r}]'!r}).filter(has_text={step.label!r})"
                    )
                    derived.append(
                        f"page.locator({f'{step.tag_name}[href$={relative_href!r}]'!r}).filter(has_text={step.label!r})"
                    )
        if step.label and step.tag_name not in {"input", "textarea", "select"}:
            derived.append(f"page.get_by_text({step.label!r})")
        if step.selector and step.label:
            derived.append(f"page.locator({step.selector!r}).filter(has_text={step.label!r})")
        if step.selector:
            derived.append(f"page.locator({step.selector!r})")
        if step.xpath:
            derived.append(f"page.locator({('xpath=' + step.xpath)!r})")
        return self._unique_nonempty(derived)

    def _debug(self, message: str) -> None:
        print(f"[app] {message}", flush=True)

    def run(self) -> None:
        if not self.chrome_path.exists():
            raise FileNotFoundError(
                f"Chrome executable not found: {self.chrome_path}\n"
                "Set --chrome-path or CHROME_PATH to your local Chrome executable."
            )

        OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
        if self.capture_step_artifacts:
            SCREENSHOT_DIR.mkdir(parents=True, exist_ok=True)
            ELEMENT_SCREENSHOT_DIR.mkdir(parents=True, exist_ok=True)
            CLICK_REPORT_DIR.mkdir(parents=True, exist_ok=True)

        signal.signal(signal.SIGINT, self._handle_stop_signal)
        if hasattr(signal, "SIGTERM"):
            signal.signal(signal.SIGTERM, self._handle_stop_signal)

        with sync_playwright() as playwright:
            page = self._launch_session(playwright)
            self._wire_page(page)
            page.goto(self.start_url, wait_until="domcontentloaded")
            self._print_recorder_status(page)
            self._save_outputs()
            self._debug("Initial artifact files created.")

            print("", flush=True)
            print(f"Recording browser actions on {self.start_url}", flush=True)
            print(
                "Tracking: clicks, text input, dropdown selections, checkbox/radio changes, Enter/Tab/Escape.",
                flush=True,
            )
            print("Press Alt+W to toggle JS element-pick mode, then click an element to capture it.", flush=True)
            print(f"Press Alt+F to toggle freeze mode for tricky UI. Freeze delay: {self.freeze_delay_ms} ms.", flush=True)
            print("Press Alt+C inside the browser to close it and end recording.", flush=True)
            print("Or press Ctrl+C in the terminal to stop recording from Python.", flush=True)
            print("Closing the browser window should also end recording.", flush=True)
            print(f"Chrome: {self.chrome_path}", flush=True)
            if self.user_data_dir is not None:
                print(f"User data dir: {self.user_data_dir}", flush=True)
            print(f"JSON output: {OUTPUT_DIR / 'recording.json'}", flush=True)
            if self.emit_html_report:
                print(f"HTML report: {OUTPUT_DIR / 'recording.html'}", flush=True)
            if self.emit_playwright_export:
                print(f"Playwright export: {OUTPUT_DIR / 'recording.playwright.py'}", flush=True)
            if self.capture_step_artifacts:
                print(f"Step artifacts: {SCREENSHOT_DIR}, {ELEMENT_SCREENSHOT_DIR}, {CLICK_REPORT_DIR}", flush=True)
            print("", flush=True)

            while not self.stop_event.is_set():
                self._drain_recorded_events()
                self._process_pending_events()
                if self._tracked_page_count() == 0:
                    break
                time.sleep(0.06)

            self._drain_recorded_events()
            self._process_pending_events()
            if self._close_requested and self.browser is not None:
                try:
                    self.browser.close()
                except Exception:
                    pass
            self._shutdown()

    def _launch_session(self, playwright: Playwright) -> Page:
        if self.user_data_dir is not None:
            self.user_data_dir.mkdir(parents=True, exist_ok=True)
            self.context = playwright.chromium.launch_persistent_context(
                user_data_dir=str(self.user_data_dir),
                executable_path=str(self.chrome_path),
                headless=False,
                viewport=None,
                args=["--disable-blink-features=AutomationControlled"],
            )
            self.browser = self.context.browser
            if self.browser is not None:
                self.browser.on("disconnected", self._handle_browser_disconnected)
            self.context.add_init_script(RECORDER_SCRIPT)
            self.context.on("page", self._wire_page)
            return self.context.pages[0] if self.context.pages else self.context.new_page()

        self.browser = playwright.chromium.launch(
            executable_path=str(self.chrome_path),
            headless=False,
            args=["--disable-blink-features=AutomationControlled"],
        )
        self.browser.on("disconnected", self._handle_browser_disconnected)
        self.context = self.browser.new_context(viewport=None)
        self.context.add_init_script(RECORDER_SCRIPT)
        self.context.on("page", self._wire_page)
        return self.context.new_page()

    def _record_payload(self, payload: dict[str, Any], page: Page | None = None) -> None:
        self._debug(
            f"Processing payload type={payload.get('type', '')} selector={payload.get('selector', '')} "
            f"page={payload.get('pageUrl', '')}"
        )
        locator_suggestions = self._unique_nonempty(payload.get("locatorSuggestions", []) or [])
        playwright_locators = self._extract_playwright_locators(
            locator_suggestions,
            payload.get("selector", ""),
            payload.get("xpath", ""),
        )
        step = RecordedStep(
            step=self.next_step,
            event_id=payload.get("eventId", ""),
            type=payload.get("type", ""),
            page_url=payload.get("pageUrl", ""),
            timestamp=payload.get("emittedAt", datetime.now(timezone.utc).isoformat()),
            selector=payload.get("selector", ""),
            label=payload.get("label", ""),
            tag_name=payload.get("tagName", ""),
            input_type=payload.get("inputType", ""),
            value=payload.get("value", ""),
            checked=payload.get("checked"),
            key=payload.get("key", ""),
            option_text=payload.get("optionText", ""),
            href=payload.get("href", ""),
            class_name=payload.get("className", ""),
            title=payload.get("title", ""),
            xpath=payload.get("xpath", ""),
            selector_mode=payload.get("selectorMode"),
            selected_options=payload.get("selectedOptions", ""),
            frame_path=payload.get("framePath", "main"),
            locator_suggestions=locator_suggestions,
            playwright_locators=playwright_locators,
            primary_playwright_locator=playwright_locators[0] if playwright_locators else "",
            screenshot_path="",
            element_screenshot_path="",
            click_report_path="",
            deferred_action=bool(payload.get("deferredAction")),
            freeze_mode=payload.get("freezeMode"),
            received_at=time.time(),
        )

        if step.event_id and step.event_id in self._processed_event_ids:
            self._debug(f"Skipped duplicate event_id={step.event_id} type={step.type}")
            return
        if step.event_id:
            self._processed_event_ids.add(step.event_id)

        if self._should_skip(step):
            self._debug(f"Skipped payload type={step.type} selector={step.selector}")
            return

        self.steps.append(step)
        self.next_step += 1
        if self.capture_step_artifacts:
            step.screenshot_path, step.element_screenshot_path = self._capture_step_screenshots(step, page)
            step.click_report_path = self._write_click_report(step)
        self._log_step(step)
        self._save_outputs()
        if step.deferred_action:
            self._replay_deferred_action(page, step)
        self._debug(f"Recorded step #{step.step}; total steps={len(self.steps)}")

        if step.type == "shortcut_exit" and step.key == "Alt+C":
            print("Alt+C detected. Closing browser and ending recording.", flush=True)
            self._close_requested = True
            self.stop_event.set()

    def _enqueue_payload(self, payload: dict[str, Any], page: Page | None = None) -> None:
        self._pending_events.append((payload, page))
        self._debug(
            f"Queued payload type={payload.get('type', '')}; pending events={len(self._pending_events)}"
        )

    def _process_pending_events(self) -> None:
        while self._pending_events:
            payload, page = self._pending_events.pop(0)
            self._debug(
                f"Dequeued payload type={payload.get('type', '')}; remaining={len(self._pending_events)}"
            )
            self._record_payload(payload, page=page)

    def _should_skip(self, step: RecordedStep) -> bool:
        if (
            step.type not in {"selector_mode", "shortcut_exit"}
            and not step.selector
            and not step.label
            and not step.href
        ):
            return True

        if not self.steps:
            return False

        previous = self.steps[-1]
        same_target = (
            previous.type == step.type
            and previous.selector == step.selector
            and previous.label == step.label
            and previous.page_url == step.page_url
            and previous.value == step.value
            and previous.checked == step.checked
            and previous.option_text == step.option_text
            and previous.key == step.key
            and previous.frame_path == step.frame_path
        )
        if same_target and step.received_at - previous.received_at < 0.4:
            return True

        if step.type == "input" and previous.type == "input":
            return (
                previous.selector == step.selector
                and previous.value == step.value
                and previous.page_url == step.page_url
            )

        navigation_noise = {("keydown", "click"), ("click", "keydown"), ("click", "select"), ("select", "click")}
        if (
            (previous.type, step.type) in navigation_noise
            and previous.selector == step.selector
            and previous.page_url == step.page_url
            and step.received_at - previous.received_at < 0.7
        ):
            return True

        return False

    def _wire_page(self, page: Page) -> None:
        page_id = id(page)
        if page_id in self._wired_pages:
            return
        self._wired_pages.add(page_id)
        self._register_page(page)
        page.on("console", lambda message: self._handle_page_console(page, message.text))
        page.on("pageerror", lambda error: print(f"[pageerror] {error}", flush=True))
        self._install_recorder(page)
        page.on("load", lambda: self._install_recorder(page))
        page.on("close", lambda: self._handle_page_close(page))

    def _install_recorder(self, page: Page) -> None:
        try:
            available = page.evaluate(
                """
                () => ({
                  installAvailable: typeof window.__pwInstallRecorder === "function",
                  installed: Boolean(window.__pwRecorderInstalled)
                })
                """
            )
            if not available.get("installAvailable"):
                self._debug(f"Recorder hook missing on page {page.url}; evaluating recorder script directly.")
                page.evaluate(RECORDER_SCRIPT)
            else:
                self._debug(f"Installing recorder hook on page {page.url}")
                page.evaluate(
                    """
                    () => {
                      if (window.__pwInstallRecorder) {
                        window.__pwInstallRecorder();
                      }
                    }
                    """
                )
            page.evaluate(
                """
                (freezeDelayMs) => {
                  window.__pwFreezeDelayMs = freezeDelayMs;
                }
                """,
                self.freeze_delay_ms,
            )
        except Exception as error:
            print(f"Recorder install failed on page {page.url}: {error}", flush=True)

    def _print_recorder_status(self, page: Page) -> None:
        try:
            status = page.evaluate(
                """
                () => ({
                  installed: Boolean(window.__pwRecorderInstalled),
                  installAvailable: typeof window.__pwInstallRecorder,
                  queueAvailable: Array.isArray(window.__pwRecordedEvents),
                  badgeAvailable: Boolean(document.getElementById("__pwRecorderBadge"))
                })
                """
            )
            print(f"Recorder installed in page: {status['installed']}", flush=True)
            print(f"Install hook type in page: {status['installAvailable']}", flush=True)
            print(f"Event queue available in page: {status['queueAvailable']}", flush=True)
            print(f"Status badge available in page: {status['badgeAvailable']}", flush=True)
        except Exception as error:
            print(f"Recorder status check failed: {error}", flush=True)

    def _log_step(self, step: RecordedStep) -> None:
        parts = [f"#{step.step}", step.type.upper()]
        if step.label:
            parts.append(f'label="{step.label}"')
        if step.selector:
            parts.append(f'selector="{step.selector}"')
        if step.primary_playwright_locator:
            parts.append(f'playwright="{step.primary_playwright_locator}"')
        if step.value:
            parts.append(f'value="{step.value}"')
        if step.option_text:
            parts.append(f'option="{step.option_text}"')
        if step.selected_options:
            parts.append(f'selected="{step.selected_options}"')
        if step.xpath:
            parts.append(f'xpath="{step.xpath}"')
        if step.frame_path:
            parts.append(f'frame="{step.frame_path}"')

        print(" | ".join(parts), flush=True)

    def _shutdown(self) -> None:
        json_path, html_path, playwright_path = self._save_outputs()

        print("", flush=True)
        print(f"Saved {len(self.steps)} steps to: {json_path}", flush=True)
        if html_path is not None:
            print(f"Saved HTML report to: {html_path}", flush=True)
        if playwright_path is not None:
            print(f"Saved Playwright export to: {playwright_path}", flush=True)

        if self.context is not None:
            try:
                self.context.close()
            except Exception:
                pass

        if self.browser is not None:
            try:
                self.browser.close()
            except Exception:
                pass

    def _capture_step_screenshots(self, step: RecordedStep, page: Page | None) -> tuple[str, str]:
        if page is None:
            self._debug(f"No page available for screenshot on step #{step.step}")
            return "", ""

        safe_type = re.sub(r"[^A-Za-z0-9._-]+", "_", step.type or "step").strip("_") or "step"
        page_screenshot_path = SCREENSHOT_DIR / f"{step.step:03d}_{safe_type}.png"
        element_screenshot_path = ELEMENT_SCREENSHOT_DIR / f"{step.step:03d}_{safe_type}_element.png"
        saved_page_path = ""
        saved_element_path = ""
        try:
            self._draw_screenshot_overlay(page, step)
            page.wait_for_timeout(220)
            page.screenshot(path=str(page_screenshot_path), full_page=False)
            saved_page_path = str(page_screenshot_path)
            self._debug(f"Saved page screenshot for step #{step.step} to {page_screenshot_path}")
            saved_element_path = self._capture_element_screenshot(page, step, element_screenshot_path)
            return saved_page_path, saved_element_path
        except Exception as error:
            self._debug(f"Failed screenshot capture for step #{step.step}: {error}")
            return saved_page_path, saved_element_path
        finally:
            try:
                self._clear_screenshot_overlay(page)
            except Exception as cleanup_error:
                self._debug(f"Overlay cleanup issue for step #{step.step}: {cleanup_error}")

    def _capture_element_screenshot(self, page: Page, step: RecordedStep, target_path: Path) -> str:
        target = self._page_target_expression(step)
        if not target:
            self._debug(f"No target available for element screenshot on step #{step.step}")
            return ""

        try:
            locator = page.locator(target).first
            locator.scroll_into_view_if_needed(timeout=1500)
            page.wait_for_timeout(80)
            locator.screenshot(path=str(target_path))
            self._debug(f"Saved element screenshot for step #{step.step} to {target_path}")
            return str(target_path)
        except Exception as error:
            self._debug(f"Failed element screenshot for step #{step.step}: {error}")
            return ""

    def _draw_screenshot_overlay(self, page: Page, step: RecordedStep) -> None:
        overlay_color = "#2563eb" if step.type in {"element_capture", "selector_mode"} else "#d14343"
        page.evaluate(
            """
            ([selector, xpath, color]) => {
              const removeExisting = () => {
                const existing = document.getElementById("__pwRecorderScreenshotOverlay");
                if (existing) {
                  existing.remove();
                }
              };

              const findByXpath = (value) => {
                try {
                  return document.evaluate(
                    value,
                    document,
                    null,
                    XPathResult.FIRST_ORDERED_NODE_TYPE,
                    null
                  ).singleNodeValue;
                } catch (error) {
                  return null;
                }
              };

              removeExisting();

              let element = null;
              if (selector) {
                try {
                  element = document.querySelector(selector);
                } catch (error) {
                  element = null;
                }
              }
              if (!element && xpath) {
                element = findByXpath(xpath);
              }
              if (!(element instanceof Element)) {
                return;
              }

              const rect = element.getBoundingClientRect();
              const overlay = document.createElement("div");
              overlay.id = "__pwRecorderScreenshotOverlay";
              overlay.setAttribute("style", [
                "position:fixed",
                `left:${Math.max(rect.left - 4, 0)}px`,
                `top:${Math.max(rect.top - 4, 0)}px`,
                `width:${Math.max(rect.width + 8, 8)}px`,
                `height:${Math.max(rect.height + 8, 8)}px`,
                `border:3px solid ${color}`,
                "border-radius:10px",
                "background:transparent",
                "box-shadow:0 0 0 9999px rgba(15, 76, 129, 0.08)",
                "z-index:2147483646",
                "pointer-events:none"
              ].join(";"));

              (document.documentElement || document.body).appendChild(overlay);
            }
            """,
            [step.selector, step.xpath, overlay_color],
        )

    def _clear_screenshot_overlay(self, page: Page) -> None:
        page.evaluate(
            """
            () => {
              const overlay = document.getElementById("__pwRecorderScreenshotOverlay");
              if (overlay) {
                overlay.remove();
              }
            }
            """
        )

    def _replay_deferred_action(self, page: Page | None, step: RecordedStep) -> None:
        if page is None or not step.event_id:
            return
        try:
            replayed = page.evaluate(
                """
                (eventId) => {
                  if (typeof window.__pwReplayDeferredAction === "function") {
                    return window.__pwReplayDeferredAction(eventId);
                  }
                  return false;
                }
                """,
                step.event_id,
            )
            self._debug(f"Replay deferred action for step #{step.step}: {replayed}")
        except Exception as error:
            self._debug(f"Failed deferred replay for step #{step.step}: {error}")

    def _write_click_report(self, step: RecordedStep) -> str:
        if step.type not in {"click", "checkbox", "radio", "select", "element_capture"}:
            return ""

        safe_type = re.sub(r"[^A-Za-z0-9._-]+", "_", step.type or "click").strip("_") or "click"
        report_path = CLICK_REPORT_DIR / f"{step.step:03d}_{safe_type}.html"
        report_html = self._render_click_report(step)
        report_path.write_text(report_html, encoding="utf-8")
        self._debug(f"Saved click report for step #{step.step} to {report_path}")
        return str(report_path)

