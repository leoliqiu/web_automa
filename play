CLICK_REPORT_DIR = OUTPUT_DIR / "click_reports"

RECORDER_SCRIPT = r"""
(() => {
  function debug(message) {
    try {
      console.log(`[recorder] ${message}`);
    } catch (error) {
    }
  }

  const TEXT_INPUT_TYPES = new Set(["", "email", "number", "password", "search", "tel", "text", "url"]);
  window.__pwRecorderEventSeq = window.__pwRecorderEventSeq || 0;
  window.__pwSuppressClicksUntil = window.__pwSuppressClicksUntil || 0;
  window.__pwDeferredActions = window.__pwDeferredActions || {};
  window.__pwFreezeModeEnabled = window.__pwFreezeModeEnabled || false;
  window.__pwFreezeDelayMs = window.__pwFreezeDelayMs || 1600;
  window.__pwBaseReplayDelayMs = window.__pwBaseReplayDelayMs || 520;

  function cssEscape(value) {
    if (window.CSS && typeof window.CSS.escape === "function") {
      return window.CSS.escape(value);
    }

    return String(value).replace(/([ #;?%&,.+*~\\':"!^$\[\]()=>|/@])/g, "\\$1");
  }

  function shorten(text, max = 80) {
    const normalized = (text || "").replace(/\s+/g, " ").trim();
    if (!normalized) {
      return "";
    }

    return normalized.length > max ? normalized.slice(0, max) + "..." : normalized;
  }

  function getText(element) {
    return shorten(
      element.getAttribute("aria-label") ||
      element.innerText ||
      element.textContent ||
      element.value ||
      ""
    );
  }

  function getAssociatedLabel(element) {
    if (!(element instanceof Element)) {
      return "";
    }

    const explicitLabel = element.closest("label");
    if (explicitLabel) {
      return shorten(explicitLabel.innerText || explicitLabel.textContent || "");
    }

    const elementId = element.getAttribute("id");
    if (elementId) {
      const byFor = document.querySelector(`label[for="${cssEscape(elementId)}"]`);
      if (byFor) {
        return shorten(byFor.innerText || byFor.textContent || "");
      }
    }

    return "";
  }

  function getFramePath() {
    try {
      const indexes = [];
      let currentWindow = window;
      while (currentWindow !== currentWindow.top) {
        const frameElement = currentWindow.frameElement;
        if (!frameElement || !frameElement.parentElement) {
          break;
        }
        const siblings = [...frameElement.parentElement.children].filter(
          (child) => child.tagName === frameElement.tagName
        );
        indexes.unshift(`${frameElement.tagName.toLowerCase()}[${siblings.indexOf(frameElement) + 1}]`);
        currentWindow = currentWindow.parent;
      }
      return indexes.length ? indexes.join(" > ") : "main";
    } catch (error) {
      return "main";
    }
  }

  function selectorXPath(element) {
    if (!element || !(element instanceof Element)) {
      return "";
    }
    if (element.id) {
      return `//*[@id=${JSON.stringify(element.id)}]`;
    }
    if (element === document.body) {
      return element.tagName.toLowerCase();
    }

    let index = 0;
    const siblings = element.parentNode ? element.parentNode.childNodes : [];
    for (let i = 0; i < siblings.length; i += 1) {
      const sibling = siblings[i];
      if (sibling === element) {
        return `${selectorXPath(element.parentNode)}/${element.tagName.toLowerCase()}[${index + 1}]`;
      }
      if (sibling.nodeType === 1 && sibling.tagName.toLowerCase() === element.tagName.toLowerCase()) {
        index += 1;
      }
    }
    return element.tagName.toLowerCase();
  }

  function ensureStatusBadge() {
    if (document.getElementById("__pwRecorderBadge")) {
      return document.getElementById("__pwRecorderBadge");
    }

    const mountRoot = document.documentElement || document.body;
    if (!mountRoot) {
      return null;
    }

    const badge = document.createElement("div");
    badge.id = "__pwRecorderBadge";
    badge.setAttribute("style", [
      "position:fixed",
      "right:16px",
      "bottom:16px",
      "z-index:2147483647",
      "padding:10px 12px",
      "max-width:320px",
      "border-radius:12px",
      "background:rgba(22,34,45,0.92)",
      "color:#f7fafc",
      "font:12px/1.4 Consolas, 'Courier New', monospace",
      "box-shadow:0 10px 30px rgba(0,0,0,0.25)",
      "pointer-events:auto",
      "white-space:pre-wrap"
    ].join(";"));
    const text = document.createElement("div");
    text.id = "__pwRecorderBadgeText";
    badge.appendChild(text);

    const button = document.createElement("button");
    button.type = "button";
    button.id = "__pwRecorderToggleButton";
    button.textContent = "Toggle Selector";
    button.setAttribute("style", [
      "margin-top:8px",
      "padding:6px 8px",
      "border:1px solid rgba(255,255,255,0.25)",
      "border-radius:8px",
      "background:#2b6cb0",
      "color:#fff",
      "font:12px Consolas, 'Courier New', monospace",
      "cursor:pointer",
      "pointer-events:auto"
    ].join(";"));
    button.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      if (window.toggleElementSelector) {
        window.toggleElementSelector();
      }
    });
    badge.appendChild(button);

    mountRoot.appendChild(badge);
    return badge;
  }

  function updateStatusBadge(message) {
    const badge = ensureStatusBadge();
    if (!badge) {
      return;
    }
    const text = badge.querySelector("#__pwRecorderBadgeText");
    if (text) {
      text.textContent = message;
    }
    const button = badge.querySelector("#__pwRecorderToggleButton");
    if (button) {
      button.textContent = window.elementSelectorActive ? "Disable Selector" : "Enable Selector";
    }
  }

  function currentReplayDelayMs() {
    return window.__pwFreezeModeEnabled ? window.__pwFreezeDelayMs : window.__pwBaseReplayDelayMs;
  }

  function clearCaptureHighlight() {
    const existing = document.getElementById("__pwRecorderCaptureHighlight");
    if (existing) {
      existing.remove();
    }
  }

  function highlightCapturedElement(element, color) {
    clearCaptureHighlight();
    if (!(element instanceof Element)) {
      return;
    }

    const rect = element.getBoundingClientRect();
    const overlay = document.createElement("div");
    overlay.id = "__pwRecorderCaptureHighlight";
    overlay.setAttribute("style", [
      "position:fixed",
      `left:${Math.max(rect.left - 4, 0)}px`,
      `top:${Math.max(rect.top - 4, 0)}px`,
      `width:${Math.max(rect.width + 8, 8)}px`,
      `height:${Math.max(rect.height + 8, 8)}px`,
      `border:3px solid ${color}`,
      "border-radius:10px",
      "background:transparent",
      "box-shadow:0 0 0 9999px rgba(15, 76, 129, 0.08)",
      "z-index:2147483646",
      "pointer-events:none"
    ].join(";"));
    (document.documentElement || document.body).appendChild(overlay);
    window.setTimeout(() => {
      if (overlay.isConnected) {
        overlay.remove();
      }
    }, 1600);
  }

  function shouldDeferActionCapture(element) {
    if (!(element instanceof Element)) {
      return false;
    }

    const tag = element.tagName.toLowerCase();
    const inputType = (element.getAttribute("type") || "").toLowerCase();

    if (tag === "a" && element.getAttribute("href")) {
      return true;
    }
    if (tag === "button") {
      return true;
    }
    if (tag === "input" && ["button", "submit", "image"].includes(inputType)) {
      return true;
    }
    if (element.getAttribute("role") === "button" || element.getAttribute("role") === "link") {
      return true;
    }

    return false;
  }

  function performDeferredAction(entry) {
    window.__pwReplayClickActive = true;
    try {
      const element = entry?.element;
      if (!(element instanceof Element)) {
        return false;
      }
      const tag = element.tagName.toLowerCase();
      if (tag === "a" && element.href) {
        const target = element.getAttribute("target");
        if (target && target !== "_self") {
          window.open(element.href, target);
        } else {
          window.location.href = element.href;
        }
        return true;
      }
      element.click();
      return true;
    } finally {
      window.__pwReplayClickActive = false;
    }
  }

  function registerDeferredAction(eventId, element) {
    if (!eventId || !(element instanceof Element)) {
      return;
    }

    const timeoutId = window.setTimeout(() => {
      const pending = window.__pwDeferredActions[eventId];
      if (!pending) {
        return;
      }
      delete window.__pwDeferredActions[eventId];
      debug(`fallback replay for deferred action ${eventId}`);
      performDeferredAction(pending);
    }, Math.max(currentReplayDelayMs() + 4800, 5200));

    window.__pwDeferredActions[eventId] = {
      element,
      timeoutId
    };
    updateStatusBadge(`Recorder: ON\nSelector: ${window.elementSelectorActive ? "ON" : "OFF"}\nPending replay`);
  }

  function replayDeferredActionById(eventId) {
    const pending = window.__pwDeferredActions[eventId];
    if (!pending) {
      return false;
    }
    delete window.__pwDeferredActions[eventId];
    if (pending.timeoutId) {
      window.clearTimeout(pending.timeoutId);
    }
    return performDeferredAction(pending);
  }

  function locatorSuggestions(element, extras = {}) {
    if (!(element instanceof Element)) {
      return [];
    }

    const suggestions = [];
    const tag = element.tagName.toLowerCase();
    const text = shorten((extras.label || getAssociatedLabel(element) || getText(element) || ""), 60);
    const elementId = element.getAttribute("id") || "";
    const name = element.getAttribute("name") || "";
    const testId =
      element.getAttribute("data-testid") ||
      element.getAttribute("data-test") ||
      element.getAttribute("data-qa") ||
      "";
    const placeholder = element.getAttribute("placeholder") || "";
    const ariaLabel = element.getAttribute("aria-label") || "";
    const altText = element.getAttribute("alt") || "";
    const title = element.getAttribute("title") || "";
    const href = element.getAttribute("href") || "";
    const role = element.getAttribute("role") || "";
    const classes = (element.getAttribute("class") || "").split(/\s+/).filter(Boolean).slice(0, 2);
    const xpath = extras.xpath || "";
    const accessibleName = extras.label || getAssociatedLabel(element) || getText(element) || "";
    const selector = getSelector(element);
    const labelText = getAssociatedLabel(element);

    if (xpath) {
      suggestions.push(`XPath: ${xpath}`);
    }
    if (elementId) {
      suggestions.push(`ID: ${elementId}`);
      suggestions.push(`CSS ID: #${elementId}`);
    }
    if (name) {
      suggestions.push(`Name: ${name}`);
      suggestions.push(`CSS Name: ${tag}[name="${name}"]`);
    }
    if (text) {
      suggestions.push(`XPath Text: //${tag}[contains(normalize-space(.), ${JSON.stringify(text)})]`);
    }
    if (href) {
      suggestions.push(`Href: ${href}`);
      suggestions.push(`CSS Href: ${tag}[href="${href}"]`);
    }
    if (title) {
      suggestions.push(`Title: ${title}`);
      suggestions.push(`CSS Title: ${tag}[title="${title}"]`);
    }
    if (classes.length) {
      suggestions.push(`CSS Class: ${tag}.${classes.map((value) => cssEscape(value)).join(".")}`);
    }
    if (extras.label) {
      suggestions.push(`Label: ${extras.label}`);
    }
    if (testId) {
      suggestions.push(`Playwright Test ID: page.get_by_test_id(${JSON.stringify(testId)})`);
    }
    if (labelText) {
      suggestions.push(`Playwright Label: page.get_by_label(${JSON.stringify(labelText)})`);
    } else if (ariaLabel) {
      suggestions.push(`Playwright Label: page.get_by_label(${JSON.stringify(ariaLabel)})`);
    }
    if (role && accessibleName) {
      suggestions.push(`Playwright Role: page.get_by_role(${JSON.stringify(role)}, name=${JSON.stringify(accessibleName)})`);
    } else if (["a", "button"].includes(tag) && accessibleName) {
      const inferredRole = tag === "a" ? "link" : "button";
      suggestions.push(`Playwright Role: page.get_by_role(${JSON.stringify(inferredRole)}, name=${JSON.stringify(accessibleName)})`);
    }
    if (placeholder) {
      suggestions.push(`Playwright Placeholder: page.get_by_placeholder(${JSON.stringify(placeholder)})`);
    }
    if (title) {
      suggestions.push(`Playwright Title: page.get_by_title(${JSON.stringify(title)})`);
    }
    if (altText) {
      suggestions.push(`Playwright Alt Text: page.get_by_alt_text(${JSON.stringify(altText)})`);
    }
    if (accessibleName && !["input", "textarea", "select"].includes(tag)) {
      suggestions.push(`Playwright Text: page.get_by_text(${JSON.stringify(accessibleName)})`);
    }
    if (xpath) {
      suggestions.push(`Playwright Locator: page.locator(${JSON.stringify(`xpath=${xpath}`)})`);
    }
    if (selector) {
      suggestions.push(`Playwright Locator: page.locator(${JSON.stringify(selector)})`);
    }

    return [...new Set(suggestions)];
  }

  function getSelectState(element) {
    if (!(element instanceof HTMLSelectElement)) {
      return { optionText: "", selectedOptions: "" };
    }

    const selectedOptions = [...element.selectedOptions].map((option) =>
      shorten(option.textContent || option.label || option.value || "")
    ).filter(Boolean);

    return {
      optionText: selectedOptions[0] || "",
      selectedOptions: selectedOptions.join(" | ")
    };
  }

  function getElementCaptureExtras(element) {
    const tagName = element?.tagName?.toLowerCase?.() || "";
    const inputType = element?.getAttribute?.("type") || "";
    const role = element?.getAttribute?.("role") || "";
    const extras = {
      className: element?.getAttribute?.("class") || "",
      title: element?.getAttribute?.("title") || "",
      xpath: selectorXPath(element),
      selectedOptions: "",
      framePath: getFramePath()
    };

    if (element instanceof HTMLSelectElement) {
      const selectState = getSelectState(element);
      extras.value = element.value || "";
      extras.optionText = selectState.optionText;
      extras.selectedOptions = selectState.selectedOptions;
      extras.label = getAssociatedLabel(element) || selectState.selectedOptions || getText(element);
      extras.locatorSuggestions = locatorSuggestions(element, extras);
      return extras;
    }

    if (element instanceof HTMLInputElement && (inputType.toLowerCase() === "checkbox" || inputType.toLowerCase() === "radio")) {
      const labelText = getAssociatedLabel(element);
      extras.checked = element.checked;
      extras.label = labelText || getText(element);
      extras.value = element.value || "";
      extras.locatorSuggestions = locatorSuggestions(element, extras);
      return extras;
    }

    if (role === "option" || role === "listbox" || role === "combobox") {
      const optionNodes = role === "option"
        ? [element]
        : [...element.querySelectorAll('[role="option"][aria-selected="true"], option:checked')];
      const selectedOptions = optionNodes
        .map((option) => shorten(option.textContent || option.getAttribute("aria-label") || option.getAttribute("value") || ""))
        .filter(Boolean);
      extras.optionText = selectedOptions[0] || shorten(getText(element), 80);
      extras.selectedOptions = selectedOptions.join(" | ");
      extras.label = getAssociatedLabel(element) || getText(element);
      extras.value = element.getAttribute("value") || extras.optionText || "";
      extras.locatorSuggestions = locatorSuggestions(element, extras);
      return extras;
    }

    if (element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement) {
      extras.value = element.value || "";
      extras.label = getAssociatedLabel(element) || getText(element);
      extras.locatorSuggestions = locatorSuggestions(element, extras);
      return extras;
    }

    extras.label = getAssociatedLabel(element) || getText(element);
    extras.locatorSuggestions = locatorSuggestions(element, extras);
    return extras;
  }

  function getSelector(element) {
    if (!(element instanceof Element)) {
      return "";
    }

    if (element.id) {
      return "#" + cssEscape(element.id);
    }

    for (const attr of ["data-testid", "data-test", "data-qa", "name", "aria-label", "placeholder"]) {
      const value = element.getAttribute(attr);
      if (value) {
        return `${element.tagName.toLowerCase()}[${attr}="${cssEscape(value)}"]`;
      }
    }

    const path = [];
    let current = element;

    while (current && current.nodeType === Node.ELEMENT_NODE && path.length < 4) {
      let part = current.tagName.toLowerCase();
      const parent = current.parentElement;

      if (parent) {
        const siblings = [...parent.children].filter((child) => child.tagName === current.tagName);
        if (siblings.length > 1) {
          part += `:nth-of-type(${siblings.indexOf(current) + 1})`;
        }
      }

      path.unshift(part);
      current = parent;
    }

    return path.join(" > ");
  }

  function emit(payload) {
    const enrichedPayload = {
      ...payload,
      eventId: `${Date.now()}-${++window.__pwRecorderEventSeq}`,
      pageUrl: window.location.href,
      emittedAt: new Date().toISOString()
    };
    window.__pwRecordedEvents = window.__pwRecordedEvents || [];
    window.__pwRecordedEvents.push(enrichedPayload);
    try {
      console.log(`[recorder-event]${JSON.stringify(enrichedPayload)}`);
    } catch (error) {
    }
    debug(`emit ${payload.type} ${payload.selector || payload.label || payload.href || ""}`);
    return enrichedPayload;
  }

  function toPayload(type, element, extra = {}) {
    const captureExtras = element instanceof Element ? getElementCaptureExtras(element) : {};
    const basePayload = {
      type,
      selector: getSelector(element),
      label: getText(element),
      tagName: element?.tagName?.toLowerCase?.() || "",
      inputType: element?.getAttribute?.("type") || "",
      href: element?.href || "",
      optionText: "",
      selectedOptions: "",
      framePath: getFramePath(),
      locatorSuggestions: [],
      ...captureExtras,
      ...extra
    };

    if (extra.label) {
      basePayload.label = extra.label;
    }

    return basePayload;
  }

  window.__pwInstallRecorder = () => {
    window.__pwRecordedEvents = window.__pwRecordedEvents || [];
    window.elementSelectorState = window.elementSelectorState || {
      selectedElement: null,
      originalStyle: null
    };
    if (window.__pwRecorderInstalled) {
      debug("recorder already installed");
      return;
    }

    window.__pwRecorderInstalled = true;
    window.__pwReplayDeferredAction = replayDeferredActionById;
    debug("recorder installed");
    updateStatusBadge("Recorder: ON\nSelector: OFF");
    if (!document.documentElement && !document.body) {
      window.addEventListener("DOMContentLoaded", () => {
        updateStatusBadge("Recorder: ON\nSelector: OFF");
      }, { once: true });
    }

    window.clearElementSelectorHighlight = function() {
      const state = window.elementSelectorState;
      if (state.selectedElement && state.originalStyle) {
        state.selectedElement.style.outline = state.originalStyle.outline;
        state.selectedElement.style.outlineOffset = state.originalStyle.outlineOffset;
        state.selectedElement.style.backgroundColor = state.originalStyle.backgroundColor;
      }
      state.selectedElement = null;
      state.originalStyle = null;
    };

    window.disableElementSelector = function() {
      if (!window.elementSelectorActive) {
        return;
      }
      document.removeEventListener("mouseover", window.highlightElement, true);
      document.removeEventListener("click", window.captureElement, true);
      window.clearElementSelectorHighlight();
      window.elementSelectorActive = false;
      debug("element selector disabled");
      updateStatusBadge("Recorder: ON\nSelector: OFF");
    };

    window.highlightElement = function(event) {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }
      if (target === document.body || target === document.documentElement) {
        return;
      }

      window.clearElementSelectorHighlight();
      window.elementSelectorState.originalStyle = {
        outline: target.style.outline,
        outlineOffset: target.style.outlineOffset,
        backgroundColor: target.style.backgroundColor
      };
      target.style.outline = "3px solid blue";
      target.style.outlineOffset = "2px";
      target.style.backgroundColor = "rgba(0, 0, 255, 0.10)";
      window.elementSelectorState.selectedElement = target;
    };

    window.captureElement = function(event) {
      event.preventDefault();
      event.stopPropagation();

      const element = event.target;
      if (!(element instanceof Element)) {
        return;
      }

      emit(toPayload("element_capture", element, {
        ...getElementCaptureExtras(element)
      }));

      highlightCapturedElement(element, "#2563eb");
      window.disableElementSelector();
      updateStatusBadge(`Recorder: ON\nCaptured: ${shorten(getText(element), 40) || element.tagName.toLowerCase()}`);
    };

    window.toggleElementSelector = function() {
      if (window.elementSelectorActive) {
        window.disableElementSelector();
        emit({
          type: "selector_mode",
          key: "Alt+W",
          selectorMode: false,
          selector: "",
          label: "",
          framePath: getFramePath()
        });
        return false;
      }

      window.elementSelectorActive = true;
      document.addEventListener("mouseover", window.highlightElement, true);
      document.addEventListener("click", window.captureElement, true);
      debug("element selector enabled");
      updateStatusBadge("Recorder: ON\nSelector: ON");
      emit({
        type: "selector_mode",
        key: "Alt+W",
        selectorMode: true,
        selector: "",
        label: "",
        framePath: getFramePath()
      });
      return true;
    };

    window.toggleFreezeMode = function() {
      window.__pwFreezeModeEnabled = !window.__pwFreezeModeEnabled;
      updateStatusBadge(
        `Recorder: ON\nSelector: ${window.elementSelectorActive ? "ON" : "OFF"}\nFreeze: ${window.__pwFreezeModeEnabled ? "ON" : "OFF"}`
      );
      emit({
        type: "freeze_mode",
        key: "Alt+F",
        freezeMode: window.__pwFreezeModeEnabled,
        selector: "",
        label: "",
        framePath: getFramePath()
      });
      return window.__pwFreezeModeEnabled;
    };

    document.addEventListener("click", (event) => {
      if (window.__pwReplayClickActive) {
        return;
      }
      if (Date.now() < (window.__pwSuppressClicksUntil || 0)) {
        debug("click suppressed after hotkey");
        return;
      }
      if (window.elementSelectorActive) {
        return;
      }
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }

      const customOption = target.closest('[role="option"], option');
      if (customOption) {
        const optionText = shorten(customOption.textContent || customOption.getAttribute("aria-label") || customOption.getAttribute("value") || "");
        const owner = customOption.closest('[role="listbox"], [role="combobox"], select') || customOption;
        highlightCapturedElement(customOption, "#d14343");
        emit(toPayload("select", owner, {
          optionText,
          selectedOptions: optionText,
          value: customOption.getAttribute("value") || optionText
        }));
        updateStatusBadge(`Recorder: ON\nLast: select ${optionText}`);
        return;
      }

      const element = target.closest("a, button, input, select, textarea, [role='button'], [role='link'], [tabindex]");
      if (!element) {
        return;
      }

      const inputType = (element.getAttribute("type") || "").toLowerCase();
      if (inputType === "checkbox") {
        highlightCapturedElement(element, "#d14343");
        emit(toPayload("checkbox", element, { checked: element.checked }));
        updateStatusBadge(`Recorder: ON\nLast: checkbox ${element.checked ? "on" : "off"}`);
        return;
      }

      if (inputType === "radio") {
        highlightCapturedElement(element, "#d14343");
        emit(toPayload("radio", element, { checked: element.checked }));
        updateStatusBadge(`Recorder: ON\nLast: radio ${getAssociatedLabel(element) || getText(element)}`);
        return;
      }

      const deferredAction = shouldDeferActionCapture(element);
      if (deferredAction) {
        event.preventDefault();
        event.stopPropagation();
        if (typeof event.stopImmediatePropagation === "function") {
          event.stopImmediatePropagation();
        }
      }

      highlightCapturedElement(element, "#d14343");
      const clickPayload = emit(toPayload("click", element, { deferredAction }));
      updateStatusBadge(
        deferredAction
          ? `Recorder: ON\nLast: click ${shorten(getText(element), 32) || element.tagName.toLowerCase()}\nAwaiting capture`
          : `Recorder: ON\nLast: click ${shorten(getText(element), 32) || element.tagName.toLowerCase()}`
      );

      if (deferredAction && clickPayload?.eventId) {
        registerDeferredAction(clickPayload.eventId, element);
      }
    }, true);

    document.addEventListener("input", (event) => {
      const element = event.target;
      if (!(element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement)) {
        return;
      }

      const inputType = (element.getAttribute("type") || "").toLowerCase();
      if (!TEXT_INPUT_TYPES.has(inputType)) {
        return;
      }

      emit(toPayload("input", element, { value: element.value }));
      updateStatusBadge(`Recorder: ON\nLast: input ${shorten(element.value, 32)}`);
    }, true);

    document.addEventListener("change", (event) => {
      const element = event.target;
      if (!element) {
        return;
      }

      if (element instanceof HTMLSelectElement) {
        const selectState = getSelectState(element);
        highlightCapturedElement(element, "#d14343");
        emit(toPayload("select", element, {
          value: element.value,
          optionText: selectState.optionText,
          selectedOptions: selectState.selectedOptions
        }));
        updateStatusBadge(`Recorder: ON\nLast: select ${selectState.selectedOptions || element.value}`);
        return;
      }

      if (element instanceof HTMLInputElement) {
        const inputType = (element.getAttribute("type") || "").toLowerCase();
        if (inputType === "checkbox") {
          emit(toPayload("checkbox", element, { checked: element.checked }));
          updateStatusBadge(`Recorder: ON\nLast: checkbox ${element.checked ? "on" : "off"}`);
        }
      }
    }, true);

    window.__pwConsumeRecorderHotkey = function(event) {
      event.preventDefault();
      event.stopPropagation();
      if (typeof event.stopImmediatePropagation === "function") {
        event.stopImmediatePropagation();
      }
    };

    window.__pwHandleRecorderHotkey = function(event) {
      if (event.type !== "keydown" || event.repeat) {
        return;
      }

      if (event.altKey && event.code === "KeyW") {
        debug("hotkey Alt+W detected");
        window.__pwSuppressClicksUntil = Date.now() + 800;
        window.__pwConsumeRecorderHotkey(event);
        window.toggleElementSelector();
        return;
      }

      if (event.altKey && event.code === "KeyF") {
        debug("hotkey Alt+F detected");
        window.__pwSuppressClicksUntil = Date.now() + 800;
        window.__pwConsumeRecorderHotkey(event);
        window.toggleFreezeMode();
        return;
      }

      if (event.altKey && event.code === "KeyC") {
        debug("hotkey Alt+C detected");
        window.__pwSuppressClicksUntil = Date.now() + 800;
        window.__pwConsumeRecorderHotkey(event);
        emit(toPayload("shortcut_exit", event.target instanceof Element ? event.target : document.body, {
          key: "Alt+C"
        }));
        return;
      }

      if (!["Enter", "Tab", "Escape"].includes(event.key)) {
        return;
      }

      const element = event.target instanceof Element ? event.target : document.body;
      emit(toPayload("keydown", element, { key: event.key }));
      updateStatusBadge(`Recorder: ON\nLast: key ${event.key}`);
    };

    window.addEventListener("keydown", window.__pwHandleRecorderHotkey, true);
    document.addEventListener("keydown", window.__pwHandleRecorderHotkey, true);
