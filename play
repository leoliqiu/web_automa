      gap: 10px;
    }}
    .locator-group {{
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: rgba(220, 235, 255, 0.45);
    }}
    .locator-heading {{
      margin-bottom: 8px;
      color: var(--accent);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }}
    .locator-primary {{
      padding: 10px;
      border: 1px solid var(--line-strong);
      border-radius: 10px;
      background: rgba(143, 184, 232, 0.18);
    }}
    .locator-primary code {{
      display: block;
      margin-top: 6px;
      white-space: pre-wrap;
      word-break: break-word;
    }}
    .step-note {{
      width: 100%;
      min-width: 240px;
      min-height: 92px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: #fff;
      color: var(--ink);
      font: 13px/1.45 Georgia, "Times New Roman", serif;
      resize: vertical;
    }}
    .step-expected {{
      width: 100%;
      min-width: 240px;
      min-height: 92px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: #fff;
      color: var(--ink);
      font: 13px/1.45 Georgia, "Times New Roman", serif;
      resize: vertical;
    }}
    .note-hint {{
      display: block;
      margin-top: 6px;
      color: var(--muted);
      font-size: 0.8rem;
    }}
    .step-check {{
      width: 140px;
      padding: 8px 10px;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: #fff;
      color: var(--ink);
    }}
    .empty-state {{
      color: var(--muted);
    }}
    .empty-state.large {{
      padding: 22px 8px;
      font-size: 1rem;
    }}
    @media (max-width: 860px) {{
      main {{ padding: 12px; }}
      .hero {{ grid-template-columns: 1fr; }}
      .page-header {{ flex-direction: column; }}
      th, td {{ padding: 10px 8px; font-size: 0.94rem; }}
      .shot-thumb {{ width: min(var(--shot-width), 180px); }}
    }}
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <section class="card summary-card">
        <h1>Recorded Browser Steps</h1>
        <p class="intro">Website testing worksheet with page-grouped steps, editable notes, pass or fail tracking, full-page screenshots, and element crops for the clicked object.</p>
        <p class="section-help">Use this summary section to confirm the recording scope and session timing before reviewing individual steps.</p>
        <table aria-label="Session metadata">
          <tbody>
            {meta_html}
          </tbody>
        </table>
      </section>
      <section class="card">
        <div class="nav-grid">
          <section class="nav-group">
            <h2>Page Navigation</h2>
            <p class="section-help">Jump to each visited page section. Each item shows the page order, a readable URL label, and how many steps were recorded on that page.</p>
            <div class="jump-list">{page_nav_html}</div>
          </section>
          <section class="nav-group">
            <h2>Step Navigation</h2>
            <p class="section-help">Jump directly to a specific recorded step. These entries summarize what happened so you can find the action you want without scanning the full table first.</p>
            <div class="jump-list">{step_nav_html}</div>
          </section>
        </div>
      </section>
    </section>
    <section class="card">
      <div class="toolbar">
        <div class="tool">
          <label for="filterMode">Filter Steps</label>
          <select id="filterMode">
            <option value="all">All Steps</option>
            <option value="user">User Actions Only</option>
            <option value="control">Control Steps Only</option>
            <option value="clicks">Clicks Only</option>
            <option value="missing-shot">Missing Page Screenshot</option>
          </select>
        </div>
        <div class="tool">
          <label for="shotWidth">Screenshot Width</label>
          <input id="shotWidth" type="range" min="140" max="520" value="240" />
        </div>
      </div>
      <h2 style="margin:0 0 8px; font-size:1.05rem; color: var(--accent);">Report Controls</h2>
      <p class="section-help">Use these controls to narrow the worksheet to the steps you want to inspect and to change screenshot width for easier side-by-side review.</p>
      <p>Click any screenshot thumbnail to open the original image in a new tab. Adjust the slider to widen or narrow both the page screenshot and the element crop columns together.</p>
    </section>
    {page_sections_html}
  </main>
  <script>
    (() => {{
      const storageKey = "playwright-action-tracker-notes";
      const expectedKey = "playwright-action-tracker-expected";
      const checkKey = "playwright-action-tracker-checks";
      let saved = {{}};
      let savedExpected = {{}};
      let savedChecks = {{}};
      try {{
        saved = JSON.parse(localStorage.getItem(storageKey) || "{{}}");
      }} catch (error) {{
        saved = {{}};
      }}
      try {{
        savedExpected = JSON.parse(localStorage.getItem(expectedKey) || "{{}}");
      }} catch (error) {{
        savedExpected = {{}};
      }}
      try {{
        savedChecks = JSON.parse(localStorage.getItem(checkKey) || "{{}}");
      }} catch (error) {{
        savedChecks = {{}};
      }}

      document.querySelectorAll(".step-note").forEach((textarea) => {{
        const key = textarea.dataset.step;
        if (saved[key]) {{
          textarea.value = saved[key];
        }}
        textarea.addEventListener("input", () => {{
          saved[key] = textarea.value;
          localStorage.setItem(storageKey, JSON.stringify(saved));
        }});
      }});

      document.querySelectorAll(".step-expected").forEach((textarea) => {{
        const key = textarea.dataset.step;
        if (savedExpected[key]) {{
          textarea.value = savedExpected[key];
        }}
        textarea.addEventListener("input", () => {{
          savedExpected[key] = textarea.value;
          localStorage.setItem(expectedKey, JSON.stringify(savedExpected));
        }});
      }});

      document.querySelectorAll(".step-check").forEach((select) => {{
        const key = select.dataset.step;
        if (savedChecks[key]) {{
          select.value = savedChecks[key];
        }}
        select.addEventListener("change", () => {{
          savedChecks[key] = select.value;
          localStorage.setItem(checkKey, JSON.stringify(savedChecks));
        }});
      }});

      const shotWidth = document.getElementById("shotWidth");
      if (shotWidth) {{
        const applyWidth = () => {{
          document.documentElement.style.setProperty("--shot-width", `${{shotWidth.value}}px`);
        }};
        shotWidth.addEventListener("input", applyWidth);
        applyWidth();
      }}

      const filterMode = document.getElementById("filterMode");
      const applyFilter = () => {{
        const mode = filterMode ? filterMode.value : "all";
        document.querySelectorAll("tr[data-type]").forEach((row) => {{
          const isControl = row.dataset.control === "true";
          const type = row.dataset.type;
          const hasShot = row.dataset.hasShot === "true";
          let show = true;
          if (mode === "user") {{
            show = !isControl;
          }} else if (mode === "control") {{
            show = isControl;
          }} else if (mode === "clicks") {{
            show = ["click", "checkbox", "radio", "select", "element_capture"].includes(type);
          }} else if (mode === "missing-shot") {{
            show = !hasShot;
          }}
          row.hidden = !show;
        }});

        document.querySelectorAll(".page-group").forEach((section) => {{
          const rows = [...section.querySelectorAll("tbody tr[data-type]")];
          const visibleCount = rows.filter((row) => !row.hidden).length;
          section.hidden = visibleCount === 0;
          const badge = section.querySelector("[data-visible-count]");
          if (badge) {{
            badge.textContent = `${{visibleCount}} visible of ${{rows.length}}`;
          }}
        }});
      }};

      if (filterMode) {{
        filterMode.addEventListener("change", applyFilter);
      }}
      applyFilter();
    }})();
  </script>
</body>
</html>
"""

    def _group_steps_by_page(self) -> list[tuple[str, list[RecordedStep]]]:
        grouped: dict[str, list[RecordedStep]] = {}
        order: list[str] = []
        for step in self.steps:
            key = step.page_url or "(no page url)"
            if key not in grouped:
                grouped[key] = []
                order.append(key)
            grouped[key].append(step)
        return [(key, grouped[key]) for key in order]

    def _shorten_label(self, value: str, limit: int = 88) -> str:
        normalized = " ".join((value or "").split())
        if len(normalized) <= limit:
            return normalized
        return normalized[: limit - 3].rstrip() + "..."

    def _render_page_nav_item(self, index: int, page_url: str, steps: list[RecordedStep]) -> str:
        label = self._escape_html(self._shorten_label(page_url or "(no page url)", 72))
        return (
            f'<a class="nav-item" href="#page-{index}">'
            f'<span class="nav-item-title">Page {index}</span>'
            f'<span class="nav-item-text">{label}</span>'
            f'<span class="nav-item-meta">{len(steps)} recorded steps</span>'
            f"</a>"
        )

    def _render_step_nav_item(self, step: RecordedStep) -> str:
        summary = self._escape_html(self._shorten_label(self._describe_step(step), 92))
        kind = "Control" if self._is_control_step(step) else "Action"
        return (
            f'<a class="nav-item nav-item-step" href="#step-{step.step}">'
            f'<span class="nav-item-title">Step {step.step}</span>'
            f'<span class="nav-item-text">{summary}</span>'
            f'<span class="nav-item-meta">{kind} | {self._escape_html(step.type)}</span>'
            f"</a>"
        )

    def _render_page_group(self, index: int, page_url: str, steps: list[RecordedStep]) -> str:
        row_html = "".join(self._render_step_row(step) for step in steps)
        page_screenshot_html = self._render_page_group_screenshots(index, steps)
        visible_label = f"{len(steps)} visible of {len(steps)}"
        escaped_url = self._escape_html(page_url or "(no page url)")
        return (
            f'<section id="page-{index}" class="card page-group">'
            f'<div class="page-header">'
            f'<div><h2>Page {index}</h2>'
            f'<p class="section-help">Use this section to review every action recorded while the browser was on this page. The screenshot strip gives quick page context before you work through the step table.</p>'
            f'<p class="page-url"><code>{escaped_url}</code></p></div>'
            f'<div class="page-header-meta">'
            f'<span class="page-pill">{len(steps)} steps</span>'
            f'<span class="page-pill" data-visible-count>{visible_label}</span>'
            f"</div>"
            f"</div>"
            f"{page_screenshot_html}"
            f'<div class="table-wrap">'
            f'<table class="steps" aria-label="Recorded steps for page {index}">'
            f"<thead><tr>"
            f"<th>Step</th>"
            f"<th>Type</th>"
            f"<th>Recorded Action</th>"
            f"<th>Status</th>"
            f"<th>Clicked Object</th>"
            f"<th>Frame</th>"
            f"<th>Locator Suggestions</th>"
            f"<th>Screenshots</th>"
            f"<th>Step Report</th>"
            f"<th>Check Result</th>"
            f"<th>Expected Result</th>"
            f"<th>Test Description</th>"
            f"<th>Page URL</th>"
            f"</tr></thead>"
            f"<tbody>{row_html}</tbody>"
            f"</table>"
            f"</div>"
            f"</section>"
        )

    def _render_step_row(self, step: RecordedStep) -> str:
        return (
            f'<tr id="step-{step.step}" class="{self._step_row_class(step)}" '
            f'data-type="{self._escape_html(step.type)}" '
            f'data-control="{str(self._is_control_step(step)).lower()}" '
            f'data-has-shot="{str(bool(step.screenshot_path)).lower()}">'
            f'<td class="col-step">{self._render_step_badge(step.step)}</td>'
            f'<td class="col-type"><span class="type-pill">{self._escape_html(step.type)}</span></td>'
            f'<td class="col-action">{self._escape_html(self._describe_step(step))}</td>'
            f'<td class="col-status">{self._render_status_cell(step)}</td>'
            f'<td class="col-object">{self._render_object_cell(step)}</td>'
            f'<td class="col-frame"><code>{self._escape_html(step.frame_path)}</code></td>'
            f'<td class="col-locators">{self._render_locator_suggestions(step)}</td>'
            f'<td class="col-shot">{self._render_screenshot_cell(step)}</td>'
            f'<td class="col-report">{self._render_screenshot_link(step.click_report_path)}</td>'
            f'<td class="col-check">{self._render_check_cell(step)}</td>'
            f'<td class="col-expected">{self._render_expected_cell(step)}</td>'
            f'<td class="col-note">{self._render_note_cell(step)}</td>'
            f'<td class="col-url"><code>{self._escape_html(step.page_url)}</code></td>'
            "</tr>"
        )

    def _render_page_group_screenshots(self, index: int, steps: list[RecordedStep]) -> str:
        screenshot_steps = [step for step in steps if step.screenshot_path][:6]
        if not screenshot_steps:
            return (
                '<div class="page-shot-strip">'
                '<div class="shot-card"><strong>Page Screenshot Summary</strong>'
                '<div style="color:#6b7280;">No screenshots were saved for this page group.</div></div>'
                "</div>"
            )
        items = "".join(
            (
                f'<div class="shot-card">'
                f'<strong>Step {step.step}</strong>'
                f'<div style="color:#486581; font-size:0.84rem;">{self._escape_html(self._shorten_label(self._describe_step(step), 72))}</div>'
                f'<a class="shot-link" href="{self._escape_html(self._path_to_html_href(step.screenshot_path))}" target="_blank" rel="noopener noreferrer">open page shot</a>'
                f'<img class="shot-thumb" src="{self._escape_html(self._path_to_html_href(step.screenshot_path))}" alt="Page {index} screenshot step {step.step}" />'
                "</div>"
            )
            for step in screenshot_steps
        )
        return (
            '<div>'
            '<h3 style="margin:0 0 8px; font-size:1rem; color: var(--accent);">Page Screenshot Summary</h3>'
            '<p class="section-help">These representative screenshots help you understand this page state before reading the detailed step rows below.</p>'
            f'<div class="page-shot-strip">{items}</div>'
            "</div>"
        )

    def _describe_step(self, step: RecordedStep) -> str:
        target = step.label or step.selector or step.href or step.tag_name or "element"
        if step.type == "click":
            return f"Click {target} on {step.page_url}"
        if step.type == "input":
            return f'Enter "{step.value}" into {target} on {step.page_url}'
        if step.type == "select":
            chosen = step.option_text or step.value
            return f'Select "{chosen}" from {target} on {step.page_url}'
        if step.type == "checkbox":
            action = "Check" if step.checked else "Uncheck"
            return f"{action} {target} on {step.page_url}"
        if step.type == "radio":
            return f"Choose {target} on {step.page_url}"
        if step.type == "keydown":
            return f"Press {step.key} on {target} on {step.page_url}"
        if step.type == "shortcut_exit":
            return f"Press {step.key} to end recording on {step.page_url}"
        if step.type == "selector_mode":
            state = "enable" if step.selector_mode else "disable"
            return f"Use {step.key} to {state} JS element-pick mode on {step.page_url}"
        if step.type == "freeze_mode":
            state = "enable" if step.freeze_mode else "disable"
            return f"Use {step.key} to {state} freeze mode on {step.page_url}"
        if step.type == "element_capture":
            if step.tag_name == "select":
                if step.selected_options and " | " in step.selected_options:
                    return f'Capture multiselect {target}; selected options are "{step.selected_options}" on {step.page_url}'
                if step.option_text or step.value:
                    return f'Capture dropdown {target}; dropdown value is "{step.option_text or step.value}" on {step.page_url}'
            if step.input_type == "checkbox":
                state = "selected" if step.checked else "not selected"
                return f"Capture checkbox {target}; it is {state} on {step.page_url}"
            if step.input_type == "radio":
                state = "selected" if step.checked else "not selected"
                return f"Capture radio button {target}; it is {state} on {step.page_url}"
            if step.value:
                return f'Capture element {target}; current value is "{step.value}" with XPath {step.xpath or "-"} on {step.page_url}'
            return f"Capture element {target} with XPath {step.xpath or '-'} on {step.page_url}"
        return f"{step.type} {target} on {step.page_url}"

    def _escape_html(self, value: str) -> str:
        return (
            value.replace("&", "&amp;")
            .replace("<", "&lt;")
            .replace(">", "&gt;")
            .replace('"', "&quot;")
            .replace("'", "&#39;")
        )

    def _render_screenshot_link(self, value: str) -> str:
        if not value:
            return "-"
        href = self._escape_html(self._path_to_html_href(value))
        return f'<a href="{href}" target="_blank" rel="noopener noreferrer">open</a>'

    def _render_step_badge(self, step_number: int) -> str:
        return f'<span class="step-badge">{step_number}</span>'

    def _step_statuses(self, step: RecordedStep) -> list[tuple[str, str]]:
        statuses: list[tuple[str, str]] = []
        if self._is_control_step(step):
            statuses.append(("control", "control"))
        else:
            statuses.append(("recorded", "recorded"))
        if step.type == "selector_mode":
            statuses.append(("selector", "selector mode"))
        if step.type == "freeze_mode":
            statuses.append(("freeze", "freeze on" if step.freeze_mode else "freeze off"))
        if step.deferred_action:
            statuses.append(("replayed", "replayed click"))
        if step.screenshot_path:
            statuses.append(("shot", "page shot"))
        else:
            statuses.append(("missing", "page shot missing"))
        if self._expects_element_screenshot(step):
            if step.element_screenshot_path:
                statuses.append(("shot", "element crop"))
            else:
                statuses.append(("missing", "element crop missing"))
        return statuses

    def _render_status_cell(self, step: RecordedStep) -> str:
        chips = []
        for css_name, label in self._step_statuses(step):
            extra = " missing" if css_name == "missing" else ""
            chips.append(f'<span class="status-chip{extra}">{self._escape_html(label)}</span>')
        return f'<div class="status-list">{"".join(chips)}</div>'

    def _is_control_step(self, step: RecordedStep) -> bool:
        return step.type in {"selector_mode", "shortcut_exit", "freeze_mode"}

    def _step_row_class(self, step: RecordedStep) -> str:
        return "row-control" if self._is_control_step(step) else "row-user"

    def _expects_element_screenshot(self, step: RecordedStep) -> bool:
        return step.type in {"click", "checkbox", "radio", "select", "element_capture"}

    def _render_click_report_image(self, value: str, label: str, base_dir: Path | None = None) -> str:
        if not value:
            return (
                f'<div class="shot-card"><strong>{self._escape_html(label)}</strong>'
                '<div style="color:#6b7280;">Image not available for this step.</div></div>'
            )
        href = self._escape_html(self._path_to_html_href(value, base_dir=base_dir))
        return (
            f'<div class="shot-card"><strong>{self._escape_html(label)}</strong>'
            f'<a class="shot-link" href="{href}" target="_blank" rel="noopener noreferrer">open</a>'
            f'<img class="shot-thumb" src="{href}" alt="{self._escape_html(label)}" />'
            "</div>"
        )

    def _render_screenshot_cell(self, step: RecordedStep) -> str:
        return (
            '<div class="shot-stack">'
            f'{self._render_click_report_image(step.screenshot_path, "Page")}'
            f'{self._render_click_report_image(step.element_screenshot_path, "Element")}'
            "</div>"
        )

    def _render_locator_suggestions(self, step: RecordedStep, empty_html: str = "-") -> str:
        generic_locators = self._generic_locator_suggestions(step)
        if not step.playwright_locators and not generic_locators:
            return empty_html

        blocks: list[str] = []
        if step.primary_playwright_locator:
            blocks.append(
                '<div class="locator-primary"><strong>Preferred Playwright Locator</strong>'
                f'<code>{self._escape_html(step.primary_playwright_locator)}</code>'
                "</div>"
            )
        if step.playwright_locators:
            items = "".join(
                f"<li>{self._escape_html(locator)}</li>" for locator in step.playwright_locators
            )
            blocks.append(
                '<div class="locator-group"><div class="locator-heading">Playwright</div>'
                f'<ul class="locator-list">{items}</ul></div>'
            )
        if generic_locators:
            items = "".join(
                f"<li>{self._escape_html(locator)}</li>" for locator in generic_locators
            )
            blocks.append(
                '<div class="locator-group"><div class="locator-heading">Other Locators</div>'
                f'<ul class="locator-list">{items}</ul></div>'
            )
        return f'<div class="locator-blocks">{"".join(blocks)}</div>'

    def _render_object_cell(self, step: RecordedStep) -> str:
        parts = []
        if step.label:
            parts.append(f"<div><b>Text:</b> {self._escape_html(step.label)}</div>")
        elif step.value:
            parts.append(f"<div><b>Text:</b> {self._escape_html(step.value)}</div>")
        if step.selector:
            parts.append(f"<div><b>Selector:</b> <code>{self._escape_html(step.selector)}</code></div>")
        if step.xpath:
            parts.append(f"<div><b>XPath:</b> <code>{self._escape_html(step.xpath)}</code></div>")
        if step.value:
            parts.append(f"<div><b>Value:</b> {self._escape_html(step.value)}</div>")
        if step.selected_options:
            parts.append(f"<div><b>Selected:</b> {self._escape_html(step.selected_options)}</div>")
        if step.checked is not None and step.input_type in {"checkbox", "radio"}:
            state = "selected" if step.checked else "not selected"
            parts.append(f"<div><b>State:</b> {state}</div>")
        if not parts:
            return "-"
        return f'<div class="object-cell">{"".join(parts)}</div>'

    def _render_note_cell(self, step: RecordedStep) -> str:
        return (
            f'<textarea class="step-note" data-step="{step.step}" '
            f'placeholder="Add your website testing note for step {step.step}"></textarea>'
            '<span class="note-hint">Saved locally in this browser.</span>'
        )

    def _render_expected_cell(self, step: RecordedStep) -> str:
        return (
            f'<textarea class="step-expected" data-step="{step.step}" '
            f'placeholder="Describe the expected result for step {step.step}"></textarea>'
            '<span class="note-hint">Use this for the expected website behavior.</span>'
        )

    def _render_check_cell(self, step: RecordedStep) -> str:
        return (
            f'<select class="step-check" data-step="{step.step}">'
            '<option value="">Not set</option>'
            '<option value="pass">Pass</option>'
            '<option value="fail">Fail</option>'
            '<option value="manual">Manual Check</option>'
            "</select>"
        )

    def _path_to_html_href(self, value: str, base_dir: Path | None = None) -> str:
        base_dir = base_dir or OUTPUT_DIR
        try:
            path = Path(value)
            relative = path.relative_to(base_dir)
            return relative.as_posix()
        except Exception:
            try:
                path = Path(value)
                return os.path.relpath(path, start=base_dir).replace("\\", "/")
            except Exception:
                return Path(value).as_posix()

    def _handle_stop_signal(self, *_: Any) -> None:
        self.stop_event.set()

    def _handle_page_close(self, page: Page) -> None:
        with self._page_lock:
            self._tracked_pages.discard(id(page))
            remaining = len(self._tracked_pages)
        self._wired_pages.discard(id(page))

        print(f"Browser page closed. Remaining tracked pages: {remaining}", flush=True)
        if remaining == 0:
            self.stop_event.set()

    def _register_page(self, page: Page) -> None:
        with self._page_lock:
            page_id = id(page)
            if page_id in self._tracked_pages:
                return
            self._tracked_pages.add(page_id)
            tracked = len(self._tracked_pages)

        print(f"Tracking browser page. Open tracked pages: {tracked}", flush=True)

    def _tracked_page_count(self) -> int:
        with self._page_lock:
            return len(self._tracked_pages)

    def _handle_browser_disconnected(self, *_: Any) -> None:
        print("Browser disconnected.", flush=True)
        self.stop_event.set()

    def _handle_page_console(self, page: Page, text: str) -> None:
        if text.startswith("[recorder-event]"):
            try:
                payload = json.loads(text.removeprefix("[recorder-event]"))
            except json.JSONDecodeError:
                print(f"Failed to parse recorder event: {text}", flush=True)
                return

            if isinstance(payload, dict):
                self._enqueue_payload(payload, page=page)
            return

        if text.startswith("[recorder]"):
            print(text, flush=True)

    def _save_outputs(self) -> tuple[Path, Path | None, Path | None]:
        ended_at = datetime.now(timezone.utc)
        json_path = OUTPUT_DIR / "recording.json"
        html_path = OUTPUT_DIR / "recording.html" if self.emit_html_report else None
        playwright_path = (
            OUTPUT_DIR / "recording.playwright.py" if self.emit_playwright_export else None
        )

        json_payload = {
            "startUrl": self.start_url,
            "chromePath": str(self.chrome_path),
            "startedAt": self.started_at.isoformat(),
            "endedAt": ended_at.isoformat(),
            "stepCount": len(self.steps),
            "steps": [
                {
                    key: value
                    for key, value in asdict(step).items()
                    if key != "received_at"
                }
                for step in self.steps
            ],
        }
        json_path.write_text(json.dumps(json_payload, indent=2), encoding="utf-8")
        if html_path is not None:
            html_path.write_text(self._render_html_report(ended_at), encoding="utf-8")
        if playwright_path is not None:
            playwright_path.write_text(self._render_playwright_export(), encoding="utf-8")
        artifact_names = [f"json={json_path.name}"]
        if html_path is not None:
            artifact_names.append(f"html={html_path.name}")
        if playwright_path is not None:
            artifact_names.append(f"playwright={playwright_path.name}")
        self._debug(f"Artifacts updated: {' '.join(artifact_names)} step_count={len(self.steps)}")
        return json_path, html_path, playwright_path

    def _drain_recorded_events(self) -> None:
        if self.context is None:
            return

        for page in list(self.context.pages):
            if page.is_closed():
                continue

            try:
                payloads = page.evaluate(
                    """
                    () => {
                      const events = window.__pwRecordedEvents || [];
                      window.__pwRecordedEvents = [];
                      return events;
                    }
                    """
                )
            except Exception:
                continue

            for payload in payloads or []:
                if isinstance(payload, dict):
                    self._enqueue_payload(payload, page=page)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Record browser interactions with Playwright Python and a local Chrome executable."
    )
    parser.add_argument(
        "url",
        nargs="?",
        default=DEFAULT_START_URL,
        help="Start URL to open in the browser.",
    )
    parser.add_argument(
        "--chrome-path",
        default=None,
        help="Path to the locally installed Chrome executable.",
    )
    parser.add_argument(
        "--user-data-dir",
        default=None,
        help="Optional Chrome user data directory for persistent-profile recording.",
    )
    parser.add_argument(
        "--freeze-ms",
        type=int,
        default=1600,
        help="Delay in milliseconds used when freeze mode is enabled before replaying deferred actions.",
    )
    parser.add_argument(
        "--emit-html-report",
        action="store_true",
        help="Also generate artifacts\\recording.html.",
    )
    parser.add_argument(
        "--emit-playwright-export",
        action="store_true",
        help="Also generate artifacts\\recording.playwright.py.",
    )
    parser.add_argument(
        "--capture-step-artifacts",
        action="store_true",
        help="Also generate per-step screenshots and click reports.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    chrome_path = Path(args.chrome_path or os.environ.get("CHROME_PATH", DEFAULT_CHROME_PATH))
    user_data_dir = Path(args.user_data_dir) if args.user_data_dir else None
    app = RecorderApp(
        start_url=args.url,
        chrome_path=chrome_path,
        user_data_dir=user_data_dir,
        freeze_delay_ms=args.freeze_ms,
        emit_html_report=args.emit_html_report,
        emit_playwright_export=args.emit_playwright_export,
        capture_step_artifacts=args.capture_step_artifacts,
    )
    app.run()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
