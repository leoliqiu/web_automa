    def _render_text_report(self) -> str:
        lines = [self._describe_step(step) for step in self.steps]
        return "\n".join(lines) + ("\n" if lines else "")

    def _render_playwright_export(self) -> str:
        lines = [
            "from playwright.sync_api import Page, expect",
            "",
            "",
            "def replay_recording(page: Page) -> None:",
        ]
        replayable_steps = [step for step in self.steps if step.type not in {"shortcut_exit", "selector_mode", "freeze_mode"}]
        if not replayable_steps:
            lines.append("    pass")
            return "\n".join(lines) + "\n"

        first_url = next((step.page_url for step in replayable_steps if step.page_url), "")
        current_url = ""
        if first_url:
            lines.append(f"    page.goto({first_url!r}, wait_until='domcontentloaded')")
            lines.append(f"    expect(page).to_have_url({first_url!r})")
            current_url = first_url

        for index, step in enumerate(replayable_steps):
            next_step = replayable_steps[index + 1] if index + 1 < len(replayable_steps) else None
            if step.page_url and step.page_url != current_url:
                lines.append(f"    page.goto({step.page_url!r}, wait_until='domcontentloaded')")
                lines.append(f"    expect(page).to_have_url({step.page_url!r})")
                current_url = step.page_url

            lines.append(f"    # Step {step.step}: {self._describe_step(step)}")
            action_lines, resulting_url = self._playwright_lines_for_step(step, next_step)
            if action_lines:
                lines.extend(f"    {line}" for line in action_lines)
            if resulting_url:
                current_url = resulting_url
            lines.append("")

        return "\n".join(lines) + "\n"

    def _playwright_lines_for_step(
        self, step: RecordedStep, next_step: RecordedStep | None
    ) -> tuple[list[str], str | None]:
        target = self._playwright_target_expression(step)
        navigation_url = self._next_navigation_url(step, next_step)
        lines: list[str] = []

        if step.type == "click" and target:
            if navigation_url:
                lines.append("with page.expect_navigation(wait_until='domcontentloaded'):")
                lines.append(f"    {target}.click()")
                lines.append(f"expect(page).to_have_url({navigation_url!r})")
                return lines, navigation_url
            lines.append(f"{target}.click()")
            return lines, None

        if step.type == "input" and target:
            lines.append(f"{target}.fill({step.value!r})")
            if step.value:
                lines.append(f"expect({target}).to_have_value({step.value!r})")
            return lines, None

        if step.type == "select" and target and step.value:
            lines.append(f"{target}.select_option({step.value!r})")
            lines.append(f"expect({target}).to_have_value({step.value!r})")
            return lines, None

        if step.type == "checkbox" and target:
            lines.append(f"{target}.set_checked({bool(step.checked)!r})")
            if step.checked:
                lines.append(f"expect({target}).to_be_checked()")
            else:
                lines.append(f"expect({target}).not_to_be_checked()")
            return lines, None

        if step.type == "radio" and target:
            lines.append(f"{target}.check()")
            lines.append(f"expect({target}).to_be_checked()")
            return lines, None

        if step.type == "keydown" and step.key in {"Enter", "Tab", "Escape"}:
            lines.append(f'page.keyboard.press({step.key!r})')
            return lines, None

        if step.type == "element_capture" and target:
            lines.extend(self._playwright_assertion_lines(step, target))
            return lines, None

        return lines, None

    def _next_navigation_url(self, step: RecordedStep, next_step: RecordedStep | None) -> str | None:
        if step.type not in {"click", "checkbox", "radio", "select"}:
            return None
        if next_step is None or not next_step.page_url:
            return None
        if next_step.page_url == step.page_url:
            return None
        return next_step.page_url

    def _playwright_assertion_lines(self, step: RecordedStep, target: str) -> list[str]:
        lines = [f"expect({target}).to_be_visible()"]
        if step.input_type in {"checkbox", "radio"} and step.checked is not None:
            lines.append(
                f"expect({target}).{'to_be_checked()' if step.checked else 'not_to_be_checked()'}"
            )
            return lines
        if step.tag_name in {"input", "textarea"} and step.value:
            lines.append(f"expect({target}).to_have_value({step.value!r})")
            return lines
        if step.tag_name == "select" and step.value:
            lines.append(f"expect({target}).to_have_value({step.value!r})")
            return lines
        if step.label:
            lines.append(f"expect({target}).to_contain_text({step.label!r})")
        return lines

    def _playwright_target_expression(self, step: RecordedStep) -> str:
        derived_locators = self._derived_playwright_locators_from_step(step)
        if derived_locators:
            return derived_locators[0]
        selector = self._page_target_expression(step)
        if selector:
            return f"page.locator({selector!r})"
        return ""

    def _page_target_expression(self, step: RecordedStep) -> str:
        if step.xpath:
            return f"xpath={step.xpath}"
        if step.selector:
            return step.selector
        if step.locator_suggestions:
            for suggestion in step.locator_suggestions:
                if suggestion.startswith("CSS ID: "):
                    return suggestion.split("CSS ID: ", 1)[1]
                if suggestion.startswith("CSS Name: "):
                    return suggestion.split("CSS Name: ", 1)[1]
                if suggestion.startswith("CSS Href: "):
                    return suggestion.split("CSS Href: ", 1)[1]
                if suggestion.startswith("CSS Title: "):
                    return suggestion.split("CSS Title: ", 1)[1]
                if suggestion.startswith("CSS Class: "):
                    return suggestion.split("CSS Class: ", 1)[1]
        return ""

