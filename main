class BrowserLaunchWorker(QObject):
    """Worker thread for launching browser to prevent UI freezing."""
    success = pyqtSignal(object)
    error = pyqtSignal(str)
    finished = pyqtSignal()

    def __init__(self, url):
        super().__init__()
        self.url = url
        self.driver = None

    def run(self):
        """Run browser launch in background thread."""
        try:
            print(f"[Browser] Starting Chrome with URL: {self.url}")

            options = Options()
            options.add_argument("--start-maximized")
            options.add_argument("--disable-blink-features=AutomationControlled")
            options.add_argument("--disable-gpu")
            options.add_argument("--no-sandbox")
            options.add_argument("--disable-dev-shm-usage")
            options.add_experimental_option("excludeSwitches", ["enable-automation"])
            options.add_experimental_option("useAutomationExtension", False)

            print("[Browser] Locating ChromeDriver...")

            # Try local ChromeDriver first (C:\Python311)
            local_chromedriver = r"C:\Python311\chromedriver.exe"
            if os.path.exists(local_chromedriver):
                chromedriver_path = local_chromedriver
                print(f"[Browser] Using local ChromeDriver: {chromedriver_path}")
            else:
                # Fallback to ChromeDriverManager
                print("[Browser] Installing ChromeDriver from webdriver-manager...")
                try:
                    chromedriver_path = ChromeDriverManager().install()
                    print(f"[Browser] ChromeDriver path: {chromedriver_path}")
                except Exception as e:
                    print(f"[Browser] ChromeDriver error: {str(e)}")
                    raise Exception(f"Failed to get ChromeDriver: {str(e)}")

            print(f"[Browser] Creating Chrome instance...")
            self.driver = webdriver.Chrome(
                service=Service(chromedriver_path),
                options=options
            )

            print(f"[Browser] Setting timeouts...")
            self.driver.set_page_load_timeout(30)
            self.driver.set_script_timeout(30)

            print(f"[Browser] Navigating to {self.url}...")
            self.driver.get(self.url)

            print(f"[Browser] Browser launched successfully!")
            self.success.emit(self.driver)

        except Exception as e:
            error_msg = f"{str(e)}\n\nType: {type(e).__name__}\n\nTroubleshooting:\n- Make sure Chrome browser is installed\n- Internet connection is available\n- URL is valid (e.g., https://www.wikipedia.org)\n- Try checking proxy settings if behind corporate firewall"
            print(f"[Browser] Error: {str(e)}")
            self.error.emit(error_msg)
        finally:
            self.finished.emit()


class EnterpriseDashboard(QMainWindow):

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Enterprise Locator Intelligence Dashboard")
        self.setGeometry(60, 40, 1680, 980)
        self.driver = None
        self.engine = None
        self.browser_thread = None
        self.browser_worker = None
        self.bg_color_toggle = True
        self.init_ui()
        self.statusBar().showMessage("Ready. Use the Page Navigation panel to launch the browser.")

    def ensure_driver(self):
        if self.driver is None:
            QMessageBox.warning(self, "No Browser", "Browser is not launched. Please use 'Browser > Launch' first.")
            return False
        return True

    def _set_browser_status(self, is_online):
        """Update the browser status badge in the header."""
        if not hasattr(self, 'browser_status_badge'):
            return
        self.browser_status_badge.setText("Browser Online" if is_online else "Browser Offline")
        self.browser_status_badge.setObjectName("statusBadgeOnline" if is_online else "statusBadgeOffline")
        self.browser_status_badge.style().unpolish(self.browser_status_badge)
        self.browser_status_badge.style().polish(self.browser_status_badge)
        self.browser_status_badge.update()

