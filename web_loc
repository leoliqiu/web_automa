    def get_attribute(
        self,
        locator: str,
        attribute: str,
        locator_type: Optional[str] = None,
        timeout: Optional[float] = None,
        include_frames: bool = True,
        include_popups: bool = True,
    ) -> Optional[str]:
        match = self.wait_for(
            locator=locator,
            locator_type=locator_type,
            condition="present",
            timeout=timeout,
            include_frames=include_frames,
            include_popups=include_popups,
            activate_match=False,
        )
        if not match:
            raise TimeoutException(self._build_not_found_message("element for attribute read", locator))

        def _read_attribute(element: WebElement) -> Optional[str]:
            if attribute.lower() == "text":
                text_value = (element.text or "").strip()
                if text_value:
                    return text_value
                return self.driver.execute_script(
                    "return (arguments[0].innerText || arguments[0].textContent || '').trim();",
