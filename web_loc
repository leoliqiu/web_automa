    def extract_table(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        timeout: Optional[float] = None,
        include_frames: bool = True,
        include_popups: bool = True,
        element_is_table: bool = False,
    ) -> dict:
        match = self.wait_for(
            locator=locator,
            locator_type=locator_type,
            condition="present",
            timeout=timeout,
            include_frames=include_frames,
            include_popups=include_popups,
            activate_match=False,
        )
        if not match:
            raise TimeoutException(self._build_not_found_message("element for table extraction", locator))
        return self.extract_table_from_match(match, element_is_table=element_is_table)

    def extract_table_from_match(
        self,
        match: LocatorMatch,
        element_is_table: bool = False,
    ) -> dict:
        table = self._run_with_match(
            match,
            lambda element: self.extract_table_from_element(element, element_is_table=element_is_table),
        )
        if not table:
            target_label = "table element" if element_is_table else "table near element"
            raise TimeoutException(
                f"Unable to extract {target_label} using [{match.strategy_name}] {match.value}"
            )
        return {
            "strategy_name": match.strategy_name,
            "by": match.by,
            "value": match.value,
            "window_handle": match.window_handle,
            "frame_path": list(match.frame_path),
            "location": match.location_label,
            "found_in_popup": match.found_in_popup,
            "table": table,
        }

    def extract_table_from_element(
        self,
        element: WebElement,
        element_is_table: bool = False,
    ) -> Optional[dict]:
        return self._extract_table_context(element, element_is_table=element_is_table)

    def describe_match(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        timeout: Optional[float] = None,
        include_frames: bool = True,
        include_popups: bool = True,
    ) -> dict:
        match = self.wait_for(
            locator=locator,
            locator_type=locator_type,
            condition="present",
            timeout=timeout,
            include_frames=include_frames,
            include_popups=include_popups,
            activate_match=False,
        )
        if not match:
            raise TimeoutException(self._build_not_found_message("element", locator))

        def _snapshot(element: WebElement) -> dict:
            return {
                "strategy_name": match.strategy_name,
                "by": match.by,
                "value": match.value,
                "window_handle": match.window_handle,
                "frame_path": list(match.frame_path),
                "location": match.location_label,
                "found_in_popup": match.found_in_popup,
                "tag": element.tag_name,
                "id": element.get_attribute("id"),
                "name": element.get_attribute("name"),
                "class": element.get_attribute("class"),
                "type": element.get_attribute("type"),
                "value_attribute": element.get_attribute("value"),
                "href": element.get_attribute("href"),
                "text": (element.text or "").strip(),
                "displayed": element.is_displayed(),
                "enabled": element.is_enabled(),
            }

        return self._run_with_match(match, _snapshot)

    def click_match(self, match: LocatorMatch) -> LocatorMatch:
        self._run_with_match(match, lambda element: self._click_with_fallback(element), condition="clickable")
        return match

    def get_value_from_match(self, match: LocatorMatch) -> str:
        return self._run_with_match(match, self._extract_best_value)

    def get_text_from_match(self, match: LocatorMatch) -> str:
        value = self._run_with_match(
            match,
            lambda element: (
                (element.text or "").strip()
                or self.driver.execute_script(
                    "return (arguments[0].innerText || arguments[0].textContent || '').trim();",
                    element,
                )
            ),
        )
        return value or ""

    def get_href_from_match(self, match: LocatorMatch) -> Optional[str]:
        return self.get_attribute_from_match(match, "href")

    def get_attribute_from_match(self, match: LocatorMatch, attribute: str) -> Optional[str]:
        def _read_attribute(element: WebElement) -> Optional[str]:
            if attribute.lower() == "text":
                text_value = (element.text or "").strip()
                if text_value:
                    return text_value
                return self.driver.execute_script(
                    "return (arguments[0].innerText || arguments[0].textContent || '').trim();",
                    element,
                )
            return element.get_attribute(attribute)

        return self._run_with_match(match, _read_attribute)

    def suggest_locators(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        include_frames: bool = True,
        include_popups: bool = True,
        limit: Optional[int] = None,
    ) -> List[dict]:
        suggestions = self._generate_locator_suggestions(
            locator=locator,
            locator_type=locator_type,
            include_frames=include_frames,
            include_popups=include_popups,
            limit=limit,
        )
        self.last_suggestions = suggestions
        return [self._suggestion_to_dict(item) for item in suggestions]

    def switch_to_match(self, match: LocatorMatch) -> None:
        self._activate_match_context(match)

    def get_last_suggestions(self) -> List[dict]:
        return [self._suggestion_to_dict(item) for item in self.last_suggestions]

    def accept_alert(self, timeout: float = 2.0) -> bool:
        end_time = time.time() + float(timeout)
        while time.time() < end_time:
            try:
                self.driver.switch_to.alert.accept()
                return True
            except NoAlertPresentException:
                time.sleep(self.poll_frequency)
        return False

    def dismiss_alert(self, timeout: float = 2.0) -> bool:
        end_time = time.time() + float(timeout)
        while time.time() < end_time:
            try:
                self.driver.switch_to.alert.dismiss()
                return True
            except NoAlertPresentException:
                time.sleep(self.poll_frequency)
        return False

    def _get_handles(self, origin_handle: str, include_popups: bool) -> List[str]:
        handles = [origin_handle]
        if include_popups:
            handles.extend(handle for handle in self.driver.window_handles if handle != origin_handle)
        return handles[: self.max_window_handles]

    def _search_handles(
        self,
        handles: Sequence[str],
        strategies: Sequence[Tuple[str, str, str]],
        condition: str,
        include_frames: bool,
        timeout_per_attempt: Optional[float],
    ) -> Optional[LocatorMatch]:
        for index, handle in enumerate(handles):
            match = self._search_window(
                handle=handle,
                strategies=strategies,
                condition=condition,
                include_frames=include_frames,
                found_in_popup=index > 0,
                timeout_per_attempt=timeout_per_attempt,
            )
            if match:
                return match
        return None

    def _search_window(
        self,
        handle: str,
        strategies: Sequence[Tuple[str, str, str]],
        condition: str,
        include_frames: bool,
        found_in_popup: bool,
        timeout_per_attempt: Optional[float],
    ) -> Optional[LocatorMatch]:
        self.driver.switch_to.window(handle)
        self.driver.switch_to.default_content()
        self.wait_for_page_ready(timeout=min(2.0, self.page_ready_timeout))
        self._wait_for_page_idle(timeout=min(self.spinner_timeout, 3.0))

        match = self._search_current_context(
            strategies=strategies,
            handle=handle,
            frame_path=(),
            condition=condition,
            found_in_popup=found_in_popup,
            timeout_per_attempt=timeout_per_attempt,
        )
        if match or not include_frames:
            return match

        for frame_path in self._collect_frame_paths():
            if not frame_path:
                continue
            try:
                self._switch_to_frame_path(frame_path)
                self.wait_for_page_ready(timeout=min(1.5, self.page_ready_timeout))
                self._wait_for_page_idle(timeout=min(self.spinner_timeout, 2.0))
                match = self._search_current_context(
                    strategies=strategies,
                    handle=handle,
                    frame_path=frame_path,
                    condition=condition,
                    found_in_popup=found_in_popup,
                    timeout_per_attempt=timeout_per_attempt,
                )
                if match:
                    return match
            except WebDriverException:
                continue
            finally:
                self.driver.switch_to.default_content()

        return None

    def _attempt_recovery_search(
        self,
        locator: str,
        locator_type: Optional[str],
        condition: str,
        include_frames: bool,
        include_popups: bool,
        timeout_per_attempt: Optional[float],
        activate_match: bool,
        origin_handle: str,
    ) -> Optional[LocatorMatch]:
        strategies = self._build_recovery_candidates(locator, locator_type)
        if not strategies:
            self._restore_origin(origin_handle)
            return None

        recovery_timeout = self.recovery_attempt_timeout if timeout_per_attempt is None else min(
            float(timeout_per_attempt),
            self.recovery_attempt_timeout,
        )
        match = self._search_handles(
            handles=self._get_handles(origin_handle, include_popups),
            strategies=strategies,
            condition=condition,
            include_frames=include_frames,
            timeout_per_attempt=recovery_timeout,
        )
        if match:
            if activate_match:
                self._activate_match_context(match)
            else:
                self._restore_origin(origin_handle)
            return match

        self._restore_origin(origin_handle)
        return None

    def _search_current_context(
        self,
        strategies: Sequence[Tuple[str, str, str]],
        handle: str,
        frame_path: Sequence[int],
        condition: str,
        found_in_popup: bool,
        timeout_per_attempt: Optional[float],
    ) -> Optional[LocatorMatch]:
        active_modal_roots = self._get_active_modal_roots()
        for strategy_name, by, value in strategies:
            try:
                for modal_root in active_modal_roots:
                    modal_element = self._find_element_within_root(modal_root, by, value, condition)
                    if modal_element:
                        return LocatorMatch(
                            strategy_name=f"{strategy_name} [modal]",
                            by=by,
                            value=value,
                            window_handle=handle,
                            frame_path=tuple(frame_path),
                            found_in_popup=found_in_popup,
                        )
                element = self._wait_for_element_in_current_context(
                    by=by,
                    value=value,
                    condition=condition,
                    timeout=timeout_per_attempt,
                )
                if element:
                    return LocatorMatch(
                        strategy_name=strategy_name,
                        by=by,
                        value=value,
                        window_handle=handle,
                        frame_path=tuple(frame_path),
                        found_in_popup=found_in_popup,
                    )
            except (InvalidSelectorException, TimeoutException, WebDriverException):
                continue
        return None

    def _wait_for_element_in_current_context(
        self,
        by: str,
        value: str,
        condition: str,
        timeout: Optional[float] = None,
    ) -> WebElement:
        immediate_match = self._find_element_immediately(by, value, condition)
        if immediate_match:
            return immediate_match

        timeout = self.attempt_timeout if timeout is None else float(timeout)
        wait = WebDriverWait(
            self.driver,
            timeout,
            poll_frequency=self.poll_frequency,
            ignored_exceptions=(StaleElementReferenceException,),
        )
        locator = (by, value)
        condition_key = (condition or "present").strip().lower()

        if condition_key == "clickable":
            return wait.until(EC.element_to_be_clickable(locator))
        if condition_key == "visible":
            return wait.until(EC.visibility_of_element_located(locator))
        return wait.until(EC.presence_of_element_located(locator))

    def _find_element_within_root(
        self,
        root: WebElement,
        by: str,
        value: str,
        condition: str,
    ) -> Optional[WebElement]:
        try:
            elements = root.find_elements(by, value)
        except (InvalidSelectorException, WebDriverException):
            return None

        for element in elements:
            try:
                if self._element_matches_condition(element, condition):
                    return element
            except WebDriverException:
                continue
        return None

    def _find_element_immediately(
        self,
        by: str,
        value: str,
        condition: str,
    ) -> Optional[WebElement]:
        try:
            elements = self.driver.find_elements(by, value)
        except (InvalidSelectorException, WebDriverException):
            return None

        for element in elements:
            try:
                if self._element_matches_condition(element, condition):
                    return element
            except WebDriverException:
                continue
        return None

    def _element_matches_condition(self, element: WebElement, condition: str) -> bool:
        condition_key = (condition or "present").strip().lower()
        if condition_key == "clickable":
            return element.is_displayed() and element.is_enabled()
        if condition_key == "visible":
            return element.is_displayed()
        return True

    def _activate_match_context(self, match: LocatorMatch) -> None:
        self.driver.switch_to.window(match.window_handle)
        self.driver.switch_to.default_content()
        self.wait_for_page_ready(timeout=min(2.0, self.page_ready_timeout))
        self._wait_for_page_idle(timeout=min(self.spinner_timeout, 3.0))
        if match.frame_path:
            self._switch_to_frame_path(match.frame_path)
            self.wait_for_page_ready(timeout=min(1.5, self.page_ready_timeout))
            self._wait_for_page_idle(timeout=min(self.spinner_timeout, 2.0))

    def _run_with_match(
        self,
        match: LocatorMatch,
        callback: Callable[[WebElement], object],
        condition: str = "present",
    ) -> object:
        last_error: Optional[Exception] = None
        for attempt in range(2):
            try:
                self._activate_match_context(match)
                element = self._wait_for_element_in_current_context(
                    by=match.by,
                    value=match.value,
                    condition=condition,
                    timeout=self.attempt_timeout,
                )
                return callback(element)
            except StaleElementReferenceException as exc:
                last_error = exc
                continue
            except WebDriverException as exc:
                message = str(exc).lower()
                if attempt == 0 and ("stale" in message or "not attached" in message):
                    last_error = exc
                    continue
                raise
        if last_error:
            raise last_error
        raise TimeoutException("Unable to operate on cached match")

    def _restore_origin(self, origin_handle: str) -> None:
        self.driver.switch_to.window(origin_handle)
        self.driver.switch_to.default_content()

    def _switch_to_frame_path(self, frame_path: Sequence[int]) -> None:
        self.driver.switch_to.default_content()
        for frame_index in frame_path:
            frames = self.driver.find_elements(By.CSS_SELECTOR, "iframe, frame")
            if frame_index >= len(frames):
                raise IndexError(f"Frame index {frame_index} is out of range for path {frame_path}")
            self.driver.switch_to.frame(frames[frame_index])

    def _collect_frame_paths(
        self,
        frame_path: Optional[Sequence[int]] = None,
        max_depth: Optional[int] = None,
    ) -> List[Tuple[int, ...]]:
        if frame_path is None:
            cache_key = self._current_page_key()
            cached_paths = self._frame_paths_cache.get(cache_key)
            if cached_paths:
                return list(cached_paths)

        start_path = tuple(frame_path or ())
        max_depth = self.max_frame_depth if max_depth is None else int(max_depth)
        paths: List[Tuple[int, ...]] = [start_path]
        queue: List[Tuple[int, ...]] = [start_path]

        while queue and len(paths) < self.max_frame_paths:
            current_path = queue.pop(0)
            if len(current_path) >= max_depth:
                continue

            try:
                self._switch_to_frame_path(current_path)
                frame_count = len(self.driver.find_elements(By.CSS_SELECTOR, "iframe, frame"))
            except WebDriverException:
                frame_count = 0
            finally:
                self.driver.switch_to.default_content()

            for index in range(frame_count):
                child_path = current_path + (index,)
                paths.append(child_path)
                if len(paths) >= self.max_frame_paths:
                    break
                queue.append(child_path)

        if frame_path is None:
            self._frame_paths_cache[self._current_page_key()] = list(paths)
        return paths

    def _build_strategy_candidates(
        self,
        locator: str,
        locator_type: Optional[str] = None,
    ) -> List[Tuple[str, str, str]]:
        locator = (locator or "").strip()
        if not locator:
            return []

        explicit_type, normalized_locator = self._extract_prefixed_locator(locator)
        if explicit_type and not locator_type:
            locator_type = explicit_type
            locator = normalized_locator

        normalized_type = self._normalize_locator_type(locator_type)
        if normalized_type == "xpath":
            return self._xpath_strategies(locator)
        if normalized_type == "id":
            return self._id_strategies(locator)
        if normalized_type == "css selector":
            return [("CSS Selector", By.CSS_SELECTOR, locator)]
        if normalized_type == "class name":
            return self._class_strategies(locator)
        if normalized_type == "name":
            return [
                ("Name", By.NAME, locator),
                ("XPath Name", By.XPATH, f"//*[@name={self._escape_xpath_text(locator)}]"),
            ]
        if normalized_type == "tag name":
            return [("Tag Name", By.TAG_NAME, locator)]
        if normalized_type == "link text":
            return [("Link Text", By.LINK_TEXT, locator)]
        if normalized_type == "partial link text":
            return [("Partial Link Text", By.PARTIAL_LINK_TEXT, locator)]
        if normalized_type == "href":
            return [
                ("XPath Href", By.XPATH, f"//*[@href={self._escape_xpath_text(locator)}]"),
                ("CSS Href", By.CSS_SELECTOR, f"[href={self._quote_css_value(locator)}]"),
            ]
        if normalized_type == "sibling":
            return self._sibling_strategies(locator)
        if normalized_type == "text":
            return self._text_strategies(locator)

        strategies: List[Tuple[str, str, str]] = []

        if self._looks_like_xpath(locator):
            strategies.extend(self._xpath_strategies(locator))
        if self._looks_like_css(locator):
            strategies.append(("CSS Selector", By.CSS_SELECTOR, locator))
        if self._looks_like_href(locator):
            strategies.extend(
                [
                    ("XPath Href", By.XPATH, f"//*[@href={self._escape_xpath_text(locator)}]"),
                    ("CSS Href", By.CSS_SELECTOR, f"[href={self._quote_css_value(locator)}]"),
                ]
            )
        if self._looks_like_sibling(locator):
            strategies.extend(self._sibling_strategies(locator))

        if self._is_simple_token(locator):
            strategies.extend(self._id_strategies(locator))
            strategies.extend(self._class_strategies(locator))
            strategies.append(("Name", By.NAME, locator))
            strategies.append(("Data TestId", By.CSS_SELECTOR, f"[data-testid={self._quote_css_value(locator)}]"))
            strategies.append(("Data Qa", By.CSS_SELECTOR, f"[data-qa={self._quote_css_value(locator)}]"))

        strategies.extend(self._text_strategies(locator))
        return self._deduplicate_strategies(strategies)

    def _build_recovery_candidates(
        self,
        locator: str,
        locator_type: Optional[str] = None,
    ) -> List[Tuple[str, str, str]]:
        terms = self._extract_recovery_terms(locator, locator_type)
        strategies: List[Tuple[str, str, str]] = []

        for term in terms:
            escaped = self._escape_xpath_text(term)
            strategies.extend(
                [
                    ("Recover Text Contains", By.XPATH, f"//*[contains(normalize-space(.), {escaped})]"),
                    ("Recover ID Contains", By.XPATH, f"//*[contains(@id, {escaped})]"),
                    ("Recover Name Contains", By.XPATH, f"//*[contains(@name, {escaped})]"),
                    ("Recover Class Contains", By.XPATH, f"//*[contains(@class, {escaped})]"),
                    ("Recover Aria Label Exact", By.XPATH, f"//*[@aria-label={escaped}]"),
                    ("Recover Aria Label Contains", By.XPATH, f"//*[contains(@aria-label, {escaped})]"),
                    ("Recover Placeholder Exact", By.XPATH, f"//*[@placeholder={escaped}]"),
                    ("Recover Placeholder Contains", By.XPATH, f"//*[contains(@placeholder, {escaped})]"),
                    ("Recover Title Contains", By.XPATH, f"//*[contains(@title, {escaped})]"),
                    ("Recover Value Contains", By.XPATH, f"//*[contains(@value, {escaped})]"),
                    ("Recover Data TestId Exact", By.XPATH, f"//*[@data-testid={escaped}]"),
                    ("Recover Data TestId Contains", By.XPATH, f"//*[contains(@data-testid, {escaped})]"),
                    ("Recover Data Qa Exact", By.XPATH, f"//*[@data-qa={escaped}]"),
                    ("Recover Href Contains", By.XPATH, f"//*[contains(@href, {escaped})]"),
                ]
            )

            if self._is_simple_token(term):
                strategies.extend(self._id_strategies(term))
                strategies.extend(self._class_strategies(term))

            stem = self._stable_token_stem(term)
            if stem and stem != term:
                stem_escaped = self._escape_xpath_text(stem)
                strategies.extend(
                    [
                        ("Recover ID Stem", By.XPATH, f"//*[contains(@id, {stem_escaped})]"),
                        ("Recover Class Stem", By.XPATH, f"//*[contains(@class, {stem_escaped})]"),
                        ("Recover Name Stem", By.XPATH, f"//*[contains(@name, {stem_escaped})]"),
                    ]
                )

        return self._deduplicate_strategies(strategies)[: self.max_recovery_strategies]

    def _xpath_strategies(self, locator: str) -> List[Tuple[str, str, str]]:
        strategies = [("XPath", By.XPATH, locator)]
        corrected = self._correct_xpath(locator)
        if corrected != locator:
            strategies.append(("XPath Corrected", By.XPATH, corrected))
        return strategies

    def _id_strategies(self, locator: str) -> List[Tuple[str, str, str]]:
        return [
            ("ID", By.ID, locator),
            ("CSS ID", By.CSS_SELECTOR, f"[id={self._quote_css_value(locator)}]"),
            ("XPath ID", By.XPATH, f"//*[@id={self._escape_xpath_text(locator)}]"),
        ]

    def _class_strategies(self, locator: str) -> List[Tuple[str, str, str]]:
        stable_tokens = self._stable_class_tokens(locator)
        strategies: List[Tuple[str, str, str]] = []
        if len(stable_tokens) == 1:
            strategies.append(("Class Name", By.CLASS_NAME, stable_tokens[0]))
            strategies.append(("CSS Class", By.CSS_SELECTOR, f".{stable_tokens[0]}"))
        elif stable_tokens:
            strategies.append(("CSS Class Group", By.CSS_SELECTOR, "".join(f".{token}" for token in stable_tokens)))
            for token in stable_tokens:
                strategies.append(("CSS Single Class", By.CSS_SELECTOR, f".{token}"))
        return self._deduplicate_strategies(strategies)

    def _text_strategies(self, locator: str) -> List[Tuple[str, str, str]]:
        escaped = self._escape_xpath_text(locator)
        return [
            ("Text Contains", By.XPATH, f"//*[contains(normalize-space(.), {escaped})]"),
            ("Text Exact", By.XPATH, f"//*[normalize-space(.)={escaped}]"),
            ("Link Text", By.LINK_TEXT, locator),
            ("Partial Link Text", By.PARTIAL_LINK_TEXT, locator),
        ]

    def _sibling_strategies(self, locator: str) -> List[Tuple[str, str, str]]:
        if self._looks_like_xpath(locator):
            return self._xpath_strategies(locator)

        escaped = self._escape_xpath_text(locator)
        return [
            ("Sibling Following Exact", By.XPATH, f"//*[normalize-space(.)={escaped}]/following-sibling::*[1]"),
            ("Sibling Following Contains", By.XPATH, f"//*[contains(normalize-space(.), {escaped})]/following-sibling::*[1]"),
            ("Sibling Previous Exact", By.XPATH, f"//*[normalize-space(.)={escaped}]/preceding-sibling::*[1]"),
            ("Label Nearby Input", By.XPATH, f"//label[normalize-space(.)={escaped}]/following::*[self::input or self::textarea or self::select][1]"),
            ("Ancestor Sibling", By.XPATH, f"//*[normalize-space(.)={escaped}]/ancestor::*[1]/following-sibling::*[1]"),
        ]

    def _generate_locator_suggestions(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        include_frames: bool = True,
        include_popups: bool = True,
        limit: Optional[int] = None,
    ) -> List[LocatorSuggestion]:
        origin_handle = self.driver.current_window_handle
        limit = self.max_suggestions if limit is None else int(limit)
        search_terms = self._extract_recovery_terms(locator, locator_type)
        suggestions: List[LocatorSuggestion] = []
        seen = set()

        for handle in self._get_handles(origin_handle, include_popups):
            self.driver.switch_to.window(handle)
            self.driver.switch_to.default_content()
            self.wait_for_page_ready(timeout=min(2.0, self.page_ready_timeout))

            frame_paths = [()]
            if include_frames:
                frame_paths = self._collect_frame_paths()

            for frame_path in frame_paths[: self.max_frame_paths]:
                try:
                    self._switch_to_frame_path(frame_path)
                    for candidate in self._collect_dom_candidates(search_terms, limit=max(limit * 2, 8)):
                        for suggestion in self._candidate_to_suggestions(candidate, handle, frame_path):
                            key = (suggestion.by, suggestion.value, suggestion.window_handle, suggestion.frame_path)
                            if key in seen:
                                continue
                            seen.add(key)
                            suggestions.append(suggestion)
                            if len(suggestions) >= limit * 3:
                                break
                        if len(suggestions) >= limit * 3:
                            break
                except WebDriverException:
                    continue
                finally:
                    self.driver.switch_to.default_content()
                if len(suggestions) >= limit * 3:
                    break
            if len(suggestions) >= limit * 3:
                break

        self._restore_origin(origin_handle)
        suggestions.sort(key=lambda item: item.score, reverse=True)
        return suggestions[:limit]

    def _collect_dom_candidates(self, search_terms: Sequence[str], limit: int = 10) -> List[dict]:
        script = """
        const rawTerms = Array.isArray(arguments[0]) ? arguments[0] : [];
        const terms = rawTerms
            .map(value => (value || '').toString().trim().toLowerCase())
            .filter(Boolean)
            .slice(0, 6);
        const limit = Math.max(1, Number(arguments[1]) || 10);
        const selectors = [
            'a', 'button', 'input', 'textarea', 'select', 'option', 'label',
            '[role]', '[id]', '[name]', '[data-testid]', '[data-qa]',
            '[aria-label]', '[placeholder]', '[title]', '[href]'
        ];
        const nodes = Array.from(document.querySelectorAll(selectors.join(','))).slice(0, 1500);

        function clean(value) {
            return (value || '').replace(/\\s+/g, ' ').trim();
        }

        function stableClasses(value) {
            return clean(value).split(' ').filter(token => token && !(/[0-9]{3,}/.test(token))).slice(0, 3);
        }

        function score(entry) {
            if (!terms.length) return 1;
            let total = 0;
            const bag = [
                entry.text, entry.id, entry.name, entry.className, entry.ariaLabel,
                entry.placeholder, entry.title, entry.href, entry.value,
                entry.dataTestId, entry.dataQa
            ].join(' ').toLowerCase();

            for (const term of terms) {
                if (entry.id && entry.id.toLowerCase() === term) total += 160;
                if (entry.name && entry.name.toLowerCase() === term) total += 145;
                if (entry.dataTestId && entry.dataTestId.toLowerCase() === term) total += 145;
                if (entry.text && entry.text.toLowerCase() === term) total += 135;
                if (entry.ariaLabel && entry.ariaLabel.toLowerCase() === term) total += 125;
                if (entry.placeholder && entry.placeholder.toLowerCase() === term) total += 120;
                if (bag.includes(term)) total += 55;
                if (stableClasses(entry.className).some(token => token.toLowerCase() === term)) total += 70;
            }
            return total;
        }

        const results = [];
        for (const node of nodes) {
            const entry = {
                tag: (node.tagName || '').toLowerCase(),
                id: clean(node.id),
                name: clean(node.getAttribute('name')),
                className: clean(node.className),
                text: clean(node.innerText || node.textContent).slice(0, 120),
                href: clean(node.getAttribute('href')),
                value: clean(node.getAttribute('value')),
                ariaLabel: clean(node.getAttribute('aria-label')),
                placeholder: clean(node.getAttribute('placeholder')),
                title: clean(node.getAttribute('title')),
                dataTestId: clean(node.getAttribute('data-testid')),
                dataQa: clean(node.getAttribute('data-qa'))
            };
            entry.score = score(entry);
            if (entry.score > 0) {
                results.push(entry);
            }
        }

        results.sort((a, b) => b.score - a.score);
        return results.slice(0, limit);
        """
        try:
            return self.driver.execute_script(script, list(search_terms), int(limit)) or []
        except WebDriverException:
            return []

    def _get_active_modal_roots(self) -> List[WebElement]:
        modal_selectors = [
            "[role='dialog']",
            "[role='alertdialog']",
            ".modal",
            ".popup",
            ".dialog",
            ".drawer",
            ".lightbox",
            ".overlay",
            "[aria-modal='true']",
            "[data-testid*='modal']",
            "[class*='modal']",
            "[class*='dialog']",
            "[class*='popup']",
        ]
        roots: List[WebElement] = []
        seen = set()
        for selector in modal_selectors:
            try:
                for element in self.driver.find_elements(By.CSS_SELECTOR, selector):
                    if not self._is_effectively_visible(element):
                        continue
                    key = element.id
                    if key in seen:
                        continue
                    seen.add(key)
                    roots.append(element)
            except WebDriverException:
                continue
        return roots[:5]

    def _wait_for_page_idle(self, timeout: Optional[float] = None) -> bool:
        if not self.enable_spinner_wait:
            return True
        timeout = self.spinner_timeout if timeout is None else float(timeout)
        try:
            WebDriverWait(
                self.driver,
                timeout,
                poll_frequency=self.poll_frequency,
                ignored_exceptions=(WebDriverException, StaleElementReferenceException),
            ).until(lambda driver: not self._has_active_spinner_or_overlay())
            return True
        except TimeoutException:
            return False

    def _has_active_spinner_or_overlay(self) -> bool:
        script = """
        const selectors = [
            '.spinner', '.loading', '.loader', '.progress', '.busy', '.block-ui',
            '[role="progressbar"]', '[aria-busy="true"]',
            '[class*="spinner"]', '[class*="loading"]', '[class*="loader"]',
            '[data-testid*="spinner"]', '[data-testid*="loading"]'
        ];
        const nodes = Array.from(document.querySelectorAll(selectors.join(',')));
        return nodes.some(node => {
            const style = window.getComputedStyle(node);
            if (!style) return false;
            if (style.display === 'none' || style.visibility === 'hidden' || style.opacity === '0') return false;
            const rect = node.getBoundingClientRect();
            return rect.width > 0 && rect.height > 0;
        });
        """
        try:
            return bool(self.driver.execute_script(script))
        except WebDriverException:
            return False

    def _is_effectively_visible(self, element: WebElement) -> bool:
        try:
            if not element.is_displayed():
                return False
            rect = self.driver.execute_script(
                "const r = arguments[0].getBoundingClientRect(); return {w: r.width, h: r.height};",
                element,
            )
            return bool(rect and rect.get("w", 0) > 0 and rect.get("h", 0) > 0)
        except WebDriverException:
            return False

    def _candidate_to_suggestions(
        self,
        candidate: dict,
        window_handle: str,
        frame_path: Sequence[int],
    ) -> List[LocatorSuggestion]:
        suggestions: List[LocatorSuggestion] = []
        tag = (candidate.get("tag") or "*").strip() or "*"
        css_tag = "" if tag == "*" else tag
        score = int(candidate.get("score") or 0)

        element_id = (candidate.get("id") or "").strip()
        if element_id:
            suggestions.append(LocatorSuggestion("Suggested ID", By.ID, element_id, "Matched DOM id", score + 40, window_handle, tuple(frame_path)))
            suggestions.append(LocatorSuggestion("Suggested XPath ID", By.XPATH, f"//*[@id={self._escape_xpath_text(element_id)}]", "ID-based XPath", score + 35, window_handle, tuple(frame_path)))

        data_test_id = (candidate.get("dataTestId") or "").strip()
        if data_test_id:
            suggestions.append(LocatorSuggestion("Suggested Data TestId", By.CSS_SELECTOR, f"[data-testid={self._quote_css_value(data_test_id)}]", "Matched data-testid", score + 35, window_handle, tuple(frame_path)))

        data_qa = (candidate.get("dataQa") or "").strip()
        if data_qa:
            suggestions.append(LocatorSuggestion("Suggested Data Qa", By.CSS_SELECTOR, f"[data-qa={self._quote_css_value(data_qa)}]", "Matched data-qa", score + 30, window_handle, tuple(frame_path)))

        name = (candidate.get("name") or "").strip()
        if name:
            suggestions.append(LocatorSuggestion("Suggested Name", By.NAME, name, "Matched name attribute", score + 30, window_handle, tuple(frame_path)))

        href = (candidate.get("href") or "").strip()
        if href:
            suggestions.append(LocatorSuggestion("Suggested Href XPath", By.XPATH, f"//{tag}[@href={self._escape_xpath_text(href)}]", "Matched href", score + 25, window_handle, tuple(frame_path)))

        text = (candidate.get("text") or "").strip()
        if text:
            exact_text = text[:80]
            partial_text = text[:40]
            suggestions.append(LocatorSuggestion("Suggested Text Exact", By.XPATH, f"//{tag}[normalize-space(.)={self._escape_xpath_text(exact_text)}]", "Matched visible text", score + 25, window_handle, tuple(frame_path)))
            suggestions.append(LocatorSuggestion("Suggested Text Contains", By.XPATH, f"//{tag}[contains(normalize-space(.), {self._escape_xpath_text(partial_text)})]", "Partial text match", score + 20, window_handle, tuple(frame_path)))

        aria_label = (candidate.get("ariaLabel") or "").strip()
        if aria_label:
            suggestions.append(LocatorSuggestion("Suggested Aria Label", By.XPATH, f"//{tag}[@aria-label={self._escape_xpath_text(aria_label)}]", "Matched aria-label", score + 20, window_handle, tuple(frame_path)))

        placeholder = (candidate.get("placeholder") or "").strip()
        if placeholder:
            suggestions.append(LocatorSuggestion("Suggested Placeholder", By.XPATH, f"//{tag}[@placeholder={self._escape_xpath_text(placeholder)}]", "Matched placeholder", score + 20, window_handle, tuple(frame_path)))

        for class_token in self._stable_class_tokens(candidate.get("className") or "")[:2]:
            css_value = f"{css_tag}.{class_token}" if css_tag else f".{class_token}"
            suggestions.append(LocatorSuggestion("Suggested CSS Class", By.CSS_SELECTOR, css_value, "Stable class token", score + 15, window_handle, tuple(frame_path)))

        seen = set()
        deduped: List[LocatorSuggestion] = []
        for suggestion in suggestions:
            key = (suggestion.by, suggestion.value)
            if key in seen:
                continue
            seen.add(key)
            deduped.append(suggestion)
        return deduped[:4]

    def _current_page_key(self) -> Tuple[str, str]:
        try:
            return (self.driver.current_url or "", self.driver.title or "")
        except WebDriverException:
            return ("", "")

    def _match_cache_key(
        self,
        locator: str,
        locator_type: Optional[str],
        condition: str,
    ) -> Tuple[str, str, str, str, str]:
        page_url, page_title = self._current_page_key()
        return (
            page_url,
            page_title,
            (locator_type or "auto").strip().lower(),
            (condition or "present").strip().lower(),
            locator.strip(),
        )

    def _cache_match(
        self,
        locator: str,
        locator_type: Optional[str],
        condition: str,
        match: LocatorMatch,
    ) -> None:
        if not self.cache_successful_matches:
            return
        self._successful_match_cache[self._match_cache_key(locator, locator_type, condition)] = {
            "strategy_name": match.strategy_name,
            "by": match.by,
            "value": match.value,
            "window_handle": match.window_handle,
            "frame_path": tuple(match.frame_path),
            "found_in_popup": match.found_in_popup,
        }

    def _try_cached_match(
        self,
        locator: str,
        locator_type: Optional[str],
        condition: str,
        activate_match: bool,
        origin_handle: str,
    ) -> Optional[LocatorMatch]:
        if not self.cache_successful_matches:
            return None

        cache_item = self._successful_match_cache.get(self._match_cache_key(locator, locator_type, condition))
        if not cache_item:
            return None

        try:
            handles = self.driver.window_handles
            if cache_item["window_handle"] not in handles:
                self._successful_match_cache.pop(self._match_cache_key(locator, locator_type, condition), None)
                return None

            candidate = LocatorMatch(
                strategy_name=cache_item["strategy_name"],
                by=cache_item["by"],
                value=cache_item["value"],
                window_handle=cache_item["window_handle"],
                frame_path=tuple(cache_item["frame_path"]),
                found_in_popup=bool(cache_item["found_in_popup"]),
            )
            self._activate_match_context(candidate)
            self._wait_for_element_in_current_context(
                by=candidate.by,
                value=candidate.value,
                condition=condition,
                timeout=min(self.attempt_timeout, 0.5),
            )
            if not activate_match:
                self._restore_origin(origin_handle)
            return candidate
        except Exception:
            self._successful_match_cache.pop(self._match_cache_key(locator, locator_type, condition), None)
            self._restore_origin(origin_handle)
            return None

    def _extract_best_value(self, element: WebElement) -> str:
        tag_name = (element.tag_name or "").lower()
        if tag_name == "select":
            try:
                selected_texts = [option.text.strip() for option in Select(element).all_selected_options if option.text.strip()]
                if selected_texts:
                    return ", ".join(selected_texts)
            except WebDriverException:
                pass

        value = element.get_attribute("value")
        if value:
            return value

        text_value = (element.text or "").strip()
        if text_value:
            return text_value

        return self.driver.execute_script(
            "return (arguments[0].innerText || arguments[0].textContent || '').trim();",
            element,
        )

    def _extract_table_context(
        self,
        element: WebElement,
        element_is_table: bool = False,
    ) -> Optional[dict]:
        script = """
        const element = arguments[0];
        const elementIsTable = !!arguments[1];

        function stableClasses(node) {
            if (!node) return [];
            return (node.className || '')
                .split(/\\s+/)
                .map(token => token.trim())
                .filter(token => token && !(/[0-9]{3,}/.test(token) || (token.length > 10 && /[A-Za-z]/.test(token) && /\\d/.test(token))))
                .slice(0, 3);
        }

        function cleanText(value) {
            return (value || '').replace(/\\s+/g, ' ').trim();
        }

        function getElementText(node) {
            return cleanText(node ? (node.innerText || node.textContent || '') : '');
        }

        function buildXPath(node) {
            if (!node) return '';
            if (node.id) {
                return `//${node.tagName.toLowerCase()}[@id="${node.id}"]`;
            }

            const path = [];
            let current = node;
            while (current && current.nodeType === 1) {
                let index = 1;
                let sibling = current.previousElementSibling;
                while (sibling) {
                    if (sibling.tagName === current.tagName) {
                        index += 1;
                    }
                    sibling = sibling.previousElementSibling;
                }
                path.unshift(`${current.tagName.toLowerCase()}[${index}]`);
                current = current.parentElement;
                if (current && current.tagName && current.tagName.toLowerCase() === 'html') {
                    path.unshift('html[1]');
                    break;
                }
            }
            return '/' + path.join('/');
        }

        function getCellText(cell) {
            return getElementText(cell);
        }

        function reconstructRows(table) {
            const sourceRows = Array.from(table.querySelectorAll('tr'));
            const grid = [];
            const activeSpans = [];

            sourceRows.forEach((row, rowIndex) => {
                if (!grid[rowIndex]) {
                    grid[rowIndex] = [];
                }

                let columnIndex = 0;
                while (activeSpans[columnIndex] && activeSpans[columnIndex].remaining > 0) {
                    grid[rowIndex][columnIndex] = activeSpans[columnIndex].text;
                    activeSpans[columnIndex].remaining -= 1;
                    if (activeSpans[columnIndex].remaining <= 0) {
                        activeSpans[columnIndex] = null;
                    }
                    columnIndex += 1;
                }

                const cells = Array.from(row.children).filter(cell => {
                    const tag = (cell.tagName || '').toLowerCase();
                    return tag === 'th' || tag === 'td';
                });

                cells.forEach(cell => {
                    while (grid[rowIndex][columnIndex] !== undefined) {
                        columnIndex += 1;
                    }

                    const text = getCellText(cell);
                    const rowSpan = parseInt(cell.getAttribute('rowspan') || '1', 10);
                    const colSpan = parseInt(cell.getAttribute('colspan') || '1', 10);

                    for (let colOffset = 0; colOffset < colSpan; colOffset += 1) {
                        grid[rowIndex][columnIndex + colOffset] = text;
                        if (rowSpan > 1) {
                            activeSpans[columnIndex + colOffset] = {
                                text: text,
                                remaining: rowSpan - 1
                            };
                        }
                    }
                    columnIndex += colSpan;

                    while (activeSpans[columnIndex] && activeSpans[columnIndex].remaining > 0) {
                        grid[rowIndex][columnIndex] = activeSpans[columnIndex].text;
                        activeSpans[columnIndex].remaining -= 1;
                        if (activeSpans[columnIndex].remaining <= 0) {
                            activeSpans[columnIndex] = null;
                        }
                        columnIndex += 1;
                    }
                });
            });

            return grid
                .map(row => row.map(cell => cleanText(cell || '')))
                .filter(row => row.some(cell => cell));
        }

        function getCandidateTables(node) {
            const candidates = [];
            const seen = new Set();
            let current = node;

            while (current && current.nodeType === 1) {
                let scopedTables = [];
                const tag = (current.tagName || '').toLowerCase();
                if (tag === 'table' || tag === 'grid' || current.getAttribute('role') === 'table' || current.getAttribute('role') === 'grid') {
                    scopedTables.push(current);
                }
                scopedTables = scopedTables.concat(Array.from(current.querySelectorAll('table, [role="table"], [role="grid"]')));
                scopedTables.forEach(table => {
                    if (!seen.has(table)) {
                        seen.add(table);
                        candidates.push(table);
                    }
                });
                current = current.parentElement;
            }
            return candidates;
        }

        function scoreTable(table, targetText) {
            const rows = reconstructRows(table);
            const tableText = getElementText(table);
            let score = 0;
            if (table === element) {
                score += 150;
            }
            if (table.contains(element)) {
                score += 100;
            }
            if (targetText && tableText.includes(targetText)) {
                score += 20;
            }
            if (rows.some(row => row.some(cell => targetText && cell.includes(targetText)))) {
                score += 40;
            }
            score += Math.min(rows.length, 20);
            return { table, rows, score };
        }

        const targetText = getElementText(element);
        const candidateTables = (elementIsTable ? [element] : getCandidateTables(element))
            .map(table => scoreTable(table, targetText))
            .sort((a, b) => b.score - a.score);

        if (!candidateTables.length || candidateTables[0].score <= 0) {
            return null;
        }

        const table = candidateTables[0].table;
        const rows = candidateTables[0].rows;

        let headers = [];
        const headerCells = table.querySelectorAll('thead th');
        if (headerCells.length) {
            headers = Array.from(headerCells).map(cell => cleanText(cell.innerText || cell.textContent));
        } else if (rows.length > 0) {
            headers = rows[0];
        }

        const stableTableClasses = stableClasses(table);
        const classXPath = stableTableClasses.length
            ? `//${table.tagName.toLowerCase()}[` + stableTableClasses.map(token => `contains(@class,"${token}")`).join(' and ') + `]`
            : '';

        return {
            tag: (table.tagName || '').toLowerCase(),
            id: table.id || '',
            classes: stableTableClasses,
            xpath: buildXPath(table),
            class_xpath: classXPath,
            headers: headers,
            rows: rows,
            row_count: rows.length,
            column_count: rows.reduce((maxCols, row) => Math.max(maxCols, row.length), 0),
            anchor_text: targetText
        };
        """
        try:
            return self.driver.execute_script(script, element, element_is_table)
        except WebDriverException:
            return None

    def _click_with_fallback(self, element: WebElement) -> None:
        self._scroll_into_view(element)
        try:
            element.click()
            return
        except WebDriverException:
            pass

        try:
            ActionChains(self.driver).move_to_element(element).pause(0.1).click(element).perform()
            return
        except WebDriverException:
            pass

        self.driver.execute_script("arguments[0].click();", element)

    def _calculate_retry_delay(
        self,
        attempt: int,
        wait_seconds: float,
        use_exponential_backoff: bool,
        max_wait_seconds: float,
    ) -> float:
        if use_exponential_backoff:
            return min(float(2 ** attempt), float(max_wait_seconds))
        return min(float(wait_seconds), float(max_wait_seconds))

    def _scroll_into_view(self, element: WebElement) -> None:
        self.driver.execute_script(
            "arguments[0].scrollIntoView({block: 'center', inline: 'nearest'});",
            element,
        )

    def _is_document_ready(self) -> bool:
        try:
            try:
                self.driver.switch_to.alert
                return True
            except NoAlertPresentException:
                pass
            state = self.driver.execute_script("return document.readyState")
            body_present = self.driver.execute_script("return !!document.body")
            jquery_ready = self.driver.execute_script("return window.jQuery ? window.jQuery.active === 0 : true")
            return state == "complete" and bool(body_present) and bool(jquery_ready)
        except WebDriverException:
            return False

    def _extract_prefixed_locator(self, locator: str) -> Tuple[Optional[str], str]:
        match = re.match(
            r"^\s*(xpath|id|css|css selector|class|class name|name|tag|tag name|text|href|sibling|link text|partial link text)\s*[:=]\s*(.+?)\s*$",
            locator,
            flags=re.IGNORECASE,
        )
        if not match:
            return None, locator
        return match.group(1), match.group(2)

    def _normalize_locator_type(self, locator_type: Optional[str]) -> str:
        if locator_type is None:
            return "auto"
        return self._LOCATOR_TYPE_ALIASES.get(locator_type.strip().lower(), "auto")

    def _looks_like_xpath(self, locator: str) -> bool:
        locator = locator.strip()
        return (
            locator.startswith(("/", "./", "(//"))
            or locator.startswith("//")
            or any(token in locator for token in ("following-sibling::", "preceding-sibling::", "ancestor::", "descendant::"))
        )

    def _looks_like_css(self, locator: str) -> bool:
        locator = locator.strip()
        if not locator:
            return False
        if locator.startswith(("#", ".", "[")):
            return True
        if any(token in locator for token in (">", "+", "~", "[", "]", ":")):
            return True
        return bool(re.match(r"^[a-z][a-z0-9_-]*(\.[A-Za-z0-9_-]+)+$", locator))

    def _looks_like_href(self, locator: str) -> bool:
        return locator.startswith(("http://", "https://", "mailto:", "tel:", "/"))

    def _looks_like_sibling(self, locator: str) -> bool:
        return any(token in locator for token in ("following-sibling", "preceding-sibling", "sibling::"))

    def _is_simple_token(self, locator: str) -> bool:
        return bool(re.match(r"^[A-Za-z_][A-Za-z0-9_\-:.]*$", locator))

    def _extract_recovery_terms(
        self,
        locator: str,
        locator_type: Optional[str] = None,
    ) -> List[str]:
        locator = (locator or "").strip()
        if not locator:
            return []

        terms: List[str] = []
        normalized_type = self._normalize_locator_type(locator_type)
        if normalized_type != "auto":
            terms.append(locator)

        if self._looks_like_xpath(locator):
            terms.extend(re.findall(r"['\"]([^'\"]{2,})['\"]", locator))
            terms.extend(re.findall(r"@(?:id|name|class|href|aria-label|placeholder|title|data-testid|data-qa)\s*=\s*['\"]([^'\"]+)['\"]", locator))
        else:
            terms.append(locator)

        for token in re.split(r"[\s>+~:/\[\]\(\)=@#.,]+", locator):
            token = token.strip()
            if len(token) >= 3:
                terms.append(token)

        seen = set()
        normalized_terms: List[str] = []
        for term in terms:
            term = " ".join(str(term).split()).strip()
            if not term or len(term) == 1:
                continue
            key = term.lower()
            if key in seen:
                continue
            seen.add(key)
            normalized_terms.append(term)
            if len(normalized_terms) >= 6:
                break
        return normalized_terms

    def _stable_token_stem(self, value: str) -> str:
        value = (value or "").strip()
        if not value:
            return ""
        stem = re.sub(r"[\d_\-:]+$", "", value)
        return stem if len(stem) >= 3 else ""

    def _correct_xpath(self, xpath: str) -> str:
        corrected = xpath.replace('""', "'")
        if "[" in corrected and "@" not in corrected:
            corrected = corrected.replace("[id=", "[@id=")
            corrected = corrected.replace("[name=", "[@name=")
            corrected = corrected.replace("[class=", "[@class=")
        if not corrected.startswith(("/", "(")):
            corrected = "//" + corrected.lstrip("/")
        return corrected

    def _escape_xpath_text(self, value: Optional[str]) -> str:
        if value is None:
            return "''"
        if "'" not in value:
            return f"'{value}'"
        if '"' not in value:
            return f'"{value}"'
        parts = value.split("'")
        return "concat(" + ', "\'", '.join(f"'{part}'" for part in parts) + ")"

    def _quote_css_value(self, value: str) -> str:
        escaped = value.replace("\\", "\\\\").replace('"', '\\"')
        return f'"{escaped}"'

    def _is_dynamic_token(self, token: str) -> bool:
        token = (token or "").strip()
        if not token:
            return False
        if len(token) > 10 and bool(re.search(r"\d", token)) and bool(re.search(r"[A-Za-z]", token)):
            return True
        return bool(re.search(r"\d{3,}", token))

    def _stable_class_tokens(self, class_value: str) -> List[str]:
        stable_tokens: List[str] = []
        for token in str(class_value or "").split():
            token = token.strip()
            if not token or self._is_dynamic_token(token):
                continue
            stable_tokens.append(token)
        return stable_tokens[:3]

    def _deduplicate_strategies(self, strategies: Sequence[Tuple[str, str, str]]) -> List[Tuple[str, str, str]]:
        seen = set()
        deduped: List[Tuple[str, str, str]] = []
        for strategy in strategies:
            if strategy in seen:
                continue
            seen.add(strategy)
            deduped.append(strategy)
        return deduped

    def _suggestion_to_dict(self, suggestion: LocatorSuggestion) -> dict:
        return {
            "strategy_name": suggestion.strategy_name,
            "by": suggestion.by,
            "value": suggestion.value,
            "reason": suggestion.reason,
            "score": suggestion.score,
            "window_handle": suggestion.window_handle,
            "frame_path": list(suggestion.frame_path),
            "location": suggestion.location_label,
        }

    def _build_not_found_message(self, target_label: str, locator: str) -> str:
        message = f"Unable to locate {target_label}: {locator}"
        if not self.last_suggestions:
            return message

        lines = [message, "Suggested alternatives:"]
        for index, suggestion in enumerate(self.last_suggestions[: self.max_suggestions], 1):
            lines.append(
                f"{index}. [{suggestion.strategy_name}] {suggestion.value} ({suggestion.location_label})"
            )
        return "\n".join(lines)
