"""
Quick start:
    from selenium import webdriver
    from web_dom_capture.smart_web_locator import SmartWebLocator

    driver = webdriver.Chrome()
    driver.get("https://example.com")

    smart = SmartWebLocator(driver)

    # Auto-detect locator type and search across page, iframes, and popups.
    match = smart.find("login-button")

    # Click using recovery if the first strategy does not match.
    smart.click("Sign in", locator_type="text", timeout=8)

    # Type into a field.
    smart.type_text("username", "tester@example.com", timeout=8)

    # Read values.
    page_title = smart.get_text("//h1")
    email_value = smart.get_value("email", locator_type="id")
    help_href = smart.get_href("Help", locator_type="link_text")

    # Get recovery suggestions when nothing matches.
    result = smart.find_with_recovery("submit-btn")
    if result.match:
        print(result.match.strategy_name, result.match.location_label)
    else:
        for suggestion in result.suggestions:
            print(suggestion.strategy_name, suggestion.value, suggestion.location_label)

Notes:
    - `find(..., condition="present")` can locate DOM elements that are not visible.
    - `click()` and `type_text()` require the element to be visible/clickable.
    - The class searches the main document first, then nested iframes, then popup windows/tabs.

Retry examples:
    from selenium.common.exceptions import TimeoutException

    # Retry up to x times with exponential backoff: 2^try seconds, capped at 500.
    smart.click_with_retry(
        "Submit",
        locator_type="text",
        timeout=5,
        retries=8,
        use_exponential_backoff=True,
        max_wait_seconds=500,
    )

    # Retry x times with a fixed wait between attempts.
    match = smart.find_with_retry(
        "submit-btn",
        retries=10,
        wait_seconds=15,
        use_recovery=True,
    )
    if not match:
        raise TimeoutException("Element not found after fixed retries")

Table extraction examples:
    # Extract the nearest table around a matched element.
    result = smart.extract_table("//span[text()='Order 1001']", locator_type="xpath")
    print(result["table"]["headers"])
    print(result["table"]["rows"])

    # Extract when the locator already points to the table element.
    table_result = smart.extract_table(
        "//table[@id='orders']",
        locator_type="xpath",
        element_is_table=True,
    )
    print(table_result["table"]["row_count"])
    print(table_result["table"]["column_count"])

Locator options for `smart.find(...)` and `smart.click(...)`:
    - `locator_type=None` or `"auto"`:
      Auto-detects from the locator text.
    - `locator_type="xpath"`:
      Examples:
          smart.find("//button[@id='submit']", locator_type="xpath")
          smart.click("//a[contains(., 'Next')]", locator_type="xpath")
    - `locator_type="id"`:
      Examples:
          smart.find("submitBtn", locator_type="id")
          smart.click("submitBtn", locator_type="id")
    - `locator_type="css"` or `"css selector"`:
      Examples:
          smart.find("button.primary", locator_type="css")
          smart.click("#submitBtn", locator_type="css selector")
    - `locator_type="class"` or `"class name"`:
      Examples:
          smart.find("primary-btn", locator_type="class")
          smart.click("primary-btn", locator_type="class name")
    - `locator_type="name"`:
      Examples:
          smart.find("username", locator_type="name")
          smart.click("username", locator_type="name")
    - `locator_type="tag"` or `"tag name"`:
      Examples:
          smart.find("button", locator_type="tag")
          smart.click("a", locator_type="tag name")
    - `locator_type="text"`:
      Examples:
          smart.find("Sign in", locator_type="text")
          smart.click("Submit", locator_type="text")
    - `locator_type="link text"`:
      Examples:
          smart.find("Help", locator_type="link text")
          smart.click("Help", locator_type="link text")
    - `locator_type="partial link text"`:
      Examples:
          smart.find("Help", locator_type="partial link text")
          smart.click("Down", locator_type="partial link text")
    - `locator_type="href"`:
      Examples:
          smart.find("/help", locator_type="href")
          smart.click("https://example.com/help", locator_type="href")
    - `locator_type="sibling"`:
      Examples:
          smart.find("Email", locator_type="sibling")
          smart.click("Password", locator_type="sibling")

Using the result from `smart.find(...)`:
    match = smart.find("submitBtn", locator_type="id")
    if match:
        text_value = smart.get_text_from_match(match)
        raw_value = smart.get_value_from_match(match)
        href_value = smart.get_href_from_match(match)
        smart.click_match(match)
"""

