    def find(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        condition: str = "present",
        include_frames: bool = True,
        include_popups: bool = True,
        timeout_per_attempt: Optional[float] = None,
        activate_match: bool = True,
        use_recovery: Optional[bool] = None,
    ) -> Optional[LocatorMatch]:
        self.last_suggestions = []
        strategies = self._build_strategy_candidates(locator, locator_type)
        if not strategies:
            return None

        origin_handle = self.driver.current_window_handle
        cached_match = self._try_cached_match(
            locator=locator,
            locator_type=locator_type,
            condition=condition,
            activate_match=activate_match,
            origin_handle=origin_handle,
        )
        if cached_match:
            return cached_match

        match = self._search_handles(
            handles=self._get_handles(origin_handle, include_popups),
            strategies=strategies,
            condition=condition,
            include_frames=include_frames,
            timeout_per_attempt=timeout_per_attempt,
        )
        if match:
            self._cache_match(locator, locator_type, condition, match)
            if activate_match:
                self._activate_match_context(match)
            else:
                self._restore_origin(origin_handle)
            return match

        if use_recovery is None:
            use_recovery = self.enable_recovery
        if use_recovery:
            recovery_match = self._attempt_recovery_search(
                locator=locator,
                locator_type=locator_type,
                condition=condition,
                include_frames=include_frames,
                include_popups=include_popups,
                timeout_per_attempt=timeout_per_attempt,
                activate_match=activate_match,
                origin_handle=origin_handle,
            )
            if recovery_match:
                self._cache_match(locator, locator_type, condition, recovery_match)
                return recovery_match

        self.last_suggestions = self._generate_locator_suggestions(
            locator=locator,
            locator_type=locator_type,
            include_frames=include_frames,
            include_popups=include_popups,
        )
        self._restore_origin(origin_handle)
        return None

    def find_with_recovery(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        condition: str = "present",
        include_frames: bool = True,
        include_popups: bool = True,
        timeout_per_attempt: Optional[float] = None,
        activate_match: bool = True,
    ) -> LocatorRecoveryResult:
        self.last_suggestions = []
        origin_handle = self.driver.current_window_handle
        strategies = self._build_strategy_candidates(locator, locator_type)
        if strategies:
            direct_match = self._search_handles(
                handles=self._get_handles(origin_handle, include_popups),
                strategies=strategies,
                condition=condition,
                include_frames=include_frames,
                timeout_per_attempt=timeout_per_attempt,
            )
            if direct_match:
                if activate_match:
                    self._activate_match_context(direct_match)
                else:
                    self._restore_origin(origin_handle)
                return LocatorRecoveryResult(match=direct_match, suggestions=[], recovered=False)

        recovery_match = self._attempt_recovery_search(
            locator=locator,
            locator_type=locator_type,
            condition=condition,
            include_frames=include_frames,
            include_popups=include_popups,
            timeout_per_attempt=timeout_per_attempt,
            activate_match=activate_match,
            origin_handle=origin_handle,
        )
        if recovery_match:
            return LocatorRecoveryResult(match=recovery_match, suggestions=[], recovered=True)

        suggestions = self._generate_locator_suggestions(
            locator=locator,
            locator_type=locator_type,
            include_frames=include_frames,
            include_popups=include_popups,
        )
        self.last_suggestions = suggestions
        self._restore_origin(origin_handle)
        return LocatorRecoveryResult(match=None, suggestions=suggestions, recovered=False)

    def wait_for(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        condition: str = "present",
        timeout: Optional[float] = None,
        include_frames: bool = True,
        include_popups: bool = True,
        activate_match: bool = True,
    ) -> Optional[LocatorMatch]:
        timeout = self.default_timeout if timeout is None else float(timeout)
        end_time = time.time() + timeout
        self.last_suggestions = []

        while time.time() < end_time:
            remaining = max(0.25, end_time - time.time())
            match = self.find(
                locator=locator,
                locator_type=locator_type,
                condition=condition,
                include_frames=include_frames,
                include_popups=include_popups,
                timeout_per_attempt=min(self.attempt_timeout, remaining),
                activate_match=activate_match,
                use_recovery=False,
            )
            if match:
                return match
            time.sleep(self.poll_frequency)

        if self.enable_recovery:
            recovery_match = self._attempt_recovery_search(
                locator=locator,
                locator_type=locator_type,
                condition=condition,
                include_frames=include_frames,
                include_popups=include_popups,
                timeout_per_attempt=min(self.recovery_attempt_timeout, max(0.2, timeout)),
                activate_match=activate_match,
                origin_handle=self.driver.current_window_handle,
            )
            if recovery_match:
                return recovery_match

        self.last_suggestions = self._generate_locator_suggestions(
            locator=locator,
            locator_type=locator_type,
            include_frames=include_frames,
            include_popups=include_popups,
        )
        return None

    def exists(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        timeout: float = 0.0,
        include_frames: bool = True,
        include_popups: bool = True,
    ) -> bool:
        if timeout and timeout > 0:
            return self.wait_for(
                locator=locator,
                locator_type=locator_type,
                timeout=timeout,
                include_frames=include_frames,
                include_popups=include_popups,
                activate_match=False,
            ) is not None
        return self.find(
            locator=locator,
            locator_type=locator_type,
            include_frames=include_frames,
            include_popups=include_popups,
            activate_match=False,
            use_recovery=False,
        ) is not None

    def wait_until_gone(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        timeout: Optional[float] = None,
        include_frames: bool = True,
        include_popups: bool = True,
    ) -> bool:
        timeout = self.default_timeout if timeout is None else float(timeout)
        end_time = time.time() + timeout

        while time.time() < end_time:
            if not self.find(
                locator=locator,
                locator_type=locator_type,
                include_frames=include_frames,
                include_popups=include_popups,
                timeout_per_attempt=min(self.attempt_timeout, max(0.25, end_time - time.time())),
                activate_match=False,
                use_recovery=False,
            ):
                return True
            time.sleep(self.poll_frequency)
        return False

    def click(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        timeout: Optional[float] = None,
        include_frames: bool = True,
        include_popups: bool = True,
    ) -> LocatorMatch:
        match = self.wait_for(
            locator=locator,
            locator_type=locator_type,
            condition="clickable",
            timeout=timeout,
            include_frames=include_frames,
            include_popups=include_popups,
            activate_match=False,
        )
        if not match:
            raise TimeoutException(self._build_not_found_message("clickable element", locator))

        self._run_with_match(match, lambda element: self._click_with_fallback(element), condition="clickable")
        return match

    def type_text(
        self,
        locator: str,
        text: str,
        locator_type: Optional[str] = None,
        timeout: Optional[float] = None,
        clear_first: bool = True,
        include_frames: bool = True,
        include_popups: bool = True,
    ) -> LocatorMatch:
        match = self.wait_for(
            locator=locator,
            locator_type=locator_type,
            condition="visible",
            timeout=timeout,
            include_frames=include_frames,
            include_popups=include_popups,
            activate_match=False,
        )
        if not match:
            raise TimeoutException(self._build_not_found_message("visible element for typing", locator))

        def _type(element: WebElement) -> None:
            self._scroll_into_view(element)
            if clear_first:
                try:
                    element.clear()
                except WebDriverException:
                    pass
            element.send_keys(text)

        self._run_with_match(match, _type, condition="visible")
        return match

    def get_value(
