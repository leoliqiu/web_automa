        self.max_window_handles = int(max_window_handles)
        self.max_frame_paths = int(max_frame_paths)
        self.max_suggestions = int(max_suggestions)
        self.default_retry_count = int(default_retry_count)
        self.default_retry_wait_seconds = float(default_retry_wait_seconds)
        self.default_retry_use_exponential_backoff = bool(default_retry_use_exponential_backoff)
        self.max_retry_wait_seconds = float(max_retry_wait_seconds)
        self.enable_spinner_wait = bool(enable_spinner_wait)
        self.spinner_timeout = float(spinner_timeout)
        self.cache_successful_matches = bool(cache_successful_matches)
        self.last_suggestions: List[LocatorSuggestion] = []
        self._successful_match_cache: dict = {}
        self._frame_paths_cache: dict = {}

    def wait_for_page_ready(self, timeout: Optional[float] = None) -> bool:
        timeout = self.page_ready_timeout if timeout is None else float(timeout)
        try:
            WebDriverWait(
                self.driver,
                timeout,
                poll_frequency=self.poll_frequency,
                ignored_exceptions=(WebDriverException,),
            ).until(lambda driver: self._is_document_ready())
            if self.stability_wait > 0:
                time.sleep(self.stability_wait)
            return True
        except TimeoutException:
            return False

    def infer_locator_strategies(
        self,
        locator: str,
        locator_type: Optional[str] = None,
    ) -> List[dict]:
        return [
            {"strategy_name": strategy_name, "by": by, "value": value}
            for strategy_name, by, value in self._build_strategy_candidates(locator, locator_type)
        ]

    def retry(
        self,
        operation: Callable[[], object],
        retries: Optional[int] = None,
        wait_seconds: Optional[float] = None,
        use_exponential_backoff: Optional[bool] = None,
        max_wait_seconds: Optional[float] = None,
        retry_exceptions: Tuple[type[BaseException], ...] = (TimeoutException, WebDriverException),
    ) -> object:
        retries = self.default_retry_count if retries is None else int(retries)
        wait_seconds = self.default_retry_wait_seconds if wait_seconds is None else float(wait_seconds)
        use_exponential_backoff = (
            self.default_retry_use_exponential_backoff
            if use_exponential_backoff is None
            else bool(use_exponential_backoff)
        )
        max_wait_seconds = self.max_retry_wait_seconds if max_wait_seconds is None else float(max_wait_seconds)

        last_error: Optional[BaseException] = None
        total_attempts = max(1, retries)

        for attempt in range(total_attempts):
            try:
                return operation()
            except retry_exceptions as exc:
                last_error = exc
                if attempt == total_attempts - 1:
                    raise
                delay = self._calculate_retry_delay(
                    attempt=attempt,
                    wait_seconds=wait_seconds,
                    use_exponential_backoff=use_exponential_backoff,
                    max_wait_seconds=max_wait_seconds,
                )
                if delay > 0:
                    time.sleep(delay)

        if last_error:
            raise last_error
        return operation()

    def find_with_retry(
        self,
        locator: str,
        locator_type: Optional[str] = None,
        condition: str = "present",
        include_frames: bool = True,
        include_popups: bool = True,
        timeout_per_attempt: Optional[float] = None,
        activate_match: bool = True,
        retries: Optional[int] = None,
        wait_seconds: Optional[float] = None,
        use_exponential_backoff: Optional[bool] = None,
        max_wait_seconds: Optional[float] = None,
        use_recovery: bool = True,
    ) -> Optional[LocatorMatch]:
        def _operation() -> LocatorMatch:
            match = self.find(
                locator=locator,
                locator_type=locator_type,
                condition=condition,
                include_frames=include_frames,
                include_popups=include_popups,
                timeout_per_attempt=timeout_per_attempt,
                activate_match=activate_match,
                use_recovery=use_recovery,
            )
            if not match:
                raise TimeoutException(self._build_not_found_message("element", locator))
            return match

        return self.retry(
            _operation,
            retries=retries,
            wait_seconds=wait_seconds,
            use_exponential_backoff=use_exponential_backoff,
            max_wait_seconds=max_wait_seconds,
            retry_exceptions=(TimeoutException, WebDriverException),
        )

