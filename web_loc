@dataclass
class LocatorMatch:
    strategy_name: str
    by: str
    value: str
    window_handle: str
    frame_path: Tuple[int, ...]
    found_in_popup: bool = False

    @property
    def location_label(self) -> str:
        if not self.frame_path:
            return "main document"
        return " > ".join(f"iframe[{index + 1}]" for index in self.frame_path)


@dataclass
class LocatorSuggestion:
    strategy_name: str
    by: str
    value: str
    reason: str = ""
    score: int = 0
    window_handle: Optional[str] = None
    frame_path: Tuple[int, ...] = ()

    @property
    def location_label(self) -> str:
        if not self.frame_path:
            return "main document"
        return " > ".join(f"iframe[{index + 1}]" for index in self.frame_path)


