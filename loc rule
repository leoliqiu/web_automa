import re


ARCHER_ID_PREFIX = "master_DefaultContent_"


def _normalize_label(locator_value):
    """Return a cleaned locator label plus any trailing index token."""
    raw_value = (locator_value or "").strip()
    match = re.match(r"^(.*?)(\[(?:\d+|last\(\)|t-)\])?$", raw_value)
    if not match:
        return raw_value, None
    return match.group(1).strip(), match.group(2)


def _apply_index(xpath_value, index_token):
    """Apply optional Archer index syntax to an XPath expression."""
    if not index_token:
        return xpath_value
    if index_token == "[t-]":
        return f"({xpath_value})[last()]"
    return f"({xpath_value}){index_token}"


def build_archer_strategy_rules(locator_value, escape_xpath_text):
    """
    Build Archer-specific locator rules.

    Extend this function with more Archer-only rules over time.
    Each item should be returned as:
    (display_name, locator_type, locator_value)
    """
    label_text, index_token = _normalize_label(locator_value)
    if not label_text:
        return []

    escaped_label = escape_xpath_text(label_text)
    compact_key = re.sub(r"[^A-Za-z0-9]+", "", label_text)
    lower_key = compact_key.lower()

    rules = [
        (
            "Archer Exact Text",
            "XPath",
            _apply_index(f"//*[normalize-space(text())={escaped_label}]", index_token),
        ),
        (
            "Archer Partial Text",
            "XPath",
            _apply_index(f"//*[contains(normalize-space(.),{escaped_label})]", index_token),
        ),
        (
            "Archer Label To Input",
            "XPath",
            _apply_index(
                "//*[contains(normalize-space(.),{label})]"
                "/ancestor::*[self::td or self::th or self::div or self::label][1]"
                "/following-sibling::*[1]//*[self::input or self::textarea or self::select][1]".format(
                    label=escaped_label
                ),
                index_token,
            ),
        ),
        (
            "Archer Parent To Input Fallback",
            "XPath",
            _apply_index(
                "//*[contains(normalize-space(.),{label})]"
                "/ancestor::*[self::tr or self::div or self::section][1]"
                "//*[self::input or self::textarea or self::select][1]".format(label=escaped_label),
                index_token,
            ),
        ),
        (
            "Archer ID Pattern",
            "XPath",
            _apply_index(
                f"//*[starts-with(@id,'{ARCHER_ID_PREFIX}') and "
                f"(contains(translate(@id,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'{lower_key}') "
                f"or contains(translate(@name,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'{lower_key}'))]",
                index_token,
            ),
        ),
        (
            "Archer Class Label",
            "XPath",
            _apply_index(
                f"//*[@class='FieldLabel' and contains(normalize-space(.),{escaped_label})]",
                index_token,
            ),
        ),
        (
            "Archer Aria Label",
            "XPath",
            _apply_index(f"//*[@aria-label={escaped_label}]", index_token),
        ),
        (
            "Archer Section Scoped",
            "XPath",
            _apply_index(
                f"//section//*[contains(normalize-space(.),{escaped_label})] | "
                f"//section//*[@aria-label={escaped_label}]",
                index_token,
            ),
        ),
    ]

    deduped_rules = []
    seen = set()
    for rule in rules:
        if rule in seen:
            continue
        deduped_rules.append(rule)
        seen.add(rule)
    return deduped_rules


def _target_attribute_conditions(target_data, escape_xpath_text):
    """Build target-side conditions for Archer relative XPath rules."""
    conditions = []
    target_name = (target_data.get("name") or "").strip()
    target_type = (target_data.get("type") or "").strip()
    target_role = (target_data.get("role") or "").strip()
    target_aria = (target_data.get("ariaLabel") or "").strip()
    target_placeholder = (target_data.get("placeholder") or "").strip()
    target_text = (target_data.get("text") or "").strip()

    if target_name:
        conditions.append(f"@name={escape_xpath_text(target_name)}")
    if target_type:
        conditions.append(f"@type={escape_xpath_text(target_type)}")
    if target_role:
        conditions.append(f"@role={escape_xpath_text(target_role)}")
    if target_aria:
        conditions.append(f"@aria-label={escape_xpath_text(target_aria)}")
    if target_placeholder:
        conditions.append(f"@placeholder={escape_xpath_text(target_placeholder)}")
    if target_text:
        conditions.append(f"contains(normalize-space(.),{escape_xpath_text(target_text[:30])})")
    return conditions[:3]


def build_archer_relative_xpath_rules(anchor_data, target_data, relationship, escape_xpath_text):
    """
    Build Archer-specific relative XPath rules from a stable anchor to a dynamic target.

    Each item is returned as:
    (label, xpath_value)
    """
    anchor_text, index_token = _normalize_label(anchor_data.get("text") or "")
    if not anchor_text:
        return []

    anchor_text_escaped = escape_xpath_text(anchor_text)
    target_tag = (target_data.get("tag") or "*").strip() or "*"
    target_conditions = _target_attribute_conditions(target_data, escape_xpath_text)
    target_filter = "[" + " and ".join(target_conditions) + "]" if target_conditions else ""

    base_label = f"//*[normalize-space(text())={anchor_text_escaped}]"
    partial_label = f"//*[contains(normalize-space(.),{anchor_text_escaped})]"
    target_descendant = f"{target_tag}{target_filter}"

    rules = [
        (
            "Archer Relative Label To Field",
            _apply_index(
                base_label +
                "/ancestor::*[self::td or self::th or self::div or self::label][1]" +
                f"/following-sibling::*[1]//*[self::{target_tag} or self::input or self::textarea or self::select][1]",
                index_token,
            ),
        ),
        (
            "Archer Relative Parent Chain",
            _apply_index(
                partial_label +
                "/ancestor::*[self::tr or self::div or self::section][1]" +
                f"//{target_descendant}[1]",
                index_token,
            ),
        ),
        (
            "Archer Relative Section Scoped",
            _apply_index(
                f"//section[{partial_label}/ancestor::section]" +
                f"//{target_descendant}[1]",
                index_token,
            ),
        ),
    ]

    direction = relationship.get("direction")
    any_offset = relationship.get("any_offset")
    same_tag_offset = relationship.get("same_tag_offset")
    if direction == "following":
        if any_offset:
            rules.append(("Archer Relative Following Sibling", _apply_index(f"{base_label}/following-sibling::*[{any_offset}]", index_token)))
        if same_tag_offset:
            rules.append(("Archer Relative Following Tag Sibling", _apply_index(f"{base_label}/following-sibling::{target_tag}[{same_tag_offset}]", index_token)))
    elif direction == "preceding":
        if any_offset:
            rules.append(("Archer Relative Previous Sibling", _apply_index(f"{base_label}/preceding-sibling::*[{any_offset}]", index_token)))
        if same_tag_offset:
            rules.append(("Archer Relative Previous Tag Sibling", _apply_index(f"{base_label}/preceding-sibling::{target_tag}[{same_tag_offset}]", index_token)))

    deduped_rules = []
    seen = set()
    for rule in rules:
        if rule in seen:
            continue
        deduped_rules.append(rule)
        seen.add(rule)
    return deduped_rules

