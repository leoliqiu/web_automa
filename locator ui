    def find_similar_locators(self, search_term, html):
        """Find similar locators in HTML based on search term."""
        try:
            soup = BeautifulSoup(html, 'lxml')
            similar_locators = []
            search_term_lower = search_term.lower()

            # Search for elements containing similar text or attributes
            for element in soup.find_all(True):  # True = find all tags
                # Extract text content
                elem_text = element.get_text(strip=True)[:50]

                # Check if text matches
                if search_term_lower in elem_text.lower():
                    elem_id = element.get('id')
                    elem_class = element.get('class')
                    elem_name = element.get('name')

                    # Create alternative locators
                    if elem_id:
                        similar_locators.append((
                            "ID",
                            elem_id,
                            {
                                'tag': element.name,
                                'text': elem_text,
                                'class': elem_class,
                                'id': elem_id
                            }
                        ))

                    if elem_class:
                        class_name = elem_class[0] if isinstance(elem_class, list) else elem_class.split()[0]
                        similar_locators.append((
                            "CSS Selector",
                            f"{element.name}.{class_name}",
                            {
                                'tag': element.name,
                                'text': elem_text,
                                'class': elem_class,
                                'id': elem_id
                            }
                        ))

                    xpath = self.build_xpath_from_element(element)
                    if xpath:
                        similar_locators.append((
                            "XPath",
                            xpath,
                            {
                                'tag': element.name,
                                'text': elem_text,
                                'class': elem_class,
                                'id': elem_id
                            }
                        ))

                    if elem_name:
                        similar_locators.append((
                            "Name",
                            elem_name,
                            {
                                'tag': element.name,
                                'text': elem_text,
                                'class': elem_class,
                                'id': elem_id
                            }
                        ))

                # Also check attributes
                if elem_id and search_term_lower in elem_id.lower():
                    similar_locators.append((
                        "ID",
                        elem_id,
                        {
                            'tag': element.name,
                            'text': elem_text,
                            'class': element.get('class'),
                            'id': elem_id
                        }
                    ))

                if elem_class:
                    classes = elem_class if isinstance(elem_class, list) else elem_class.split()
                    for cls in classes:
                        if search_term_lower in cls.lower():
                            similar_locators.append((
                                "CSS Selector",
                                f".{cls}",
                                {
                                    'tag': element.name,
                                    'text': elem_text,
                                    'class': elem_class,
                                    'id': elem_id
                                }
                            ))

            # Remove duplicates and limit results
            seen = set()
            unique_locators = []
            for loc_type, loc_value, elem_info in similar_locators:
                key = (loc_type, loc_value)
                if key not in seen:
                    seen.add(key)
                    unique_locators.append((loc_type, loc_value, elem_info))

            return unique_locators[:5]  # Return top 5

        except Exception as e:
            print(f"Error finding similar locators: {str(e)}")
            return []

    def build_xpath_from_element(self, element):
        """Build a simple XPath from a BeautifulSoup element."""
        try:
            path = []
            current = element

            while current and current.name:
                tag = current.name
                # Get position among siblings
                siblings = [s for s in current.parent.children if s.name == tag]
                position = siblings.index(current) + 1

                if current.get('id'):
                    return f"//{tag}[@id='{current.get('id')}']"

                path.append(f"{tag}[{position}]")
                current = current.parent

            path.reverse()
            return "/" + "/".join(path) if path else None
        except:
            return None

    def _format_match_value(self, value):
        """Normalize values for display in the results table."""
        return self._normalize_display_text(value)

    def _build_locator_options(self, match):
        """Build a de-duplicated list of locator options for a match."""
        locators = []
        text = (match.get('text') or '').strip()
        tag = self._format_match_value(match.get('tag'))
        match_id = match.get('id')
        match_name = match.get('name')
        classes = self._format_match_value(match.get('class'))

        if text:
            locators.append(f"XPath Text: //*[contains(text(),'{text[:30]}')]")
            locators.append(f"XPath Tag: //{tag}[contains(text(),'{text[:20]}')]")

        if match_id:
            locators.append(f"ID: {match_id}")
            locators.append(f"CSS: #{match_id}")

        first_class = classes.split()[0] if classes and classes != '-' else None
        if first_class:
            locators.append(f"CSS Class: .{first_class}")

        if match_name:
            locators.append(f"Name: {match_name}")

        deduped = []
        seen = set()
        for locator in locators:
            if locator not in seen:
                deduped.append(locator)
                seen.add(locator)
        return deduped

    def _sanitize_filename_part(self, value, fallback='report'):
        """Create a filesystem-safe filename fragment."""
        cleaned = re.sub(r'[^A-Za-z0-9._-]+', '_', (value or '').strip())
        cleaned = cleaned.strip('._')
        return cleaned[:50] or fallback

