            self.workspace_tabs.updateGeometry()
        if hasattr(self, 'workspace_tabs'):
            self._sync_workspace_nav_buttons(self.workspace_tabs.currentIndex())

    def _sync_workspace_nav_buttons(self, current_index):
        """Keep the custom workspace navigation row aligned with the active page."""
        if hasattr(self, 'locator_tester_nav_button') and hasattr(self, 'tester_tab_index'):
            self.locator_tester_nav_button.setChecked(current_index == self.tester_tab_index)
        if hasattr(self, 'frames_nav_button') and hasattr(self, 'frame_tab_index'):
            self.frames_nav_button.setChecked(current_index == self.frame_tab_index)
