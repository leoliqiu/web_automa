    def get_locator_strategy(self, locator_type, locator_value):
        """Return the appropriate By strategy based on locator type."""
        locator_type = self._normalize_strategy_name(locator_type)
        strategies = {
            "XPath": (By.XPATH, locator_value),
            "ID": (By.ID, locator_value),
            "CSS Selector": (By.CSS_SELECTOR, locator_value),
            "Class Name": (By.CLASS_NAME, locator_value),
            "Tag Name": (By.TAG_NAME, locator_value),
            "Link Text": (By.LINK_TEXT, locator_value),
            "Partial Link Text": (By.PARTIAL_LINK_TEXT, locator_value),
            "Name": (By.NAME, locator_value),
            "Text (Contains)": (By.XPATH, f"//*[contains(normalize-space(.),{self._escape_xpath_text(locator_value)})]"),
        }
        return strategies.get(locator_type)

    def test_locator(self):
        """Test a locator and display consolidated locator details."""
        if not self.ensure_driver():
