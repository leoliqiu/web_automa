                self.refresh_live_frame_selector()
        if hasattr(self, 'output_nav_button') and hasattr(self, 'output_tab_index'):
            self.output_nav_button.setChecked(self.output_nav_button.isEnabled() and current_index == self.output_tab_index)
        if hasattr(self, 'table_grid_nav_button') and hasattr(self, 'table_grid_tab_index'):
            self.table_grid_nav_button.setChecked(self.table_grid_nav_button.isEnabled() and current_index == self.table_grid_tab_index)

    def launch_browser(self):
        if self.browser_launch_in_progress:
            self.output.append("Browser launch is already in progress. Please wait.")
            self._set_processing_status(True, "Browser launch already in progress...")
            return

        if self.driver is not None:
            reply = QMessageBox.question(self, "Browser Running",
                "Browser is already running. Close and restart?",
                QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
            if reply == QMessageBox.StandardButton.No:
                return
            self.close_browser()

        url = self.url_input.text().strip()
        if not url:
            url = "https://en.wikipedia.org/wiki/National_Basketball_Association"
            self.url_input.setText(url)

        self.output.append(f"Launching browser with {url}... Please wait (this may take 10-30 seconds).")
        self._set_processing_status(True, "Launching browser...")
        self.browser_launch_in_progress = True

        # Launch browser in background thread to prevent UI freeze
        self.browser_thread = QThread()
        self.browser_worker = BrowserLaunchWorker(url)
        self.browser_worker.moveToThread(self.browser_thread)

        # Connect signals
        self.browser_thread.started.connect(self.browser_worker.run)
        self.browser_worker.success.connect(self.on_browser_success)
        self.browser_worker.error.connect(self.on_browser_error)
        self.browser_worker.finished.connect(self.browser_thread.quit)
        self.browser_worker.finished.connect(self.browser_worker.deleteLater)
        self.browser_thread.finished.connect(self.browser_thread.deleteLater)
        self.browser_thread.finished.connect(self._on_browser_launch_finished)

        # Start thread
        self.browser_thread.start()

    def _on_browser_launch_finished(self):
        """Reset browser launch state after the worker thread exits."""
        self.browser_launch_in_progress = False
        self.browser_thread = None
        self.browser_worker = None

    def on_browser_success(self, driver):
        """Handle successful browser launch."""
        self.driver = driver
        self.output.append(f"✓ Browser launched successfully")
        self._set_browser_status(True)
        self._set_processing_status(False, "Browser launched - Ready to use")
        self.statusBar().showMessage("Browser launched - Ready to use")

    def on_browser_error(self, error_msg):
        """Handle browser launch error."""
        QMessageBox.critical(self, "Browser Launch Error", f"Failed to launch browser:\n\n{error_msg}")
        self.output.append(f"✗ Browser launch failed: {error_msg}")
        self.driver = None
        self._set_browser_status(False)
        self._set_processing_status(False, "Browser launch failed")

    def close_browser(self):
        if self.browser_launch_in_progress:
            self.output.append("Browser launch is still in progress. Wait for it to finish before closing.")
            return
        if self.driver:
            try:
                self.driver.quit()
            except:
                pass
            self.driver = None
        self._set_browser_status(False)
        self._set_processing_status(False, "Browser closed")
        self.output.append("Browser closed")

    def open_url(self):
        if not self.ensure_driver():
            return
        url = self.url_input.text().strip()
        if not url:
            self.output.append("Please enter a URL.")
            return
        self._set_processing_status(True, f"Opening {url} ...")
        try:
            self.driver.get(url)
            self.output.append(f"Opened: {url}")
            self._set_processing_status(False, f"Opened {url}")
        except Exception as e:
            self.output.append(f"Failed to open URL: {str(e)}")
            self._set_processing_status(False, "Failed to open URL")

    def download_html(self):
        try:
            html = self.driver.page_source
            export_dir = self._get_export_directory()
            filename = f"page_{datetime.now().strftime('%Y%m%d_%H%M%S')}.html"
            file_path = os.path.join(export_dir, filename)
            with open(file_path, 'w', encoding='utf-8') as f:
                f.write(html)
            return html, file_path
        except Exception as e:
            self.output.append(f"Failed to download HTML: {str(e)}")
            return None, None

    def _switch_to_frame_path(self, frame_path):
        """Switch Selenium context to the given nested frame path."""
        self.driver.switch_to.default_content()
        for frame_index in frame_path:
            frames = self.driver.find_elements(By.CSS_SELECTOR, 'iframe, frame')
            if frame_index >= len(frames):
                raise IndexError(f'Frame index {frame_index} out of range for path {frame_path}')
            self.driver.switch_to.frame(frames[frame_index])

    def _collect_frame_paths(self, frame_path=None, max_depth=10):
        """Collect all reachable frame paths starting from the main document."""
        frame_path = frame_path or []
        paths = [list(frame_path)]

        if len(frame_path) >= max_depth:
            return paths

        self._switch_to_frame_path(frame_path)
        frame_count = len(self.driver.find_elements(By.CSS_SELECTOR, 'iframe, frame'))
        for index in range(frame_count):
            paths.extend(self._collect_frame_paths(frame_path + [index], max_depth))
        return paths

    def _format_frame_path(self, frame_path):
        """Convert a frame path list into a readable label."""
        if not frame_path:
            return 'main document'
        return ' > '.join(f'iframe[{index + 1}]' for index in frame_path)

    def _extract_element_details(self, element, frame_path):
        """Capture element details before switching out of its frame."""
        return {
            'tag': element.tag_name,
            'id': element.get_attribute('id') or '(none)',
            'class': element.get_attribute('class') or '(none)',
            'text': element.text[:60] or '(none)',
            'frame_path': self._format_frame_path(frame_path)
        }

    def _populate_table_grid(self, dataframe):
        """Display a DataFrame in the table grid."""
        self.table_grid.clear()
        if dataframe is None or dataframe.empty:
            self.table_grid.setRowCount(0)
            self.table_grid.setColumnCount(0)
            self._refresh_result_nav_buttons()
            return

        self.table_grid.setRowCount(len(dataframe.index))
        self.table_grid.setColumnCount(len(dataframe.columns))
        self.table_grid.setHorizontalHeaderLabels([str(col) for col in dataframe.columns])

        for row_index in range(len(dataframe.index)):
            for col_index, column_name in enumerate(dataframe.columns):
                full_text = self._normalize_display_text(dataframe.iloc[row_index, col_index])
                display_text = self._truncate_text(full_text)
                if display_text != full_text:
                    display_text = f"{display_text} [Click to expand]"
                item = QTableWidgetItem(display_text)
                item.setToolTip(full_text)
                item.setData(Qt.ItemDataRole.UserRole, full_text)
                self.table_grid.setItem(row_index, col_index, item)

        self.table_grid.resizeColumnsToContents()
        self._refresh_result_nav_buttons()
        if hasattr(self, 'workspace_tabs') and hasattr(self, 'table_grid_tab_index'):
            self.workspace_tabs.setCurrentIndex(self.table_grid_tab_index)

    def _normalize_display_text(self, value):
        """Normalize values for display across grid and HTML views."""
        if not value:
            return "-"
        if isinstance(value, list):
            normalized = " ".join(str(item) for item in value if item)
            return normalized or "-"
        return str(value)

    def _truncate_text(self, value, limit=None):
        """Keep long captured text compact in the UI."""
        text = self._normalize_display_text(value)
        max_length = limit or self.preview_text_limit
        if len(text) <= max_length:
            return text
        return f"{text[:max_length].rstrip()}..."

    def _register_expandable_text(self, value):
        """Store the full text behind an expand link."""
        text = self._normalize_display_text(value)
        key = f"text_{len(self.expanded_text_registry) + 1}"
        self.expanded_text_registry[key] = text
        return key

    def _format_expandable_html(self, value, label="Text"):
        """Render long text as a short preview with an expand link."""
        text = self._normalize_display_text(value)
        preview = self._truncate_text(text)
        if preview == text:
            return html.escape(text)

        key = self._register_expandable_text(text)
        return (
            f"{html.escape(preview)} "
            f"<a href=\"expand:{key}\" style=\"color:#1d4ed8; font-weight:600; text-decoration:none;\">Expand</a>"
        )

    def _show_expanded_text(self, title, text):
        """Show the full captured text in a dedicated dialog."""
        dialog = QDialog(self)
        dialog.setWindowTitle(title)
        dialog.resize(760, 520)

        layout = QVBoxLayout(dialog)
        text_view = QTextEdit()
        text_view.setReadOnly(True)
        text_view.setPlainText(text)
        layout.addWidget(text_view)

        close_button = QPushButton("Close")
        close_button.clicked.connect(dialog.accept)
        layout.addWidget(close_button, 0, Qt.AlignmentFlag.AlignRight)
        dialog.exec()

    def _handle_output_link(self, url):
        """Open long truncated text from the output browser."""
        url_text = url.toString()
        if not url_text.startswith("expand:"):
            return

        key = url_text.split("expand:", 1)[1]
        full_text = self.expanded_text_registry.get(key)
        if full_text:
            self._show_expanded_text("Captured Text", full_text)

    def _handle_table_item_click(self, item):
        """Open long table cell values when the preview is clicked."""
        full_text = item.data(Qt.ItemDataRole.UserRole)
        if not full_text or self._truncate_text(full_text) == full_text:
            return
        self._show_expanded_text("Table Cell Text", full_text)

    def _populate_frame_download_list(self, downloads):
        """Render downloaded frame HTML locations in the list tab."""
        self.frame_download_list.clear()
        if not downloads:
            self.frame_download_list.setVisible(False)
            return

        self.frame_download_list.setVisible(True)
        for entry in downloads:
            label = f"{entry['frame_label']} -> {entry['file_path']}"
            if entry.get('is_target'):
                label = f"[Target] {label}"
            item = QListWidgetItem(label)
            item.setData(Qt.ItemDataRole.UserRole, entry.get('file_path'))
            self.frame_download_list.addItem(item)

    def refresh_live_frame_selector(self):
        """List the main document and reachable frames for live preview/export."""
        if not hasattr(self, 'frame_selector_combo'):
            return

        self.frame_selector_combo.clear()
        if not self.driver:
            self.frame_selector_combo.addItem("Browser not launched")
            self.frame_selector_combo.setEnabled(False)
            return

        self.frame_selector_combo.setEnabled(True)
        for frame_path in self._get_selection_context_paths():
            frame_label = self._format_frame_path(frame_path)
            self.frame_selector_combo.addItem(frame_label, list(frame_path))

    def _capture_frame_html(self, frame_path):
        """Capture the current HTML for a specific frame path."""
        if not self.ensure_driver():
            return None, None

        try:
            self._switch_to_frame_path(frame_path or [])
            html_content = self.driver.page_source
            return html_content, self._format_frame_path(frame_path or [])
        finally:
            try:
                self.driver.switch_to.default_content()
            except Exception:
                pass

    def _set_frame_view_content(self, html_content, source_label):
        """Store frame content and render it in the Frames viewer."""
        self.current_frame_html_content = html_content or ""
        self.current_frame_view_label = source_label or "Frame Content"
        if hasattr(self, 'frame_search_input'):
            self.frame_search_input.clear()
        self._render_frame_html_viewer()

    def _render_frame_html_viewer(self):
        """Render current frame content with optional highlighted search matches."""
        if not hasattr(self, 'frame_html_viewer'):
            return

        raw_text = self.current_frame_html_content or ""
        source_label = self.current_frame_view_label or "Frame Content"
        search_term = self.frame_search_input.text().strip() if hasattr(self, 'frame_search_input') else ""

        if not raw_text:
            self.frame_html_viewer.setPlainText("No frame content loaded.")
            if hasattr(self, 'frame_search_status'):
                self.frame_search_status.setText("No frame content loaded.")
            return

        match_count = 0
        if search_term:
            pattern = re.compile(re.escape(search_term), re.IGNORECASE)
            parts = []
            last_index = 0
            for match in pattern.finditer(raw_text):
                parts.append(html.escape(raw_text[last_index:match.start()]))
                parts.append(
                    "<span style=\"background-color: #fde68a; color: #92400e; font-weight: 700;\">"
                    f"{html.escape(match.group(0))}"
                    "</span>"
                )
                last_index = match.end()
                match_count += 1
            parts.append(html.escape(raw_text[last_index:]))
            body_html = "".join(parts)
        else:
            body_html = html.escape(raw_text)

        self.frame_html_viewer.setHtml(
            "<div style=\"font-family: Consolas, 'Courier New', monospace; font-size: 12px; color: #0f172a;\">"
            f"<div style=\"margin-bottom: 10px; font-weight: 700; color: #1e3a8a;\">{html.escape(source_label)}</div>"
            f"<pre style=\"white-space: pre-wrap; word-break: break-word; margin: 0;\">{body_html}</pre>"
            "</div>"
        )
        if hasattr(self, 'frame_search_status'):
            if search_term:
                self.frame_search_status.setText(f"{match_count} match(es) highlighted in {source_label}.")
            else:
                self.frame_search_status.setText(f"Viewing {source_label}.")

    def apply_frame_search(self):
        """Search within the currently loaded frame content and highlight matches."""
        self._render_frame_html_viewer()

    def clear_frame_search(self):
        """Clear the current frame search and remove highlights."""
        if hasattr(self, 'frame_search_input'):
            self.frame_search_input.clear()
        self._render_frame_html_viewer()

    def _show_html_in_frame_viewer(self, file_path):
        """Load HTML file contents into the Frames tab viewer."""
        if not file_path or not os.path.exists(file_path):
            self.current_frame_html_content = ""
            self.current_frame_view_label = ""
            self.frame_html_viewer.setPlainText("HTML file not found.")
            if hasattr(self, 'frame_search_status'):
                self.frame_search_status.setText("HTML file not found.")
            return

        try:
            with open(file_path, 'r', encoding='utf-8') as file_handle:
                html_content = file_handle.read()
            self._set_frame_view_content(html_content, os.path.basename(file_path))
        except Exception as exc:
            self.current_frame_html_content = ""
            self.current_frame_view_label = ""
            self.frame_html_viewer.setPlainText(f"Failed to load HTML: {str(exc)}")
            if hasattr(self, 'frame_search_status'):
                self.frame_search_status.setText("Failed to load HTML.")

    def _handle_frame_download_selection(self, item):
        """Preview the selected frame HTML file in the Frames tab."""
        file_path = item.data(Qt.ItemDataRole.UserRole)
        if file_path:
            self._show_html_in_frame_viewer(file_path)

    def preview_selected_live_frame(self):
        """Load the selected live frame directly into the in-app viewer."""
        if not self.ensure_driver():
            return

        frame_path = self.frame_selector_combo.currentData()
        html_content, frame_label = self._capture_frame_html(frame_path or [])
        if html_content is None:
            self.frame_html_viewer.setPlainText("Failed to capture frame HTML.")
            if hasattr(self, 'frame_search_status'):
                self.frame_search_status.setText("Failed to capture frame HTML.")
            return
        self._set_frame_view_content(html_content, f"Live Preview: {frame_label}")
        if hasattr(self, 'workspace_tabs') and hasattr(self, 'frame_tab_index'):
            self.workspace_tabs.setCurrentIndex(self.frame_tab_index)

    def export_selected_frame_html(self):
        """Export the selected live frame HTML and load it into the Frames tab."""
        if not self.ensure_driver():
            return

        frame_path = self.frame_selector_combo.currentData()
        html_content, frame_label = self._capture_frame_html(frame_path or [])
        if html_content is None:
            self.frame_html_viewer.setPlainText("Failed to export selected frame HTML.")
            if hasattr(self, 'frame_search_status'):
                self.frame_search_status.setText("Failed to export selected frame HTML.")
            return

        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        export_dir = self._get_export_directory()
        safe_frame_name = self._sanitize_filename_part(frame_label.replace(' > ', '_'), 'main_document')
        file_path = os.path.join(export_dir, f"{safe_frame_name}_{timestamp}.html")
        try:
            with open(file_path, 'w', encoding='utf-8') as file_handle:
                file_handle.write(html_content)
            entry = {
                'frame_label': frame_label,
                'file_path': file_path,
                'is_target': False,
            }
            self.last_frame_downloads.insert(0, entry)
            self._populate_frame_download_list(self.last_frame_downloads)
            self._set_frame_view_content(html_content, f"Exported: {frame_label}")
            self.statusBar().showMessage(f"Selected frame exported to {file_path}")
        except Exception as exc:
            self.frame_html_viewer.setPlainText(f"Failed to export selected frame HTML: {str(exc)}")
            if hasattr(self, 'frame_search_status'):
                self.frame_search_status.setText("Failed to export selected frame HTML.")

    def _download_frame_htmls(self, target_frame_path=None):
        """Download HTML for the main document and all reachable frames, marking the target frame."""
        if not self.ensure_driver():
            return []

        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        frame_export_dir = os.path.join(self._get_export_directory(), f"frames_{timestamp}")
        os.makedirs(frame_export_dir, exist_ok=True)

        try:
            frame_paths = self._collect_frame_paths()
        except Exception:
            frame_paths = [[]]

        downloads = []
        for frame_path in frame_paths:
            try:
                self._switch_to_frame_path(frame_path)
                frame_html = self.driver.page_source
                frame_label = self._format_frame_path(frame_path)
                safe_frame_name = self._sanitize_filename_part(frame_label.replace(' > ', '_'), 'main_document')
                file_path = os.path.join(frame_export_dir, f"{safe_frame_name}.html")
                with open(file_path, 'w', encoding='utf-8') as file_handle:
                    file_handle.write(frame_html)
                downloads.append({
                    'frame_path': list(frame_path),
                    'frame_label': frame_label,
                    'file_path': file_path,
                    'is_target': list(frame_path) == list(target_frame_path or [])
                })
            except Exception:
                continue
            finally:
                self.driver.switch_to.default_content()

        self.last_frame_downloads = downloads
        self._populate_frame_download_list(downloads)
        if downloads:
            self._show_html_in_frame_viewer(downloads[0].get('file_path'))
        return downloads

    def export_full_html(self):
        """Export the current main document HTML and show it in the Frames tab."""
        if not self.ensure_driver():
            return

        self._set_processing_status(True, "Exporting full HTML ...")
        try:
            timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
            export_dir = self._get_export_directory()
            os.makedirs(export_dir, exist_ok=True)
            file_path = os.path.join(export_dir, f"full_page_{timestamp}.html")

            self.driver.switch_to.default_content()
            full_html = self.driver.page_source
            with open(file_path, 'w', encoding='utf-8') as file_handle:
                file_handle.write(full_html)

            self.last_full_html_export = file_path
