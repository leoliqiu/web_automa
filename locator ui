    def _refresh_result_nav_buttons(self):
        """Show right-side result buttons only when the related pane has content."""
        output_has_content = hasattr(self, 'output') and not self.output.document().isEmpty()
        table_has_content = hasattr(self, 'table_grid') and self.table_grid.rowCount() > 0 and self.table_grid.columnCount() > 0

        if hasattr(self, 'output_nav_button'):
            self.output_nav_button.setEnabled(output_has_content)
        if hasattr(self, 'table_grid_nav_button'):
