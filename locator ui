            }
        };

        window.captureElement = function(e) {
            e.preventDefault();
            e.stopPropagation();

            const element = e.target;
            if (element !== document && element !== document.body && element !== document.documentElement) {
                const tag = element.tagName.toLowerCase();
                const id = element.getAttribute('id') || null;
                const className = element.getAttribute('class') || null;
                const name = element.getAttribute('name') || null;
                const type = element.getAttribute('type') || null;
                const value = element.getAttribute('value') || null;
                const text = (element.textContent || '').substring(0, 100).trim();
                const href = element.getAttribute('href') || null;
                const title = element.getAttribute('title') || null;

                window.selectedElementData = {
                    tag: tag,
