        self.expanded_text_registry.clear()
        source_note = (
            f"<p style=\"margin: 0 0 8px 0;\"><b>HTML downloaded:</b> {html.escape(html_filename)}</p>"
            if html_filename else
            ""
        )
        report_note = (
            f"<p style=\"margin: 0 0 8px 0;\"><b>Exported report:</b> {html.escape(report_filename)}</p>"
            if report_filename else
            ""
        )

        return f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Find All Versions Report</title>
</head>
<body style="margin: 0; font-family: 'Segoe UI', sans-serif; background-color: #e0f2fe; color: #111827;">
    <div style="max-width: 1280px; margin: 0 auto; padding: 18px;">
        <div style="margin-bottom: 18px; padding: 16px; border-radius: 10px; background-color: #ffffff; border: 2px solid #7dd3fc;">
            <h2 style="margin: 0 0 10px 0; color: #0f172a;">Find All Versions</h2>
            <p style="margin: 0 0 8px 0;"><b>Search term:</b> {html.escape(search_term)}</p>
            {source_note}
            {report_note}
            <p style="margin: 0;"><b>Total matches:</b> {len(all_matches)}</p>
        </div>

        <div style="margin-bottom: 22px;">
            <h3 style="margin: 0 0 12px 0; color: #0f172a;">Record View</h3>
            {self._render_versions_cards(all_matches)}
        </div>

        <div style="padding: 16px; border-radius: 10px; background-color: #ffffff; border: 2px solid #7dd3fc;">
            <h3 style="margin: 0 0 12px 0; color: #0f172a;">Table View</h3>
            <p style="margin: 0 0 12px 0; color: #475569;">Long text is limited to the first {self.preview_text_limit} characters. Click Expand to inspect the full value.</p>
            {self._render_versions_table(all_matches)}
        </div>
    </div>
</body>
</html>
"""

    def _export_versions_report(self, search_term, html_filename, all_matches):
        """Save the results as an HTML report file."""
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        safe_search_term = self._sanitize_filename_part(search_term, 'matches')
        report_filename = f"matches_{safe_search_term}_{timestamp}.html"
        report_path = os.path.join(self._get_export_directory(), report_filename)
        report_html = self._render_versions_report(search_term, html_filename, all_matches, report_filename)

        with open(report_path, 'w', encoding='utf-8') as report_file:
            report_file.write(report_html)

        return report_path, report_html

    def find_all_versions_comprehensive(self):
        if not self.ensure_driver():
            return

        search_term = self.locator_input.text().strip()
        if not search_term:
            self.output.append('Enter a search term')
            return

        self._set_processing_status(True, "Finding all versions ...")
        try:
            self.bg_color_toggle = not self.bg_color_toggle
            self.output.clear()

            html_content, html_filename = self.download_html()
            if not html_content:
                self.output.append('Failed to download HTML.')
                return

            all_matches = []
            try:
                frame_paths = self._collect_frame_paths()
            except Exception:
                frame_paths = [[]]

            for frame_path in frame_paths:
                try:
                    self._switch_to_frame_path(frame_path)
                    frame_html = self.driver.page_source
                    all_matches.extend(
                        self.search_text_in_html(
                            search_term,
                            frame_html,
                            self._format_frame_path(frame_path)
                        )
                    )
                except Exception:
                    continue
                finally:
                    self.driver.switch_to.default_content()

            if not all_matches:
                self.output.append('No matches found!')
                return

            try:
                report_path, report_html = self._export_versions_report(search_term, html_filename, all_matches)
            except Exception as e:
                self.output.append(f'Failed to export report HTML: {str(e)}')
                return

            self.output.setHtml(report_html)
            if hasattr(self, 'workspace_tabs') and hasattr(self, 'output_tab_index'):
                self.workspace_tabs.setCurrentIndex(self.output_tab_index)
            self.statusBar().showMessage(f"Report exported to {report_path}")
        finally:
            self._set_processing_status(False, "Find all versions finished")


