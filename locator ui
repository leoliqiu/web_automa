        locator_type = self.locator_type_combo.currentText()
        attempt_logs = []

        self._set_processing_status(True, "Testing locator ...")
        try:
            self.test_result_display.clear()
            self.test_result_display.setText(
                f"Testing {locator_type}: {locator_value[:50]}...\n"
            )

            element, strategy_used, strategy_value_used, frame_path = self.try_locator_with_strategy(
                locator_value,
                locator_type,
                attempt_logs=attempt_logs
            )
            frame_label = self._format_frame_path(frame_path or [])

            requested_locator_rows = []
            requested_seen = set()
            self._add_locator_row(requested_locator_rows, requested_seen, locator_type, locator_value, frame_label if element else "-")

            if element:
                by_strategy = self.get_locator_strategy(strategy_used, strategy_value_used)
                if by_strategy:
                    by_type, by_value = by_strategy
                    value, snapshot, table_context, context = self._with_element_in_frame(
                        by_type,
                        by_value,
                        frame_path,
                        lambda current_element: (
                            lambda value_result: (
                                value_result[0],
                                value_result[1],
                                self._extract_table_context(current_element),
                                self._get_element_dom_context(current_element)
                            )
                        )(self._extract_value_from_element(current_element, attempt_logs=attempt_logs)),
                        timeout=4
                    )
                    verified_stable_options = self._get_verified_stable_xpath_options(context or {}, attempt_logs=attempt_logs)
                else:
                    value = ""
                    snapshot = self._get_element_snapshot(element)
                    table_context = None
                    context = self._get_element_dom_context(element)
                    verified_stable_options = []

                info_lines = [
                    "SUCCESS - Element Found!",
                    f"Strategy Used: {strategy_used}",
                    f"Tag: <{snapshot.get('tag', '')}>",
                    f"Frame: {frame_label}",
                    f"Value/Text: {value or '(empty)'}",
                ]

                elem_id = snapshot.get('id')
                if elem_id:
                    info_lines.append(f"ID: {elem_id}")

                elem_class = snapshot.get('class')
                if elem_class:
                    info_lines.append(f"Class: {elem_class}")

                elem_text = (snapshot.get('text') or '')[:50]
                if elem_text:
                    info_lines.append(f"Text: {elem_text}")

                elem_value = snapshot.get('value')
                if elem_value:
                    info_lines.append(f"Value: {elem_value}")

                if snapshot.get('selected_texts'):
                    info_lines.append(f"Selected Options: {', '.join(snapshot['selected_texts'])}")
                if table_context:
                    info_lines.append(f"Nearest Table XPath: {(table_context or {}).get('xpath') or '-'}")
                if verified_stable_options:
                    primary_stable_option = verified_stable_options[0]
                    info_lines.append(f"Primary Stable XPath: {primary_stable_option['value']}")
                    info_lines.append(f"Stable XPath Frame: {self._format_frame_path(primary_stable_option['frame_path'] or [])}")
                    info_lines.append(f"Validated Stable XPath Count: {len(verified_stable_options)}")

                locator_rows = []
                seen = set()
                for row in requested_locator_rows:
                    self._add_locator_row(locator_rows, seen, row.get("type"), row.get("value"), row.get("frame"))
                if strategy_used != locator_type or strategy_value_used != locator_value:
                    self._add_locator_row(locator_rows, seen, strategy_used, strategy_value_used, frame_label)
                for row in self._build_selected_element_locator_rows(snapshot or {}, frame_label=frame_label):
                    self._add_locator_row(locator_rows, seen, row.get("type"), row.get("value"), row.get("frame"))
                for option in verified_stable_options:
                    option_frame_label = self._format_frame_path(option.get("frame_path") or [])
                    self._add_locator_row(locator_rows, seen, option.get("type"), option.get("value"), option_frame_label)
                for option in self._build_locator_result_options(context or {}):
                    locator_type_option, locator_value_option = option.split(": ", 1) if ": " in option else ("Locator", option)
                    self._add_locator_row(locator_rows, seen, locator_type_option, locator_value_option, frame_label)

                self._refresh_frame_downloads_for_match(frame_path, attempt_logs)
                self._render_tester_locator_results_html("Locator test log", attempt_logs, info_lines, locator_rows)
            else:
                info_lines = [f"FAILED - Element Not Found with {locator_type}", "Searching for similar elements..."]

                html, _ = self.download_html()
                if html:
                    similar_elements = self.find_similar_locators(locator_value, html)

                    if similar_elements:
                        info_lines.append(f"Found {len(similar_elements)} similar option(s):")

                        for i, (locator_type_alt, locator_value_alt, element_info) in enumerate(similar_elements[:5], 1):
                            info_lines.append(f"{i}. Try: [{locator_type_alt}]")
