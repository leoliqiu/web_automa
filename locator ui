    def _find_element_across_frames(self, finder):
        """Run a finder callback across the main document and nested frames."""
        try:
            frame_paths = self._collect_frame_paths()
        except Exception:
            frame_paths = [[]]

        for frame_path in frame_paths:
            try:
                self._switch_to_frame_path(frame_path)
                result = finder()
                if result:
                    return result, frame_path
            except Exception:
                continue
            finally:
                self.driver.switch_to.default_content()
        return None, None

    def search_text_in_html(self, text, html, frame_path='main document'):
        try:
            soup = BeautifulSoup(html, 'lxml')
            matches = []
            for element in soup.find_all(string=True):
                if text.lower() in element.lower():
                    parent = element.parent
                    context = {
                        'text': element.strip(),
                        'tag': parent.name,
                        'id': parent.get('id'),
                        'class': parent.get('class'),
                        'name': parent.get('name'),
                        'type': parent.get('type'),
                        'href': parent.get('href'),
                        'frame_path': frame_path,
                    }
                    matches.append(context)
            return matches
        except Exception as e:
            self.output.append(f"Error searching HTML: {str(e)}")
            return []

    def correct_xpath(self, xpath):
        """Correct common XPath errors."""
        corrected = xpath
        corrected = corrected.replace('""', "'")

        if "[" in corrected and "@" not in corrected:
            corrected = corrected.replace("[id=", "[@id=")
            corrected = corrected.replace("[name=", "[@name=")
            corrected = corrected.replace("[class=", "[@class=")

        if corrected.startswith("/") and not corrected.startswith("//"):
            corrected = "/" + corrected

        return corrected

    def try_xpath_variants(self, xpath):
        """Try different XPath variants across the main document and nested frames."""
        variants = [
            xpath,
            self.correct_xpath(xpath),
        ]

        for variant in variants:
            element, frame_path = self._find_element_across_frames(
                lambda variant=variant: self.driver.find_element(By.XPATH, variant)
            )
            if element:
                return element, variant, frame_path
        return None, None, None

    def _build_analyze_locator_options(self, snapshot, context):
        """Build locator suggestions for Analyze Locator."""
        return [
            f"{row['type']}: {row['value']}"
            for row in self._build_analyze_locator_rows(snapshot, context)
        ]

    def _add_locator_row(self, rows, seen, locator_type, locator_value, frame_label=None):
        """Append a locator row once so outputs stay deduplicated."""
        locator_type = (locator_type or '').strip()
        locator_value = (locator_value or '').strip()
        if not locator_type or not locator_value:
            return
        frame_label = (frame_label or '').strip() or '-'
        key = (locator_type, locator_value, frame_label)
        if key in seen:
            return
        rows.append({"type": locator_type, "value": locator_value, "frame": frame_label})
        seen.add(key)

    def _build_analyze_locator_rows(self, snapshot, context, frame_label='-'):
        """Build structured locator rows for Analyze Locator output."""
        tag = (snapshot.get('tag') or '*').lower()
        text = (snapshot.get('text') or '').strip()
        elem_value = (snapshot.get('value') or '').strip()
        elem_id = (snapshot.get('id') or '').strip()
        elem_name = (snapshot.get('name') or '').strip()
        elem_class = (snapshot.get('class') or '').strip()
        elem_href = (snapshot.get('href') or '').strip()
        elem_title = (snapshot.get('title') or '').strip()
        stable_classes = self._stable_class_tokens(elem_class)
        prev_sibling = context.get('prevSibling') if context else None
        next_sibling = context.get('nextSibling') if context else None

        rows = []
        seen = set()

        if text:
            self._add_locator_row(
                rows,
                seen,
                "XPath Text",
                f"//{tag}[contains(normalize-space(.),{self._escape_xpath_text(text[:30])})]",
                frame_label
            )
            self._add_locator_row(
                rows,
                seen,
                "XPath Text Exact",
                f"//{tag}[normalize-space(.)={self._escape_xpath_text(text[:60])}]",
                frame_label
            )
            if tag == 'a':
                self._add_locator_row(rows, seen, "Link Text", text[:100], frame_label)
                self._add_locator_row(rows, seen, "Partial Link Text", text[:30], frame_label)

        if elem_value:
            self._add_locator_row(rows, seen, "XPath Value", f"//{tag}[@value={self._escape_xpath_text(elem_value)}]", frame_label)

        if elem_id:
            self._add_locator_row(rows, seen, "ID", elem_id, frame_label)
            self._add_locator_row(rows, seen, "CSS ID", f"#{elem_id}", frame_label)
            self._add_locator_row(
                rows,
                seen,
                "XPath ID",
                f"//{tag}[@id={self._escape_xpath_text(elem_id)}]",
                frame_label
            )

        if elem_name:
            self._add_locator_row(rows, seen, "Name", elem_name, frame_label)
            self._add_locator_row(
                rows,
                seen,
                "XPath Name",
                f"//{tag}[@name={self._escape_xpath_text(elem_name)}]",
                frame_label
            )

        if elem_href:
            self._add_locator_row(rows, seen, "Href", elem_href, frame_label)
            self._add_locator_row(rows, seen, "CSS Href", f"{tag}[href='{elem_href}']", frame_label)
            self._add_locator_row(rows, seen, "XPath Href", f"//{tag}[@href={self._escape_xpath_text(elem_href)}]", frame_label)

        if elem_title:
            self._add_locator_row(rows, seen, "Title", elem_title, frame_label)
            self._add_locator_row(rows, seen, "CSS Title", f"{tag}[title='{elem_title}']", frame_label)
            self._add_locator_row(rows, seen, "XPath Title", f"//{tag}[@title={self._escape_xpath_text(elem_title)}]", frame_label)

        if stable_classes:
            class_conditions = " and ".join(
                f"contains(@class,{self._escape_xpath_text(class_token)})" for class_token in stable_classes[:2]
            )
            first_class = stable_classes[0]
            self._add_locator_row(rows, seen, "Class Name", first_class, frame_label)
            self._add_locator_row(rows, seen, "CSS Class", f".{first_class}", frame_label)
            self._add_locator_row(rows, seen, "Class Auto", f"{tag}.{first_class}", frame_label)
            self._add_locator_row(rows, seen, "CSS Tag.Class", f"{tag}.{first_class}", frame_label)
            self._add_locator_row(rows, seen, "XPath Class", f"//{tag}[{class_conditions}]", frame_label)

        dynamic_candidates = self._build_dynamic_xpath_candidates(context or {})
        for candidate in dynamic_candidates:
            if "following-sibling::" in candidate:
                self._add_locator_row(rows, seen, "Stable XPath From Previous Sibling", candidate, frame_label)
            elif "preceding-sibling::" in candidate:
                self._add_locator_row(rows, seen, "Stable XPath From Next Sibling", candidate, frame_label)
            else:
                self._add_locator_row(rows, seen, "Stable XPath", candidate, frame_label)

        for option in self._build_locator_result_options(context or {}):
            locator_type, locator_value = option.split(": ", 1) if ": " in option else ("Locator", option)
            self._add_locator_row(rows, seen, locator_type, locator_value, frame_label)

        if getattr(self, "archer_mode_btn", None) and self.archer_mode_btn.isChecked():
            archer_seed = text or elem_id or elem_name or elem_href or elem_title
            if archer_seed:
                for rule_name, rule_type, rule_value in build_archer_strategy_rules(
                    archer_seed,
                    self._escape_xpath_text
                ):
                    self._add_locator_row(rows, seen, f"{rule_type} | {rule_name}", rule_value, frame_label)
        return rows

