    def analyze_locator(self):
        if not self.ensure_driver():
            return

        locator_input = self.locator_input.text().strip()
        if not locator_input:
            self.output.append("Enter a locator or search term")
            return

        self._set_processing_status(True, "Analyzing locator ...")
        try:
            locator_type = "XPath" if locator_input.startswith("//") else "Auto-Detect"
            attempt_logs = []
            archer_rules = []
            if getattr(self, "archer_mode_btn", None) and self.archer_mode_btn.isChecked():
                archer_rules = list(build_archer_strategy_rules(locator_input, self._escape_xpath_text))
                self._append_attempt_log(
                    attempt_logs,
                    f"Archer Mode is ON. Added {len(archer_rules)} Archer-specific locator rule(s) before standard strategies."
                )
            element, strategy_used, strategy_value_used, frame_path = self.try_locator_with_strategy(
                locator_input,
                locator_type,
                attempt_logs=attempt_logs
            )

            if element:
                by_strategy = self.get_locator_strategy(strategy_used, strategy_value_used)
                if not by_strategy:
                    self._render_output_locator_results_html(
                        "Analyze Locator",
                        attempt_logs,
                        ["FAILED - Matched element, but could not rebuild locator strategy for analysis."],
                        [],
                    )
                    return

                by_type, by_value = by_strategy
                snapshot, context = self._with_element_in_frame(
                    by_type,
                    by_value,
                    frame_path,
                    lambda current_element: (
                        self._get_element_snapshot(current_element),
                        self._get_element_dom_context(current_element)
                    ),
                    timeout=4
                )
                frame_label = self._format_frame_path(frame_path or [])
                info_lines = [
                    "SUCCESS - Element Found!",
                    f"Strategy Used: {strategy_used}",
                    f"Tag: <{snapshot.get('tag') or '-'}>",
                    f"ID: {snapshot.get('id') or '(none)'}",
                    f"Name: {snapshot.get('name') or '(none)'}",
                    f"Class: {snapshot.get('class') or '(none)'}",
                    f"Href: {snapshot.get('href') or '(none)'}",
                    f"Title: {snapshot.get('title') or '(none)'}",
                    f"Text: {(snapshot.get('text') or '(none)')[:60]}",
                    f"Frame: {frame_label}",
                ]
                if strategy_used == "XPath" and strategy_value_used != locator_input:
                    info_lines.append(f"Auto-corrected XPath: {strategy_value_used}")
                if archer_rules:
                    info_lines.append(f"Archer Mode: ON")
                    info_lines.append(f"Archer Rules Attempted: {len(archer_rules)}")
                    if " | " in (strategy_used or ""):
                        _, matched_archer_rule = strategy_used.split(" | ", 1)
                        info_lines.append(f"First Archer Match: {matched_archer_rule}")
                    else:
                        info_lines.append("First Archer Match: none")

                locator_rows = self._build_analyze_locator_rows(snapshot, context, frame_label=frame_label)
                self._refresh_frame_downloads_for_match(frame_path)
                self._render_output_locator_results_html("Analyze Locator", attempt_logs, info_lines, locator_rows)
            else:
                info_lines = ["FAILED - Element not found in main document or nested iframes. Try with different format."]
                if archer_rules:
                    info_lines.append("Archer Mode: ON")
                    info_lines.append(f"Archer Rules Attempted: {len(archer_rules)}")
                    info_lines.append("First Archer Match: none")
                self._render_output_locator_results_html("Analyze Locator", attempt_logs, info_lines, [])
        finally:
            self._set_processing_status(False, "Locator analysis finished")

    def _set_selection_buttons_state(self, active_mode=None):
        """Keep selection buttons in sync with the active page-pick mode."""
        is_active = bool(active_mode)
        if hasattr(self, "click_element_btn"):
            self.click_element_btn.setEnabled(not is_active or active_mode == "single")
            self.click_element_btn.setText("Selecting..." if active_mode == "single" else "Click Element on Page")
        if hasattr(self, "relative_xpath_btn"):
            self.relative_xpath_btn.setEnabled(not is_active or active_mode == "relative")
            self.relative_xpath_btn.setText("Selecting..." if active_mode == "relative" else "Build Relative XPath")
        if hasattr(self, "cancel_selection_btn"):
            self.cancel_selection_btn.setVisible(is_active)
            self.cancel_selection_btn.setEnabled(is_active)

    def _get_selection_context_paths(self):
        """Return the document/frame contexts used for selector injection and cleanup."""
        try:
            return self._collect_frame_paths()
        except Exception:
            return [[]]

    def _run_script_in_selection_contexts(self, script):
        """Execute a selector script in the main document and reachable frames."""
        executed_count = 0
        for frame_path in self._get_selection_context_paths():
            try:
                self._switch_to_frame_path(frame_path)
                self.driver.execute_script(script)
                executed_count += 1
            except Exception:
                continue
            finally:
                self.driver.switch_to.default_content()
        return executed_count

    def _begin_selection_mode(self, mode, js_code, header_lines, ready_message, tester_message=None):
        """Start a selection mode using shared setup and context injection."""
        self.cleanup_element_selector()
        self.selection_mode = mode
        self.relative_selection_progress = None
        self._set_selection_buttons_state(mode)
        for line in header_lines:
            self.output.append(line)
        try:
            injected_count = self._run_script_in_selection_contexts(js_code)
            if tester_message:
                self.test_result_display.setText(tester_message)
            self.output.append(ready_message.format(injected_count=injected_count))
            self._start_element_selection_polling()
        except Exception as e:
            self.output.append(f"Failed to enable selector: {str(e)}")
            self.cleanup_element_selector()

    def enable_element_selection(self):
