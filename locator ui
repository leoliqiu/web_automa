        dialog.exec()

    def capture_selected_element(self, dialog):
        """Get the selected element data and show locators."""
        try:
            element_data = None
            selected_frame_path = []
            try:
                frame_paths = self._collect_frame_paths()
            except Exception:
                frame_paths = [[]]

            for frame_path in frame_paths:
                try:
                    self._switch_to_frame_path(frame_path)
                    frame_element_data = self.driver.execute_script("return window.selectedElementData || null;")
                    if frame_element_data:
                        element_data = frame_element_data
                        selected_frame_path = list(frame_path)
                        break
                except Exception:
                    continue
                finally:
                    self.driver.switch_to.default_content()

            if not element_data:
                QMessageBox.warning(self, "No Element", "Please click on an element first!")
                return

            dialog.close()

            self.bg_color_toggle = not self.bg_color_toggle
            bg_marker = "[A]" if self.bg_color_toggle else "[B]"

            self.output.append(f"\n{bg_marker} " + "=" * 98)
            self.output.append("ELEMENT SELECTED")
            self.output.append("=" * 100)

            self.output.append("\nELEMENT INFO:")
            self.output.append(f"  Tag: <{element_data['tag']}>")
            if element_data['id']:
                self.output.append(f"  ID: {element_data['id']}")
            if element_data['class']:
                self.output.append(f"  Class: {element_data['class']}")
            if element_data['name']:
                self.output.append(f"  Name: {element_data['name']}")
            if element_data['type']:
                self.output.append(f"  Type: {element_data['type']}")
            if element_data.get('value'):
                self.output.append(f"  Value: {element_data['value']}")
            if element_data['text']:
                self.output.append(f"  Text: {element_data['text'][:60]}")
            if element_data['href']:
                self.output.append(f"  Href: {element_data['href']}")
            if element_data.get('title'):
                self.output.append(f"  Title: {element_data['title']}")
            frame_label = self._format_frame_path(selected_frame_path)
            self.output.append(f"  Frame: {frame_label}")

            self.output.append("\nLOCATOR OPTIONS:")
            self._append_locator_rows_table(self._build_selected_element_locator_rows(element_data, frame_label=frame_label))

            self.output.append("=" * 100)
            self.output.append("You can now copy any locator above to use in your tests")
            self.cleanup_element_selector()
        except Exception as e:
            QMessageBox.critical(self, "Error", f"Failed to capture element: {str(e)}")
            self.cleanup_element_selector()

    def cancel_element_selection(self, dialog=None):
        """Cancel element selection."""
        if dialog is not None:
            dialog.close()
        self.cleanup_element_selector()
        self.output.append("Element selection cancelled")

    def cleanup_element_selector(self):
        """Remove element selector from the main document and reachable frames."""
        try:
            if self.selection_poll_timer:
                self.selection_poll_timer.stop()
            self.selection_mode = None
            self.relative_selection_progress = None
            self._set_selection_buttons_state(None)
            cleanup_js = """
            if (window.elementSelectorActive) {
                document.removeEventListener('mouseover', window.highlightElement, true);
                document.removeEventListener('click', window.captureElement, true);
                if (window.clearElementSelectorHighlight) {
                    window.clearElementSelectorHighlight();
                }
                window.elementSelectorActive = false;
                window.selectedElementData = null;
            }
            if (window.relativeXPathSelectionActive || window.relativeSelectionData) {
                document.removeEventListener('mouseover', window.relativeHighlightElement, true);
                document.removeEventListener('click', window.captureRelativeElement, true);
                if (window.clearRelativeXPathHighlight) {
                    window.clearRelativeXPathHighlight();
                }
                window.relativeXPathSelectionActive = false;
                window.relativeSelectionStage = null;
                window.relativeSelectionData = null;
                window.relativeSelectedTarget = null;
            }
            """
            if self.driver:
                self._run_script_in_selection_contexts(cleanup_js)
        except Exception:
            pass

    def _escape_xpath_text(self, value):
        """Escape text for safe XPath string usage."""
        if value is None:
            return "''"
        if "'" not in value:
            return f"'{value}'"
        if '"' not in value:
            return f'"{value}"'
        parts = value.split("'")
        return "concat(" + ", \"'\", ".join(f"'{part}'" for part in parts) + ")"

    def _is_dynamic_token(self, token):
        """Heuristic check for tokens that likely contain dynamic identifiers."""
        if not token:
            return False
        token = str(token).strip()
        return (
            len(token) > 10 and bool(re.search(r'\d', token)) and bool(re.search(r'[A-Za-z]', token))
        ) or bool(re.search(r'[0-9]{3,}', token))

    def _stable_class_tokens(self, class_value):
        """Return class tokens that are more likely to be stable."""
        if not class_value:
            return []
        tokens = class_value if isinstance(class_value, list) else str(class_value).split()
        stable_tokens = []
        for token in tokens:
            token = token.strip()
            if not token:
                continue
            if self._is_dynamic_token(token):
                continue
            stable_tokens.append(token)
        return stable_tokens[:3]

    def _append_attempt_log(self, logs, message):
        """Append a formatted attempt message."""
        if logs is not None:
            logs.append(message)

    def _update_archer_mode_button(self, checked):
        """Reflect Archer mode state in the toggle button label."""
        self.archer_mode_btn.setText("Archer Mode ON" if checked else "Archer Mode")

    def _normalize_strategy_name(self, locator_type):
        """Map decorated strategy names back to a supported base locator type."""
        locator_type = (locator_type or "").strip()
        return locator_type.split(" | ", 1)[0] if " | " in locator_type else locator_type

    def _build_strategy_list(self, locator_value, locator_type):
        """Build the strategies to try for the given locator."""
        strategies = []

        if getattr(self, "archer_mode_btn", None) and self.archer_mode_btn.isChecked():
            for rule_name, rule_type, rule_value in build_archer_strategy_rules(locator_value, self._escape_xpath_text):
                strategies.append((f"{rule_type} | {rule_name}", rule_value))

        if locator_type == "Auto-Detect":
            strategies.extend([
                ("XPath", locator_value if locator_value.startswith("//") else f"//*[contains(normalize-space(.),{self._escape_xpath_text(locator_value)})]"),
                ("ID", locator_value),
                ("CSS Selector", locator_value),
                ("Name", locator_value),
                ("Text (Contains)", locator_value),
            ])
            return strategies

        strategies.append((locator_type, locator_value))
        return strategies

    def _find_element_in_frames_with_wait(self, by_type, by_value, timeout=4):
        """Find an element across frames with a small explicit wait."""
        try:
            frame_paths = self._collect_frame_paths()
        except Exception:
            frame_paths = [[]]

        for frame_path in frame_paths:
            try:
                self._switch_to_frame_path(frame_path)
                wait = WebDriverWait(self.driver, timeout)
                element = wait.until(lambda driver: driver.find_element(by_type, by_value))
                if element:
                    return element, frame_path
            except Exception:
                continue
            finally:
                self.driver.switch_to.default_content()
        return None, None

    def _get_element_snapshot(self, element):
        """Capture element details without keeping a live reference for later UI use."""
        snapshot = {
            'tag': '',
            'id': '',
            'class': '',
            'text': '',
            'value': '',
            'name': '',
            'type': '',
            'href': '',
            'title': '',
            'selected_texts': [],
        }
        try:
            snapshot['tag'] = element.tag_name or ''
        except Exception:
            pass
        for attr in ('id', 'class', 'value', 'name', 'type', 'href', 'title'):
            try:
                snapshot[attr] = element.get_attribute(attr) or ''
            except Exception:
                snapshot[attr] = ''
        try:
            snapshot['text'] = (element.text or '')[:120]
        except Exception:
            snapshot['text'] = ''
        try:
            if (snapshot['tag'] or '').lower() == 'select':
                select = Select(element)
                snapshot['selected_texts'] = [opt.text.strip() for opt in select.all_selected_options if opt.text.strip()]
        except Exception:
            snapshot['selected_texts'] = []
        return snapshot

    def _locate_element_in_frame(self, by_type, by_value, frame_path, timeout=4):
        """Locate an element while already scoped to a specific frame path."""
        self._switch_to_frame_path(frame_path or [])
        wait = WebDriverWait(self.driver, timeout)
        return wait.until(lambda driver: driver.find_element(by_type, by_value))

    def _with_element_in_frame(self, by_type, by_value, frame_path, callback, timeout=4):
        """Run a callback with a fresh element inside its frame and always restore default content."""
        try:
            element = self._locate_element_in_frame(by_type, by_value, frame_path, timeout=timeout)
            return callback(element)
        finally:
            self.driver.switch_to.default_content()

    def _locate_with_strategies(self, strategies_to_try, attempt_logs=None, timeout=4):
        """Try a list of locator strategies and log each attempt."""
        for strategy_name, strategy_value in strategies_to_try:
            self._append_attempt_log(attempt_logs, f"Trying locator option: [{strategy_name}] {strategy_value}")
            try:
                by_strategy = self.get_locator_strategy(strategy_name, strategy_value)
                if not by_strategy:
                    self._append_attempt_log(attempt_logs, f"Skipped unsupported strategy: {strategy_name}")
                    continue

                by_type, by_value = by_strategy
                element, frame_path = self._find_element_in_frames_with_wait(by_type, by_value, timeout=timeout)
                if element:
                    self._append_attempt_log(
                        attempt_logs,
                        f"SUCCESS with locator option: [{strategy_name}] in {self._format_frame_path(frame_path or [])}"
                    )
                    return element, strategy_name, strategy_value, frame_path
                self._append_attempt_log(attempt_logs, f"No match for option: [{strategy_name}]")
            except Exception as e:
                self._append_attempt_log(attempt_logs, f"Option failed: [{strategy_name}] - {str(e)}")
        return None, None, None, None

    def _looks_like_dropdown_element(self, element):
        """Best-effort detection for dropdown or option elements."""
        try:
            tag = (element.tag_name or '').lower()
            role = (element.get_attribute('role') or '').lower()
            aria_haspopup = (element.get_attribute('aria-haspopup') or '').lower()
            classes = (element.get_attribute('class') or '').lower()
            multiple = element.get_attribute('multiple')
            return (
                tag in ('select', 'option')
                or role in ('combobox', 'listbox', 'option', 'menuitem')
                or aria_haspopup in ('listbox', 'menu', 'true')
                or any(keyword in classes for keyword in ('dropdown', 'select', 'menu', 'option', 'combo'))
                or multiple is not None
            )
        except Exception:
            return False

    def _open_dropdown_if_needed(self, element, attempt_logs=None):
        """Open a dropdown-like control and wait briefly for options to become available."""
        if not self._looks_like_dropdown_element(element):
            return

        self._append_attempt_log(attempt_logs, "Dropdown handling enabled. Attempting to open option container.")
        try:
            tag = (element.tag_name or '').lower()
            if tag == 'option':
                self._append_attempt_log(attempt_logs, "Target is a native <option>; parent <select> will handle selection.")
                return

            self.driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", element)
            try:
                element.click()
                self._append_attempt_log(attempt_logs, "Dropdown trigger clicked directly.")
            except Exception:
                self.driver.execute_script("arguments[0].click();", element)
                self._append_attempt_log(attempt_logs, "Dropdown trigger clicked with JavaScript fallback.")

            WebDriverWait(self.driver, 3).until(
                lambda driver: len(driver.find_elements(By.XPATH, "//option|//*[@role='option']")) > 0
            )
            self._append_attempt_log(attempt_logs, "Option list appeared after waiting.")
        except Exception as e:
            self._append_attempt_log(attempt_logs, f"Dropdown open attempt did not confirm options: {str(e)}")

    def _extract_value_from_element(self, element, attempt_logs=None):
        """Return the most useful value representation for a matched element."""
        snapshot = self._get_element_snapshot(element)
        tag = (snapshot.get('tag') or '').lower()

        if tag == 'select':
            selected_texts = snapshot.get('selected_texts') or []
            if selected_texts:
                self._append_attempt_log(attempt_logs, f"Read selected option text: {', '.join(selected_texts)}")
                return ", ".join(selected_texts), snapshot

        value = snapshot.get('value') or ''
        if value:
            self._append_attempt_log(attempt_logs, f"Read value attribute: {value}")
            return value, snapshot

        text = snapshot.get('text') or ''
        if text:
            self._append_attempt_log(attempt_logs, f"Read visible text: {text}")
            return text, snapshot

        self._append_attempt_log(attempt_logs, "Element did not expose a value or visible text.")
        return "", snapshot

    def _extract_table_context(self, element, element_is_table=False):
        """Extract the nearest table around the current element, if one exists."""
        script = """
        const element = arguments[0];
        const elementIsTable = !!arguments[1];

        function stableClasses(node) {
            if (!node) return [];
            return (node.className || '')
                .split(/\\s+/)
                .map(token => token.trim())
                .filter(token => token && !(/[0-9]{3,}/.test(token) || (token.length > 10 && /[A-Za-z]/.test(token) && /\\d/.test(token))))
                .slice(0, 3);
        }

        function cleanText(value) {
            return (value || '').replace(/\\s+/g, ' ').trim();
        }

        function getElementText(node) {
            return cleanText(node ? (node.innerText || node.textContent || '') : '');
        }

        function buildXPath(node) {
            if (!node) return '';
            if (node.id) {
                return `//${node.tagName.toLowerCase()}[@id="${node.id}"]`;
            }

            const path = [];
            let current = node;
            while (current && current.nodeType === 1) {
                let index = 1;
                let sibling = current.previousElementSibling;
                while (sibling) {
                    if (sibling.tagName === current.tagName) {
                        index += 1;
                    }
                    sibling = sibling.previousElementSibling;
                }
                path.unshift(`${current.tagName.toLowerCase()}[${index}]`);
                current = current.parentElement;
                if (current && current.tagName && current.tagName.toLowerCase() === 'html') {
                    path.unshift('html[1]');
                    break;
                }
            }
            return '/' + path.join('/');
        }

        function getCellText(cell) {
            return getElementText(cell);
        }

        function reconstructRows(table) {
            const sourceRows = Array.from(table.querySelectorAll('tr'));
            const grid = [];
            const activeSpans = [];

            sourceRows.forEach((row, rowIndex) => {
                if (!grid[rowIndex]) {
                    grid[rowIndex] = [];
                }

                let columnIndex = 0;
                while (activeSpans[columnIndex] && activeSpans[columnIndex].remaining > 0) {
                    grid[rowIndex][columnIndex] = activeSpans[columnIndex].text;
                    activeSpans[columnIndex].remaining -= 1;
                    if (activeSpans[columnIndex].remaining <= 0) {
                        activeSpans[columnIndex] = null;
                    }
                    columnIndex += 1;
                }

                const cells = Array.from(row.children).filter(cell => {
                    const tag = (cell.tagName || '').toLowerCase();
                    return tag === 'th' || tag === 'td';
                });

                cells.forEach(cell => {
                    while (grid[rowIndex][columnIndex] !== undefined) {
                        columnIndex += 1;
                    }

                    const text = getCellText(cell);
                    const rowSpan = parseInt(cell.getAttribute('rowspan') || '1', 10);
                    const colSpan = parseInt(cell.getAttribute('colspan') || '1', 10);

                    for (let colOffset = 0; colOffset < colSpan; colOffset += 1) {
                        grid[rowIndex][columnIndex + colOffset] = text;
                        if (rowSpan > 1) {
                            activeSpans[columnIndex + colOffset] = {
                                text: text,
                                remaining: rowSpan - 1
                            };
                        }
                    }
                    columnIndex += colSpan;

                    while (activeSpans[columnIndex] && activeSpans[columnIndex].remaining > 0) {
                        grid[rowIndex][columnIndex] = activeSpans[columnIndex].text;
                        activeSpans[columnIndex].remaining -= 1;
                        if (activeSpans[columnIndex].remaining <= 0) {
                            activeSpans[columnIndex] = null;
                        }
                        columnIndex += 1;
                    }
                });
            });

            return grid
                .map(row => row.map(cell => cleanText(cell || '')))
                .filter(row => row.some(cell => cell));
        }

        function getCandidateTables(node) {
            const candidates = [];
            const seen = new Set();
            let current = node;

            while (current && current.nodeType === 1) {
                let scopedTables = [];
                const tag = (current.tagName || '').toLowerCase();
                if (tag === 'table' || tag === 'grid' || current.getAttribute('role') === 'table' || current.getAttribute('role') === 'grid') {
                    scopedTables.push(current);
                }
                scopedTables = scopedTables.concat(Array.from(current.querySelectorAll('table, [role="table"], [role="grid"]')));
                scopedTables.forEach(table => {
                    if (!seen.has(table)) {
                        seen.add(table);
                        candidates.push(table);
                    }
                });
                current = current.parentElement;
            }
            return candidates;
        }

        function scoreTable(table, targetText) {
            const rows = reconstructRows(table);
            const tableText = getElementText(table);
            let score = 0;
            if (table === element) {
                score += 150;
            }
            if (table.contains(element)) {
                score += 100;
            }
            if (targetText && tableText.includes(targetText)) {
                score += 20;
            }
            if (rows.some(row => row.some(cell => targetText && cell.includes(targetText)))) {
                score += 40;
            }
            score += Math.min(rows.length, 20);
            return { table, rows, score };
        }

        const targetText = getElementText(element);
        const candidateTables = (elementIsTable ? [element] : getCandidateTables(element))
            .map(table => scoreTable(table, targetText))
            .sort((a, b) => b.score - a.score);

        if (!candidateTables.length || candidateTables[0].score <= 0) {
            return null;
        }

        const table = candidateTables[0].table;
        const rows = candidateTables[0].rows;

        let headers = [];
        const headerCells = table.querySelectorAll('thead th');
        if (headerCells.length) {
            headers = Array.from(headerCells).map(cell => cleanText(cell.innerText || cell.textContent));
        } else if (rows.length > 0) {
            headers = rows[0];
        }

        const stableTableClasses = stableClasses(table);
        const classXPath = stableTableClasses.length
            ? `//${table.tagName.toLowerCase()}[` + stableTableClasses.map(token => `contains(@class,"${token}")`).join(' and ') + `]`
            : '';

        return {
            tag: (table.tagName || '').toLowerCase(),
            id: table.id || '',
            classes: stableTableClasses,
            xpath: buildXPath(table),
            class_xpath: classXPath,
            headers: headers,
            rows: rows,
            row_count: rows.length,
            column_count: rows.reduce((maxCols, row) => Math.max(maxCols, row.length), 0),
            anchor_text: targetText
        };
        """
        return self.driver.execute_script(script, element, element_is_table)

    def _table_context_to_dataframe(self, table_context):
        """Convert extracted table context into a pandas DataFrame."""
        rows = table_context.get('rows') or []
        headers = table_context.get('headers') or []
        if not rows:
            return pd.DataFrame()

        filtered_rows = self._strip_pagination_rows(rows)
        data_rows = rows
        if headers and filtered_rows and headers == filtered_rows[0]:
            data_rows = filtered_rows[1:]
        else:
            data_rows = filtered_rows

        max_cols = max(len(row) for row in filtered_rows) if filtered_rows else 0
        if max_cols == 0:
            return pd.DataFrame()
        normalized_rows = [row + [''] * (max_cols - len(row)) for row in data_rows]

        if headers and len(headers) == max_cols:
            columns = headers
        else:
            columns = [f"Column {index}" for index in range(1, max_cols + 1)]

        return pd.DataFrame(normalized_rows, columns=columns)

    def _looks_like_pagination_row(self, row, total_rows, row_index):
        """Heuristically identify trailing pagination controls captured as table rows."""
        non_empty_cells = [str(cell).strip() for cell in (row or []) if str(cell).strip()]
        if not non_empty_cells:
            return False
        if row_index < max(0, total_rows - 2):
            return False

        combined = " ".join(non_empty_cells).lower()
        compact = re.sub(r"\s+", " ", combined).strip()
        if len(compact) > 80:
            return False

        normalized = re.sub(r"[|,/\\()\[\]{}]+", " ", compact)
        tokens = [token for token in normalized.split() if token]
        if not tokens:
            return False

        keyword_tokens = {
            "page", "pages", "next", "prev", "previous", "first", "last",
            "more", "older", "newer", "back", "forward"
        }
        punctuation_tokens = {"<", ">", "<<", ">>", "‹", "›", "«", "»"}
        numeric_tokens = [token for token in tokens if token.isdigit()]
        pagination_keywords = [token for token in tokens if token in keyword_tokens or token in punctuation_tokens]
        allowed_tokens = []
        for token in tokens:
            cleaned = token.strip(".:-")
            if (
                cleaned.isdigit()
                or cleaned in keyword_tokens
                or cleaned in punctuation_tokens
                or re.fullmatch(r"[<>«»‹›]+", cleaned)
            ):
                allowed_tokens.append(token)

        if len(allowed_tokens) != len(tokens):
            return False

        has_pagination_pattern = len(numeric_tokens) >= 2 or bool(pagination_keywords)
        return has_pagination_pattern

    def _strip_pagination_rows(self, rows):
        """Remove trailing rows that appear to be pagination controls."""
        filtered_rows = list(rows or [])
        while filtered_rows and self._looks_like_pagination_row(filtered_rows[-1], len(filtered_rows), len(filtered_rows) - 1):
            filtered_rows.pop()
        return filtered_rows

    def _build_table_locator_rows(self, table_context, dataframe, frame_label='-'):
        """Build structured locator rows for extracted table output."""
        rows = []
        seen = set()
        self._add_locator_row(rows, seen, "Table XPath", table_context.get('xpath') or '', frame_label)
        self._add_locator_row(rows, seen, "Table Class XPath", table_context.get('class_xpath') or '', frame_label)
        self._add_locator_row(rows, seen, "Table ID", table_context.get('id') or '', frame_label)
        classes = table_context.get('classes') or []
        if classes:
            self._add_locator_row(rows, seen, "Table Class", "." + ".".join(classes), frame_label)
        headers = [str(header).strip() for header in (table_context.get('headers') or []) if str(header).strip()]
        if headers:
            self._add_locator_row(rows, seen, "Table Headers", " | ".join(headers[:10]), frame_label)
        self._add_locator_row(rows, seen, "Extracted Rows", str(dataframe.shape[0]), frame_label)
        self._add_locator_row(rows, seen, "Extracted Columns", str(dataframe.shape[1]), frame_label)
        return rows

    def _render_table_extraction_report(self, locator_value, frame_path, table_context, dataframe):
        """Render extracted table information and content as HTML."""
        info_rows = [
            ("Locator", locator_value),
            ("Frame", self._format_frame_path(frame_path or [])),
            ("Anchor Text", table_context.get('anchor_text') or '-'),
            ("Table XPath", table_context.get('xpath') or '-'),
            ("Table Class XPath", table_context.get('class_xpath') or '-'),
            ("Table ID", table_context.get('id') or '-'),
            ("Rows", str(dataframe.shape[0])),
            ("Columns", str(dataframe.shape[1])),
        ]

        info_html = ''.join(
            f"<tr><th style=\"text-align:left; padding:8px; border:1px solid #cbd5e1; background:#eff6ff;\">{html.escape(label)}</th>"
            f"<td style=\"padding:8px; border:1px solid #cbd5e1;\">{html.escape(value)}</td></tr>"
            for label, value in info_rows
        )

        if dataframe.empty:
            table_html = "<p style=\"margin: 12px 0 0 0;\">No table rows were extracted.</p>"
        else:
            preview_dataframe = dataframe.applymap(lambda value: self._truncate_text(value))
            table_html = preview_dataframe.to_html(index=False, border=0, classes="table-extract")

        return f"""
        <div style="font-family: 'Segoe UI', sans-serif; color: #0f172a; background: #f8fbff; padding: 16px;">
            <h2 style="margin: 0 0 12px 0;">Extracted Table</h2>
            <p style="margin: 0 0 12px 0; color: #475569;">Long text is limited to the first {self.preview_text_limit} characters in this view. Use the Table Grid tab to expand a cell.</p>
            <table style="width: 100%; border-collapse: collapse; margin-bottom: 16px;">
                <tbody>{info_html}</tbody>
            </table>
            <div style="overflow-x: auto;">
                {table_html}
            </div>
        </div>
        """

    def _maybe_extract_table_for_locator(self, locator_value, frame_path, table_context, attempt_logs=None):
        """Persist the nearest table as a DataFrame and render it when requested."""
        if not table_context:
            self._append_attempt_log(attempt_logs, "No ancestor table was found for the matched element.")
            return None

        dataframe = self._table_context_to_dataframe(table_context)
        self.last_extracted_table_df = dataframe
        self.last_extracted_table_html = self._render_table_extraction_report(locator_value, frame_path, table_context, dataframe)
        self._populate_table_grid(dataframe)
        self.output.setHtml(self.last_extracted_table_html)
        self._append_attempt_log(
            attempt_logs,
            f"Extracted table into DataFrame with shape {dataframe.shape[0]}x{dataframe.shape[1]}."
        )
        return dataframe

    def _refresh_frame_downloads_for_match(self, frame_path, attempt_logs=None):
        """Download and list HTML for all current frames, highlighting the matched frame."""
        downloads = self._download_frame_htmls(target_frame_path=frame_path)
        if downloads:
            self._append_attempt_log(attempt_logs, f"Downloaded HTML for {len(downloads)} frame location(s).")
        else:
            self._append_attempt_log(attempt_logs, "No frame HTML files were downloaded.")
        return downloads

    def _click_element_with_fallback(self, element, attempt_logs=None):
        """Click or select an element with dropdown-aware fallbacks."""
        try:
            target = element
            self.driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", target)
            self._open_dropdown_if_needed(target, attempt_logs)

            tag = (target.tag_name or '').lower()
            if tag == 'option':
                parent = target.find_element(By.XPATH, "./parent::*")
                if parent.tag_name.lower() == 'select':
                    option_text = (target.text or '').strip()
                    if option_text:
                        Select(parent).select_by_visible_text(option_text)
                        self._append_attempt_log(attempt_logs, f"Selected native option by visible text: {option_text}")
                        return True, "native select"
                    option_value = target.get_attribute('value')
                    if option_value:
                        Select(parent).select_by_value(option_value)
                        self._append_attempt_log(attempt_logs, f"Selected native option by value: {option_value}")
                        return True, "native select"

            try:
                WebDriverWait(self.driver, 3).until(lambda driver: target.is_enabled())
            except Exception:
                pass

            try:
                target.click()
                self._append_attempt_log(attempt_logs, "Clicked target directly.")
                return True, "direct click"
            except Exception as click_error:
                self._append_attempt_log(attempt_logs, f"Direct click failed: {str(click_error)}")

            try:
                ActionChains(self.driver).move_to_element(target).pause(0.2).click(target).perform()
                self._append_attempt_log(attempt_logs, "Clicked target using ActionChains.")
                return True, "action chains"
            except Exception as action_error:
                self._append_attempt_log(attempt_logs, f"ActionChains click failed: {str(action_error)}")

            self.driver.execute_script("arguments[0].click();", target)
            self._append_attempt_log(attempt_logs, "Clicked target using JavaScript fallback.")
            return True, "javascript click"
        except Exception as e:
            self._append_attempt_log(attempt_logs, f"Click flow failed: {str(e)}")
            return False, "failed"

    def _get_element_dom_context(self, element):
        """Collect DOM context for generating stable XPath candidates."""
        script = """
        const element = arguments[0];

        function firstUsefulText(node) {
            if (!node) return '';
            const text = (node.innerText || node.textContent || '').replace(/\\s+/g, ' ').trim();
            return text.slice(0, 80);
        }

        function stableClasses(node) {
            if (!node) return [];
            return (node.className || '')
                .split(/\\s+/)
                .map(token => token.trim())
                .filter(token => token && !(/[0-9]{3,}/.test(token) || (token.length > 10 && /[A-Za-z]/.test(token) && /\\d/.test(token))))
                .slice(0, 3);
        }

        function siblingInfo(node, direction) {
            let current = direction === 'prev' ? node.previousElementSibling : node.nextElementSibling;
            while (current) {
                const text = firstUsefulText(current);
                const classes = stableClasses(current);
                if (text || classes.length || current.id || current.getAttribute('name')) {
                    return {
                        tag: (current.tagName || '').toLowerCase(),
                        text: text,
                        classes: classes,
                        id: current.id || '',
                        name: current.getAttribute('name') || ''
                    };
                }
                current = direction === 'prev' ? current.previousElementSibling : current.nextElementSibling;
            }
            return null;
        }

        let ancestors = [];
        let parent = element.parentElement;
        while (parent && ancestors.length < 4) {
            const classes = stableClasses(parent);
            const text = firstUsefulText(parent);
            if (classes.length || parent.id || parent.getAttribute('name')) {
                ancestors.push({
                    tag: (parent.tagName || '').toLowerCase(),
                    classes: classes,
                    id: parent.id || '',
                    name: parent.getAttribute('name') || '',
                    text: text
                });
            }
            parent = parent.parentElement;
        }

        return {
            tag: (element.tagName || '').toLowerCase(),
            id: element.id || '',
            name: element.getAttribute('name') || '',
            type: element.getAttribute('type') || '',
            role: element.getAttribute('role') || '',
            text: firstUsefulText(element),
            classes: stableClasses(element),
            ancestors: ancestors,
            prevSibling: siblingInfo(element, 'prev'),
            nextSibling: siblingInfo(element, 'next'),
            ariaLabel: element.getAttribute('aria-label') || '',
            placeholder: element.getAttribute('placeholder') || ''
        };
        """
        return self.driver.execute_script(script, element)

    def _build_dynamic_xpath_candidates(self, context):
        """Generate stable XPath candidates using multiple anchoring techniques."""
        tag = context.get('tag') or '*'
        text = (context.get('text') or '').strip()
        name = (context.get('name') or '').strip()
        role = (context.get('role') or '').strip()
        elem_type = (context.get('type') or '').strip()
        aria_label = (context.get('ariaLabel') or '').strip()
        placeholder = (context.get('placeholder') or '').strip()
        elem_id = (context.get('id') or '').strip()
        target_classes = context.get('classes') or []
        ancestors = context.get('ancestors') or []
        prev_sibling = context.get('prevSibling')
        next_sibling = context.get('nextSibling')

        candidates = []

        if elem_id and not self._is_dynamic_token(elem_id):
            candidates.append(f"//{tag}[@id={self._escape_xpath_text(elem_id)}]")
        if name:
            candidates.append(f"//{tag}[@name={self._escape_xpath_text(name)}]")
        if aria_label:
            candidates.append(f"//{tag}[@aria-label={self._escape_xpath_text(aria_label)}]")
        if placeholder:
            candidates.append(f"//{tag}[@placeholder={self._escape_xpath_text(placeholder)}]")
        if role:
            candidates.append(f"//{tag}[@role={self._escape_xpath_text(role)}]")
        if elem_type:
            candidates.append(f"//{tag}[@type={self._escape_xpath_text(elem_type)}]")
        if role and text:
            candidates.append(
                f"//{tag}[@role={self._escape_xpath_text(role)} and contains(normalize-space(.),{self._escape_xpath_text(text[:40])})]"
            )
        if text:
            text_sample = text[:40]
            candidates.append(f"//{tag}[contains(normalize-space(.),{self._escape_xpath_text(text_sample)})]")
            candidates.append(
                f"//{tag}[contains(normalize-space(string(.)),{self._escape_xpath_text(text_sample)})]"
            )
        if target_classes:
            class_conditions = " and ".join(
                f"contains(concat(' ', normalize-space(@class), ' '), {self._escape_xpath_text(f' {class_token} ')})"
                for class_token in target_classes[:2]
            )
            candidates.append(f"//{tag}[{class_conditions}]")

        for ancestor in ancestors[:2]:
            ancestor_conditions = []
            if ancestor.get('id') and not self._is_dynamic_token(ancestor.get('id')):
                ancestor_conditions.append(f"@id={self._escape_xpath_text(ancestor['id'])}")
            for class_token in ancestor.get('classes', []):
                ancestor_conditions.append(
                    f"contains(concat(' ', normalize-space(@class), ' '), {self._escape_xpath_text(f' {class_token} ')})"
                )
            if ancestor.get('name'):
                ancestor_conditions.append(f"@name={self._escape_xpath_text(ancestor['name'])}")
            if ancestor.get('text'):
                ancestor_conditions.append(
                    f"contains(normalize-space(string(.)),{self._escape_xpath_text(ancestor['text'][:30])})"
                )
            if not ancestor_conditions:
                continue

            ancestor_xpath = f"//{ancestor.get('tag') or '*'}[" + " and ".join(ancestor_conditions[:3]) + "]"
            target_conditions = []
            if name:
                target_conditions.append(f"@name={self._escape_xpath_text(name)}")
            for class_token in target_classes:
                target_conditions.append(
                    f"contains(concat(' ', normalize-space(@class), ' '), {self._escape_xpath_text(f' {class_token} ')})"
                )
            if text:
                target_conditions.append(f"contains(normalize-space(.),{self._escape_xpath_text(text[:40])})")
            if aria_label:
                target_conditions.append(f"@aria-label={self._escape_xpath_text(aria_label)}")
            if role:
                target_conditions.append(f"@role={self._escape_xpath_text(role)}")

            if target_conditions:
                candidates.append(f"{ancestor_xpath}//{tag}[" + " and ".join(target_conditions[:3]) + "]")
                candidates.append(f"{ancestor_xpath}/descendant::{tag}[" + " and ".join(target_conditions[:3]) + "][1]")

            if prev_sibling:
                prev_conditions = []
                if prev_sibling.get('text'):
                    prev_conditions.append(
                        f"contains(normalize-space(.),{self._escape_xpath_text(prev_sibling['text'][:30])})"
                    )
                for class_token in prev_sibling.get('classes', []):
                    prev_conditions.append(f"contains(@class,{self._escape_xpath_text(class_token)})")
                if prev_sibling.get('name'):
                    prev_conditions.append(f"@name={self._escape_xpath_text(prev_sibling['name'])}")
                if prev_conditions:
                    candidates.append(
                        f"{ancestor_xpath}//{prev_sibling.get('tag') or '*'}[" + " and ".join(prev_conditions[:2]) +
                        f"]/following-sibling::{tag}[1]"
                    )
                    if target_conditions:
                        candidates.append(
                            f"{ancestor_xpath}//{prev_sibling.get('tag') or '*'}[" + " and ".join(prev_conditions[:2]) +
                            f"]/following-sibling::{tag}[" + " and ".join(target_conditions[:2]) + "][1]"
                        )

            if next_sibling:
                next_conditions = []
                if next_sibling.get('text'):
                    next_conditions.append(
                        f"contains(normalize-space(.),{self._escape_xpath_text(next_sibling['text'][:30])})"
                    )
                for class_token in next_sibling.get('classes', []):
                    next_conditions.append(f"contains(@class,{self._escape_xpath_text(class_token)})")
                if next_sibling.get('name'):
                    next_conditions.append(f"@name={self._escape_xpath_text(next_sibling['name'])}")
                if next_conditions:
                    candidates.append(
                        f"{ancestor_xpath}//{next_sibling.get('tag') or '*'}[" + " and ".join(next_conditions[:2]) +
                        f"]/preceding-sibling::{tag}[1]"
                    )
                    if target_conditions:
                        candidates.append(
                            f"{ancestor_xpath}//{next_sibling.get('tag') or '*'}[" + " and ".join(next_conditions[:2]) +
                            f"]/preceding-sibling::{tag}[" + " and ".join(target_conditions[:2]) + "][1]"
                        )

        deduped = []
        seen = set()
        for candidate in candidates:
            if candidate not in seen:
                deduped.append(candidate)
                seen.add(candidate)
        return deduped

    def _label_stable_xpath_candidate(self, candidate_xpath):
        """Return a readable label for a generated stable XPath candidate."""
        candidate_xpath = (candidate_xpath or '').strip()
        if "following-sibling::" in candidate_xpath:
            return "Stable XPath From Previous Sibling"
        if "preceding-sibling::" in candidate_xpath:
            return "Stable XPath From Next Sibling"
        return "Stable XPath"

    def _get_verified_stable_xpath_options(self, context, attempt_logs=None):
        """Build and validate stable XPath candidates from element context."""
        candidates = self._build_dynamic_xpath_candidates(context or {})
        verified_options = []
        seen = set()

        for index, candidate in enumerate(candidates, 1):
            self._append_attempt_log(attempt_logs, f"Trying stable XPath option {index}: {candidate}")
            candidate_element, candidate_xpath, candidate_frame = self.try_xpath_variants(candidate)
            if candidate_element:
                option_key = (candidate_xpath, tuple(candidate_frame or []))
                if option_key not in seen:
                    verified_options.append({
                        "type": self._label_stable_xpath_candidate(candidate_xpath),
                        "value": candidate_xpath,
                        "frame_path": candidate_frame or [],
                    })
                    seen.add(option_key)
                self._append_attempt_log(
                    attempt_logs,
                    f"SUCCESS with stable XPath option {index} in {self._format_frame_path(candidate_frame or [])}"
                )
            else:
                self._append_attempt_log(attempt_logs, f"Stable XPath option {index} did not match.")

        return verified_options

    def _build_element_anchor_conditions(self, context, limit=3):
        """Build stable element conditions for locator suggestions."""
        conditions = []
        elem_id = (context.get('id') or '').strip()
        elem_name = (context.get('name') or '').strip()
        elem_text = (context.get('text') or '').strip()

        if elem_id and not self._is_dynamic_token(elem_id):
            conditions.append(f"@id={self._escape_xpath_text(elem_id)}")
        if elem_name:
            conditions.append(f"@name={self._escape_xpath_text(elem_name)}")
        for class_token in context.get('classes', []) or []:
            conditions.append(f"contains(@class,{self._escape_xpath_text(class_token)})")
        if elem_text:
            conditions.append(f"contains(normalize-space(.),{self._escape_xpath_text(elem_text[:40])})")
        return conditions[:limit]

    def _build_parent_anchor_xpath(self, ancestor):
        """Build a parent XPath anchor from stable classes, id, or name."""
        if not ancestor:
            return None

        conditions = []
        ancestor_id = (ancestor.get('id') or '').strip()
        ancestor_name = (ancestor.get('name') or '').strip()
        for class_token in ancestor.get('classes', []) or []:
            conditions.append(f"contains(@class,{self._escape_xpath_text(class_token)})")
        if ancestor_id and not self._is_dynamic_token(ancestor_id):
            conditions.append(f"@id={self._escape_xpath_text(ancestor_id)}")
        if ancestor_name:
            conditions.append(f"@name={self._escape_xpath_text(ancestor_name)}")

        if not conditions:
            return None
        return f"//{ancestor.get('tag') or '*'}[" + " and ".join(conditions[:3]) + "]"

    def _build_locator_result_options(self, context):
        """Build locator result options around siblings and the first two parent levels."""
        if not context:
            return []

        tag = context.get('tag') or '*'
        ancestors = context.get('ancestors') or []
        target_conditions = self._build_element_anchor_conditions(context)
        target_xpath = f"//{tag}"
        if target_conditions:
            target_xpath += "[" + " and ".join(target_conditions) + "]"

        options = [f"Locator XPath: {target_xpath}"]
        seen = {options[0]}

        parent_one = ancestors[0] if len(ancestors) > 0 else None
        parent_two = ancestors[1] if len(ancestors) > 1 else None
        parent_one_anchor = self._build_parent_anchor_xpath(parent_one)
        parent_two_anchor = self._build_parent_anchor_xpath(parent_two)

        def add_option(label, xpath_value):
            if not xpath_value or xpath_value in seen:
                return
            options.append(f"{label}: {xpath_value}")
            seen.add(xpath_value)

        if parent_one_anchor:
            add_option("Upper Class Level 1", parent_one_anchor)
            if target_conditions:
                add_option(
                    "Locator Under Upper Class Level 1",
                    f"{parent_one_anchor}//{tag}[" + " and ".join(target_conditions) + "]"
                )
                add_option(
                    "Next Sibling Using Upper Class Level 1",
                    f"{parent_one_anchor}//{tag}[" + " and ".join(target_conditions) + "]/following-sibling::*[1]"
                )
                add_option(
                    "Previous Sibling Using Upper Class Level 1",
                    f"{parent_one_anchor}//{tag}[" + " and ".join(target_conditions) + "]/preceding-sibling::*[1]"
                )
        else:
            options.append("Upper Class Level 1: not found")

        if parent_two_anchor:
            add_option("Upper Class Level 2", parent_two_anchor)
            if target_conditions and not parent_one_anchor:
                add_option(
                    "Locator Under Upper Class Level 2",
                    f"{parent_two_anchor}//{tag}[" + " and ".join(target_conditions) + "]"
                )
                add_option(
                    "Next Sibling Using Upper Class Level 2",
                    f"{parent_two_anchor}//{tag}[" + " and ".join(target_conditions) + "]/following-sibling::*[1]"
                )
                add_option(
                    "Previous Sibling Using Upper Class Level 2",
                    f"{parent_two_anchor}//{tag}[" + " and ".join(target_conditions) + "]/preceding-sibling::*[1]"
                )
        elif len(ancestors) > 1:
            options.append("Upper Class Level 2: not found")

        if target_conditions:
            add_option("Next Sibling", f"{target_xpath}/following-sibling::*[1]")
            add_option("Previous Sibling", f"{target_xpath}/preceding-sibling::*[1]")

        return options

    def _render_attempt_results(self, heading, attempt_logs, extra_lines=None):
        """Render attempt logs and any follow-up information into the tester panel."""
        lines = [heading, ""]
        lines.extend(attempt_logs or ["No attempts were recorded."])
