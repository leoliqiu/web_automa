    def enable_relative_xpath_selection(self):
        """Enable selecting a dynamic target followed by a stable reference element."""
        if not self.ensure_driver():
            return

        js_code = """
        if (window.relativeXPathSelectionActive) {
            document.removeEventListener('mouseover', window.relativeHighlightElement, true);
            document.removeEventListener('click', window.captureRelativeElement, true);
        }

        window.relativeXPathSelectionActive = true;
        window.relativeSelectionStage = 'target';
        window.relativeSelectionData = null;
        window.relativeSelectedTarget = null;
        window.relativeSelectorState = window.relativeSelectorState || {
            highlightedElement: null,
            highlightedOriginalStyle: null
        };

        function cleanText(value) {
            return (value || '').replace(/\\s+/g, ' ').trim();
        }

        function stableClasses(node) {
            if (!node) return [];
            return (node.className || '')
                .split(/\\s+/)
                .map(token => token.trim())
                .filter(token => token && !(/[0-9]{3,}/.test(token) || (token.length > 10 && /[A-Za-z]/.test(token) && /\\d/.test(token))))
                .slice(0, 3);
        }

        function firstUsefulText(node) {
            if (!node) return '';
            return cleanText(node.innerText || node.textContent || '').slice(0, 80);
        }

        function siblingInfo(node, direction) {
            let current = direction === 'prev' ? node.previousElementSibling : node.nextElementSibling;
            while (current) {
                const text = firstUsefulText(current);
                const classes = stableClasses(current);
                if (text || classes.length || current.id || current.getAttribute('name')) {
                    return {
                        tag: (current.tagName || '').toLowerCase(),
                        text: text,
                        classes: classes,
                        id: current.id || '',
                        name: current.getAttribute('name') || ''
                    };
                }
                current = direction === 'prev' ? current.previousElementSibling : current.nextElementSibling;
            }
            return null;
        }

        function buildXPath(element) {
            if (!element) return null;
            if (element.id) return "//*[@id='" + element.id + "']";
            if (element === document.body) return "/html/body";

            let index = 0;
            const siblings = element.parentNode ? element.parentNode.childNodes : [];
            for (let i = 0; i < siblings.length; i += 1) {
                const sibling = siblings[i];
                if (sibling === element) {
                    return buildXPath(element.parentNode) + "/" + element.tagName.toLowerCase() + "[" + (index + 1) + "]";
                }
                if (sibling.nodeType === 1 && sibling.tagName === element.tagName) {
                    index += 1;
                }
            }
            return null;
        }

        function collectAncestors(node) {
            const ancestors = [];
            let parent = node.parentElement;
            while (parent && ancestors.length < 4) {
                const classes = stableClasses(parent);
                const text = firstUsefulText(parent);
                if (classes.length || parent.id || parent.getAttribute('name')) {
                    ancestors.push({
                        tag: (parent.tagName || '').toLowerCase(),
                        classes: classes,
                        id: parent.id || '',
                        name: parent.getAttribute('name') || '',
                        text: text
                    });
                }
                parent = parent.parentElement;
            }
            return ancestors;
        }

        function collectElementData(element) {
            return {
                tag: (element.tagName || '').toLowerCase(),
                id: element.id || '',
                class: element.getAttribute('class') || '',
                classes: stableClasses(element),
                name: element.getAttribute('name') || '',
                type: element.getAttribute('type') || '',
                role: element.getAttribute('role') || '',
                value: element.getAttribute('value') || '',
                text: firstUsefulText(element),
                href: element.getAttribute('href') || '',
                title: element.getAttribute('title') || '',
                ariaLabel: element.getAttribute('aria-label') || '',
                placeholder: element.getAttribute('placeholder') || '',
                xpath: buildXPath(element),
                ancestors: collectAncestors(element),
                prevSibling: siblingInfo(element, 'prev'),
                nextSibling: siblingInfo(element, 'next')
            };
        }

        function indexWithinTag(node) {
            let index = 1;
            let sibling = node.previousElementSibling;
            while (sibling) {
                if ((sibling.tagName || '').toLowerCase() === (node.tagName || '').toLowerCase()) {
                    index += 1;
                }
                sibling = sibling.previousElementSibling;
            }
            return index;
        }

        function buildPathToAncestor(node, ancestor) {
            const path = [];
            let current = node;
            while (current && current !== ancestor) {
                path.unshift({
                    tag: (current.tagName || '').toLowerCase(),
                    index: indexWithinTag(current)
                });
                current = current.parentElement;
            }
            return path;
        }

        function findCommonAncestor(first, second) {
            let current = first;
            while (current) {
                if (current.contains(second)) {
                    return current;
                }
                current = current.parentElement;
            }
            return document.body;
        }

        function collectRelationship(anchor, target) {
            const commonAncestor = findCommonAncestor(anchor, target);
            const anchorPath = buildPathToAncestor(anchor, commonAncestor);
            const targetPath = buildPathToAncestor(target, commonAncestor);
            const relationship = {
                common_tag: (commonAncestor.tagName || '').toLowerCase(),
                common_id: commonAncestor.id || '',
                common_name: commonAncestor.getAttribute('name') || '',
                common_text: firstUsefulText(commonAncestor),
                common_classes: stableClasses(commonAncestor),
                anchor_up: anchorPath.length,
                target_path: targetPath.map(part => `${part.tag}[${part.index}]`).join('/'),
                same_parent: !!anchor.parentElement && anchor.parentElement === target.parentElement,
                direction: null,
                any_offset: null,
                same_tag_offset: null
            };

            if (relationship.same_parent) {
                const direction = anchor.compareDocumentPosition(target) & Node.DOCUMENT_POSITION_FOLLOWING ? 'following' : 'preceding';
                relationship.direction = direction;

                let anyOffset = 0;
                let current = direction === 'following' ? anchor.nextElementSibling : anchor.previousElementSibling;
                while (current) {
                    anyOffset += 1;
                    if (current === target) break;
                    current = direction === 'following' ? current.nextElementSibling : current.previousElementSibling;
                }
                relationship.any_offset = anyOffset || null;

                let sameTagOffset = 0;
                current = direction === 'following' ? anchor.nextElementSibling : anchor.previousElementSibling;
                while (current) {
                    if ((current.tagName || '').toLowerCase() === (target.tagName || '').toLowerCase()) {
                        sameTagOffset += 1;
                    }
                    if (current === target) break;
                    current = direction === 'following' ? current.nextElementSibling : current.previousElementSibling;
                }
                relationship.same_tag_offset = sameTagOffset || null;
            }

            return relationship;
        }

        window.clearRelativeXPathHighlight = function() {
            const state = window.relativeSelectorState;
            if (state.highlightedElement && state.highlightedOriginalStyle) {
                state.highlightedElement.style.outline = state.highlightedOriginalStyle.outline;
                state.highlightedElement.style.outlineOffset = state.highlightedOriginalStyle.outlineOffset;
                state.highlightedElement.style.backgroundColor = state.highlightedOriginalStyle.backgroundColor;
            }
            state.highlightedElement = null;
            state.highlightedOriginalStyle = null;
        };
        window.clearRelativeXPathHighlight();

        window.relativeHighlightElement = function(e) {
            e.preventDefault();
            e.stopPropagation();
            window.clearRelativeXPathHighlight();

            const target = e.target;
            if (target !== document && target !== document.body && target !== document.documentElement) {
                window.relativeSelectorState.highlightedOriginalStyle = {
                    outline: target.style.outline,
                    outlineOffset: target.style.outlineOffset,
                    backgroundColor: target.style.backgroundColor
                };
                const isTargetStage = window.relativeSelectionStage === 'target';
                target.style.outline = isTargetStage ? '3px solid #dc2626' : '3px solid #16a34a';
                target.style.outlineOffset = '2px';
                target.style.backgroundColor = isTargetStage ? 'rgba(220, 38, 38, 0.12)' : 'rgba(22, 163, 74, 0.12)';
                window.relativeSelectorState.highlightedElement = target;
            }
        };

        window.captureRelativeElement = function(e) {
            e.preventDefault();
            e.stopPropagation();

            const element = e.target;
            if (element === document || element === document.body || element === document.documentElement) {
                return;
            }

            if (window.relativeSelectionStage === 'target') {
                window.relativeSelectedTarget = element;
                window.relativeSelectionData = {
                    stage: 'target_selected',
                    target: collectElementData(element)
                };
                window.relativeSelectionStage = 'anchor';
                return;
            }

            if (window.relativeSelectionStage === 'anchor') {
                window.relativeSelectionData = {
                    stage: 'complete',
                    target: collectElementData(window.relativeSelectedTarget),
                    anchor: collectElementData(element),
                    relationship: collectRelationship(element, window.relativeSelectedTarget)
                };
                document.removeEventListener('mouseover', window.relativeHighlightElement, true);
                document.removeEventListener('click', window.captureRelativeElement, true);
                window.relativeXPathSelectionActive = false;
                window.clearRelativeXPathHighlight();
            }
        };

        document.addEventListener('mouseover', window.relativeHighlightElement, true);
       document.addEventListener('click', window.captureRelativeElement, true);
        """
        self._begin_selection_mode(
            "relative",
            js_code,
            [
                "\nRELATIVE XPATH SELECTOR ACTIVATED",
                "=" * 100,
                "Step 1: Click the dynamic target element.",
                "Step 2: Click the stable reference element.",
                "Relative XPath options will be generated from the second element back to the first.",
                "=" * 100 + "\n",
            ],
            "Relative XPath selector ready in {injected_count} document context(s).",
            tester_message=(
                "Relative XPath selection started.\n\n"
                "1. Click the dynamic target element.\n"
                "2. Click the stable reference element.\n"
                "Relative XPath options will appear in Output."
            ),
        )

    def _start_element_selection_polling(self):
        """Poll the browser for the active selector mode."""
        if self.selection_poll_timer is None:
            self.selection_poll_timer = QTimer(self)
            self.selection_poll_timer.timeout.connect(self._poll_selection_data)
        self.selection_poll_timer.start(250)

    def _poll_selection_data(self):
        """Dispatch polling based on the current selection mode."""
        if self.selection_mode == "relative":
            self._poll_relative_selection_data()
            return
        self._poll_selected_element_data()

    def _poll_selected_element_data(self):
        """Capture the first selected element without requiring a confirmation dialog."""
        if not self.driver:
            if self.selection_poll_timer:
                self.selection_poll_timer.stop()
            return

        try:
            element_data = None
            selected_frame_path = []
            try:
                frame_paths = self._collect_frame_paths()
            except Exception:
                frame_paths = [[]]

            for frame_path in frame_paths:
                try:
                    self._switch_to_frame_path(frame_path)
                    frame_element_data = self.driver.execute_script("return window.selectedElementData || null;")
                    if frame_element_data:
                        element_data = frame_element_data
                        selected_frame_path = list(frame_path)
                        break
                except Exception:
                    continue
                finally:
                    self.driver.switch_to.default_content()

            if not element_data:
                return

            if self.selection_poll_timer:
                self.selection_poll_timer.stop()
            self._apply_selected_element_data(element_data, selected_frame_path)
        except Exception as e:
            if self.selection_poll_timer:
                self.selection_poll_timer.stop()
            self.output.append(f"Failed to capture selected element: {str(e)}")
            self.cleanup_element_selector()

    def _poll_relative_selection_data(self):
        """Capture the second-stage anchor and build relative XPath candidates."""
        if not self.driver:
            if self.selection_poll_timer:
                self.selection_poll_timer.stop()
            return

        try:
            relative_data = None
            selected_frame_path = []
            try:
                frame_paths = self._collect_frame_paths()
            except Exception:
                frame_paths = [[]]

            for frame_path in frame_paths:
                try:
                    self._switch_to_frame_path(frame_path)
                    frame_relative_data = self.driver.execute_script("return window.relativeSelectionData || null;")
                    if not frame_relative_data:
                        continue
                    if frame_relative_data.get("stage") == "target_selected" and self.relative_selection_progress != "target_selected":
                        self.relative_selection_progress = "target_selected"
                        self.test_result_display.setText(
                            "Dynamic target captured.\n\n"
                            "Now click the stable reference element to generate relative XPath options."
                        )
                    if frame_relative_data.get("stage") == "complete":
                        relative_data = frame_relative_data
                        selected_frame_path = list(frame_path)
                        break
                except Exception:
                    continue
                finally:
                    self.driver.switch_to.default_content()

            if not relative_data:
                return

            if self.selection_poll_timer:
                self.selection_poll_timer.stop()
            self._apply_relative_selection_data(relative_data, selected_frame_path)
        except Exception as e:
            if self.selection_poll_timer:
                self.selection_poll_timer.stop()
            self.test_result_display.setText(f"Failed to capture relative selection: {str(e)}")
            self.cleanup_element_selector()

    def _apply_selected_element_data(self, element_data, selected_frame_path):
        """Render the clicked element details and push the primary XPath into the tester."""
        frame_label = self._format_frame_path(selected_frame_path)
        self.bg_color_toggle = not self.bg_color_toggle
        bg_marker = "[A]" if self.bg_color_toggle else "[B]"

        self.output.append(f"\n{bg_marker} " + "=" * 98)
        self.output.append("ELEMENT SELECTED")
        self.output.append("=" * 100)

        self.output.append("\nELEMENT INFO:")
        self.output.append(f"  Tag: <{element_data['tag']}>")
        if element_data['id']:
            self.output.append(f"  ID: {element_data['id']}")
        if element_data['class']:
            self.output.append(f"  Class: {element_data['class']}")
        if element_data['name']:
            self.output.append(f"  Name: {element_data['name']}")
        if element_data['type']:
            self.output.append(f"  Type: {element_data['type']}")
        if element_data.get('value'):
            self.output.append(f"  Value: {element_data['value']}")
        if element_data['text']:
            self.output.append(f"  Text: {element_data['text'][:60]}")
        if element_data['href']:
            self.output.append(f"  Href: {element_data['href']}")
        if element_data.get('title'):
            self.output.append(f"  Title: {element_data['title']}")
        self.output.append(f"  Frame: {frame_label}")

        self.output.append("\nLOCATOR OPTIONS:")
        self._append_locator_rows_table(self._build_selected_element_locator_rows(element_data, frame_label=frame_label))

        if element_data.get('xpath'):
            self.test_locator_input.setText(element_data['xpath'])
            self.locator_type_combo.setCurrentText("XPath")
            self.test_result_display.setText(
                f"Selected element loaded into Locator Tester.\n\nXPath: {element_data['xpath']}\nFrame: {frame_label}"
            )
            if hasattr(self, 'workspace_tabs') and hasattr(self, 'tester_tab_index'):
                self.workspace_tabs.setCurrentIndex(self.tester_tab_index)

        self.output.append("=" * 100)
        self.output.append("Element was captured directly and loaded into the Locator Tester")
        self.cleanup_element_selector()

    def _collect_xpath_locator_values(self, element_data, context=None, frame_label='-'):
        """Return XPath-only locator candidates for a selected anchor element."""
        rows = []
        seen = set()

        for row in self._build_selected_element_locator_rows(element_data or {}, frame_label=frame_label):
            locator_type = row.get("type") or ""
            locator_value = row.get("value") or ""
            if locator_value.startswith("//") or locator_value.startswith("("):
                self._add_locator_row(rows, seen, locator_type, locator_value, row.get("frame"))

        for option in self._get_verified_stable_xpath_options(context or {}):
            option_frame_label = self._format_frame_path(option.get("frame_path") or [])
            self._add_locator_row(rows, seen, option.get("type"), option.get("value"), option_frame_label)

        return rows

    def _build_target_match_conditions(self, target_data, limit=3):
        """Build a small set of target-side predicates for relative XPath generation."""
        conditions = []
        target_name = (target_data.get("name") or "").strip()
        target_type = (target_data.get("type") or "").strip()
        target_role = (target_data.get("role") or "").strip()
        target_aria = (target_data.get("ariaLabel") or "").strip()
        target_placeholder = (target_data.get("placeholder") or "").strip()
        target_text = (target_data.get("text") or "").strip()

        if target_name:
            conditions.append(f"@name={self._escape_xpath_text(target_name)}")
        if target_type:
            conditions.append(f"@type={self._escape_xpath_text(target_type)}")
        if target_role:
            conditions.append(f"@role={self._escape_xpath_text(target_role)}")
        if target_aria:
            conditions.append(f"@aria-label={self._escape_xpath_text(target_aria)}")
        if target_placeholder:
            conditions.append(f"@placeholder={self._escape_xpath_text(target_placeholder)}")
        if target_text:
            conditions.append(f"contains(normalize-space(.),{self._escape_xpath_text(target_text[:30])})")

        return conditions[:limit]

    def _build_relative_xpath_candidates(self, anchor_data, target_data, relationship, anchor_context=None):
        """Build relative XPath candidates from a stable anchor back to the target element."""
        relationship = relationship or {}
        target_tag = (target_data.get("tag") or "*").lower()
        target_conditions = self._build_target_match_conditions(target_data)
        candidates = []
        seen = set()

        def add_candidate(label, xpath_value):
            xpath_value = (xpath_value or "").strip()
            if not xpath_value or xpath_value in seen:
                return
            candidates.append({"type": label, "value": xpath_value})
            seen.add(xpath_value)

        anchor_xpath_rows = self._collect_xpath_locator_values(anchor_data, context=anchor_context)
        target_filter = "[" + " and ".join(target_conditions) + "]" if target_conditions else ""

        for row in anchor_xpath_rows[:10]:
            anchor_xpath = row.get("value")
            same_parent = relationship.get("same_parent")
            direction = relationship.get("direction")
            any_offset = relationship.get("any_offset")
            same_tag_offset = relationship.get("same_tag_offset")
            anchor_up = relationship.get("anchor_up") or 0
            target_path = relationship.get("target_path") or ""

            if same_parent and direction == "following":
                if any_offset:
                    add_candidate("Relative Following Sibling", f"{anchor_xpath}/following-sibling::*[{any_offset}]")
                if same_tag_offset:
                    add_candidate("Relative Following Tag Sibling", f"{anchor_xpath}/following-sibling::{target_tag}[{same_tag_offset}]")
            elif same_parent and direction == "preceding":
                if any_offset:
                    add_candidate("Relative Previous Sibling", f"{anchor_xpath}/preceding-sibling::*[{any_offset}]")
                if same_tag_offset:
                    add_candidate("Relative Previous Tag Sibling", f"{anchor_xpath}/preceding-sibling::{target_tag}[{same_tag_offset}]")

            if target_path:
                ancestor_prefix = anchor_xpath if anchor_up == 0 else f"{anchor_xpath}/ancestor::*[{anchor_up}]"
                add_candidate("Relative Common Ancestor Path", f"{ancestor_prefix}/{target_path}")
                if target_conditions:
                    add_candidate("Relative Ancestor Descendant", f"{ancestor_prefix}//{target_tag}{target_filter}[1]")

        if getattr(self, "archer_mode_btn", None) and self.archer_mode_btn.isChecked():
            for label, xpath_value in build_archer_relative_xpath_rules(anchor_data, target_data, relationship, self._escape_xpath_text):
                add_candidate(label, xpath_value)

        return candidates

    def _verify_relative_xpath_candidates(self, candidates, target_xpath, frame_path, attempt_logs=None):
        """Keep only relative XPath candidates that resolve to the selected target element."""
        verified_candidates = []
        for index, candidate in enumerate(candidates, 1):
            xpath_value = candidate.get("value") or ""
            self._append_attempt_log(attempt_logs, f"Trying relative XPath option {index}: {xpath_value}")
            try:
                def compare_elements():
                    target_element = self._locate_element_in_frame(By.XPATH, target_xpath, frame_path, timeout=4)
                    candidate_element = self._locate_element_in_frame(By.XPATH, xpath_value, frame_path, timeout=4)
                    return candidate_element == target_element

                matched = compare_elements()
            except Exception:
                matched = False
            finally:
                self.driver.switch_to.default_content()

            if matched:
                verified_candidates.append(candidate)
                self._append_attempt_log(attempt_logs, f"SUCCESS with relative XPath option {index}")
            else:
                self._append_attempt_log(attempt_logs, f"Relative XPath option {index} did not resolve to the selected target.")

        return verified_candidates

    def _apply_relative_selection_data(self, relative_data, selected_frame_path):
        """Render relative XPath options built from the chosen anchor and target elements."""
        anchor_data = relative_data.get("anchor") or {}
        target_data = relative_data.get("target") or {}
        relationship = relative_data.get("relationship") or {}
        frame_label = self._format_frame_path(selected_frame_path or [])

        if not anchor_data.get("xpath") or not target_data.get("xpath"):
            self.test_result_display.setText("Relative XPath selection did not capture enough element data.")
            self.cleanup_element_selector()
            return

        anchor_context = {
            "tag": anchor_data.get("tag") or "",
            "id": anchor_data.get("id") or "",
            "name": anchor_data.get("name") or "",
            "type": anchor_data.get("type") or "",
            "role": anchor_data.get("role") or "",
            "text": anchor_data.get("text") or "",
            "classes": anchor_data.get("classes") or [],
            "ancestors": anchor_data.get("ancestors") or [],
            "prevSibling": anchor_data.get("prevSibling"),
            "nextSibling": anchor_data.get("nextSibling"),
            "ariaLabel": anchor_data.get("ariaLabel") or "",
            "placeholder": anchor_data.get("placeholder") or "",
        }

        attempt_logs = []
        self._append_attempt_log(attempt_logs, "Captured dynamic target and stable reference element.")
        if getattr(self, "archer_mode_btn", None) and self.archer_mode_btn.isChecked():
            self._append_attempt_log(attempt_logs, "Archer Mode is ON. Archer-specific relative rules were included.")

        candidate_rows = self._build_relative_xpath_candidates(anchor_data, target_data, relationship, anchor_context=anchor_context)
        verified_rows = self._verify_relative_xpath_candidates(candidate_rows, target_data["xpath"], selected_frame_path, attempt_logs=attempt_logs)

        info_lines = [
            "SUCCESS - Relative XPath selection completed.",
            f"Target Tag: <{target_data.get('tag', '')}>",
            f"Reference Tag: <{anchor_data.get('tag', '')}>",
            f"Frame: {frame_label}",
        ]
        if target_data.get("text"):
            info_lines.append(f"Target Text: {target_data['text'][:60]}")
        if anchor_data.get("text"):
            info_lines.append(f"Reference Text: {anchor_data['text'][:60]}")
        info_lines.append(f"Verified Relative XPath Count: {len(verified_rows)}")

        verified_locator_rows = []
        verified_seen = set()
        for row in verified_rows:
            self._add_locator_row(verified_locator_rows, verified_seen, row.get("type"), row.get("value"), frame_label)

        candidate_locator_rows = []
        candidate_seen = set()
        for row in candidate_rows:
            self._add_locator_row(candidate_locator_rows, candidate_seen, row.get("type"), row.get("value"), frame_label)

        primary_rows = verified_locator_rows or candidate_locator_rows
        if primary_rows:
            self.test_locator_input.setText(primary_rows[0]["value"])
            self.locator_type_combo.setCurrentText("XPath")

        self._render_output_locator_sections_html(
            "Relative XPath builder",
            attempt_logs,
            info_lines,
            [
                {"title": "Verified Relative XPath", "rows": verified_locator_rows},
                {"title": "Candidate Relative XPath", "rows": candidate_locator_rows},
            ],
        )
        self.cleanup_element_selector()

    def show_element_selector_dialog(self):
