from __future__ import annotations

import argparse
import importlib.util
import json
import os
import sys
from pathlib import Path
from types import ModuleType
from typing import Any, Callable
from urllib.parse import urlsplit

from playwright.sync_api import Page, expect, sync_playwright

from playwright_app import DEFAULT_CHROME_PATH, OUTPUT_DIR

try:
    import tkinter as tk
    from tkinter import filedialog
except Exception:
    tk = None
    filedialog = None


def _load_export_module(export_path: Path) -> ModuleType:
    spec = importlib.util.spec_from_file_location("playwright_recording_export", export_path)
    if spec is None or spec.loader is None:
        raise RuntimeError(f"Unable to load Playwright export from {export_path}")

    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


def _load_replay_function(export_path: Path) -> Callable[[Page], None]:
    module = _load_export_module(export_path)
    replay = getattr(module, "replay_recording", None)
    if not callable(replay):
        raise AttributeError(f"{export_path} does not define replay_recording(page)")
    return replay


def _load_json_payload(json_path: Path) -> dict[str, Any]:
    payload = json.loads(json_path.read_text(encoding="utf-8"))
    if not isinstance(payload, dict):
        raise TypeError(f"{json_path} does not contain a JSON object")
    steps = payload.get("steps")
    if not isinstance(steps, list):
        raise TypeError(f"{json_path} does not contain a steps list")
    return payload


def _unique_nonempty(values: list[str]) -> list[str]:
    result: list[str] = []
    seen: set[str] = set()
    for value in values:
        normalized = (value or "").strip()
        if not normalized or normalized in seen:
            continue
        seen.add(normalized)
        result.append(normalized)
    return result


def _print_console(message: str) -> None:
    encoding = sys.stdout.encoding or "utf-8"
    safe_message = message.encode(encoding, errors="replace").decode(encoding, errors="replace")
    print(safe_message)


def _step_value(step: dict[str, Any], snake_key: str, camel_key: str | None = None) -> Any:
    if snake_key in step:
        return step[snake_key]
    if camel_key is not None and camel_key in step:
        return step[camel_key]
    return None


def _playwright_locators_from_suggestions(step: dict[str, Any]) -> list[str]:
    locators: list[str] = []
    primary = _step_value(step, "primary_playwright_locator", "primaryPlaywrightLocator")
    if isinstance(primary, str) and primary.strip():
        locators.append(primary)

    raw_locators = _step_value(step, "playwright_locators", "playwrightLocators")
    if isinstance(raw_locators, list):
        locators.extend(value for value in raw_locators if isinstance(value, str))

    suggestions = _step_value(step, "locator_suggestions", "locatorSuggestions")
    if isinstance(suggestions, list):
        for suggestion in suggestions:
            if not isinstance(suggestion, str) or not suggestion.startswith("Playwright "):
                continue
            _prefix, separator, expression = suggestion.partition(": ")
            if separator and expression:
                locators.append(expression)

    return _unique_nonempty(locators)


def _derived_playwright_locators(step: dict[str, Any]) -> list[str]:
    tag_name = str(_step_value(step, "tag_name", "tagName") or "")
    input_type = str(_step_value(step, "input_type", "inputType") or "").lower()
    label = str(_step_value(step, "label", "label") or "")
    title = str(_step_value(step, "title", "title") or "")
    href = str(_step_value(step, "href", "href") or "")
    selector = str(_step_value(step, "selector", "selector") or "")
    xpath = str(_step_value(step, "xpath", "xpath") or "")

    locators = _playwright_locators_from_suggestions(step)
    if tag_name == "a" and label:
        locators.append(f"page.get_by_role('link', name={label!r}, exact=True)")
        locators.append(f"page.get_by_role('link', name={label!r})")
    if tag_name == "button" and label:
        locators.append(f"page.get_by_role('button', name={label!r}, exact=True)")
        locators.append(f"page.get_by_role('button', name={label!r})")
    if input_type in {"checkbox", "radio"} and label:
        locators.append(f"page.get_by_label({label!r})")
    if tag_name in {"input", "textarea", "select"} and label:
        locators.append(f"page.get_by_label({label!r})")
    if title:
        locators.append(f"page.get_by_title({title!r})")
    if href and tag_name:
        locators.append(f"page.locator({f'{tag_name}[href={href!r}]'!r})")
        if label:
            locators.append(
                f"page.locator({f'{tag_name}[href={href!r}]'!r}).filter(has_text={label!r})"
            )
        href_parts = urlsplit(href)
        relative_href = href_parts.path
        if href_parts.query:
            relative_href += f"?{href_parts.query}"
        if href_parts.fragment:
            relative_href += f"#{href_parts.fragment}"
        if relative_href and relative_href != href:
            locators.append(f"page.locator({f'{tag_name}[href={relative_href!r}]'!r})")
            locators.append(f"page.locator({f'{tag_name}[href$={relative_href!r}]'!r})")
            if label:
                locators.append(
                    f"page.locator({f'{tag_name}[href={relative_href!r}]'!r}).filter(has_text={label!r})"
                )
                locators.append(
                    f"page.locator({f'{tag_name}[href$={relative_href!r}]'!r}).filter(has_text={label!r})"
                )
    if label and tag_name not in {"input", "textarea", "select"}:
        locators.append(f"page.get_by_text({label!r})")
    if selector and label:
        locators.append(f"page.locator({selector!r}).filter(has_text={label!r})")
    if selector:
        locators.append(f"page.locator({selector!r})")
    if xpath:
        locators.append(f"page.locator({('xpath=' + xpath)!r})")
    return _unique_nonempty(locators)


def _evaluate_locator(page: Page, expression: str):
    return eval(expression, {"__builtins__": {}}, {"page": page})


def _resolve_locator(page: Page, step: dict[str, Any]) -> tuple[Any, str]:
    candidates = _derived_playwright_locators(step)
    failures: list[str] = []

    for expression in candidates:
        try:
            locator = _evaluate_locator(page, expression)
            count = locator.count()
        except Exception as error:
            failures.append(f"{expression} -> {error}")
            continue

        if count == 1:
            return locator, expression
        failures.append(f"{expression} -> matched {count} elements")

    step_number = _step_value(step, "step", "step")
    raise RuntimeError(
        f"Unable to find a unique locator for step {step_number}. Tried: "
        + " | ".join(failures or ["no locator candidates"])
    )


def _replayable_steps(payload: dict[str, Any]) -> list[dict[str, Any]]:
    raw_steps = payload.get("steps", [])
    control_types = {"shortcut_exit", "selector_mode", "freeze_mode"}
    return [
        step for step in raw_steps
        if isinstance(step, dict) and str(_step_value(step, "type", "type") or "") not in control_types
    ]


def _next_navigation_url(step: dict[str, Any], next_step: dict[str, Any] | None) -> str | None:
    step_type = str(_step_value(step, "type", "type") or "")
    if step_type not in {"click", "checkbox", "radio", "select"}:
        return None
    if next_step is None:
        return None

    current_url = str(_step_value(step, "page_url", "pageUrl") or "")
    next_url = str(_step_value(next_step, "page_url", "pageUrl") or "")
    if not next_url or next_url == current_url:
        return None
    return next_url


def _describe_step(step: dict[str, Any]) -> str:
    target = (
        str(_step_value(step, "label", "label") or "")
        or str(_step_value(step, "selector", "selector") or "")
        or str(_step_value(step, "href", "href") or "")
        or str(_step_value(step, "tag_name", "tagName") or "")
        or "element"
    )
    step_type = str(_step_value(step, "type", "type") or "")
    page_url = str(_step_value(step, "page_url", "pageUrl") or "")

    if step_type == "click":
        return f"Click {target} on {page_url}"
    if step_type == "input":
        return f'Enter "{_step_value(step, "value", "value") or ""}" into {target} on {page_url}'
    if step_type == "select":
        chosen = _step_value(step, "option_text", "optionText") or _step_value(step, "value", "value") or ""
        return f'Select "{chosen}" from {target} on {page_url}'
    if step_type == "checkbox":
        action = "Check" if bool(_step_value(step, "checked", "checked")) else "Uncheck"
        return f"{action} {target} on {page_url}"
    if step_type == "radio":
        return f"Choose {target} on {page_url}"
    if step_type == "keydown":
        return f"Press {_step_value(step, 'key', 'key') or ''} on {target} on {page_url}"
    if step_type == "element_capture":
        return f"Capture {target} on {page_url}"
    return f"{step_type} {target} on {page_url}"


def _is_visibility_failure(error: Exception) -> bool:
    text = str(error).lower()
    return "not visible" in text or "timeout" in text or "waiting for element to be visible" in text


def _click_with_fallback(
    page: Page,
    locator: Any,
    navigation_url: str | None,
    href: str | None = None,
) -> str | None:
    if navigation_url:
        try:
            with page.expect_navigation(wait_until="domcontentloaded"):
                locator.click(timeout=5000)
            expect(page).to_have_url(navigation_url)
            return navigation_url
        except Exception as error:
            if not _is_visibility_failure(error):
                raise
            try:
                with page.expect_navigation(wait_until="domcontentloaded"):
                    locator.click(timeout=5000, force=True)
                expect(page).to_have_url(navigation_url)
                return navigation_url
            except Exception:
                if href:
                    page.goto(href, wait_until="domcontentloaded")
                    expect(page).to_have_url(navigation_url)
                    return navigation_url
                raise

    try:
        locator.click(timeout=5000)
        return None
    except Exception as error:
        if not _is_visibility_failure(error):
            raise
        try:
            locator.click(timeout=5000, force=True)
            return None
        except Exception:
            if href:
                page.goto(href, wait_until="domcontentloaded")
                return href
            raise


def _run_step(page: Page, step: dict[str, Any], next_step: dict[str, Any] | None) -> str | None:
    step_type = str(_step_value(step, "type", "type") or "")
    navigation_url = _next_navigation_url(step, next_step)

    if step_type == "keydown":
        key = str(_step_value(step, "key", "key") or "")
        if key:
            page.keyboard.press(key)
        return None

    locator, locator_expression = _resolve_locator(page, step)
    _print_console(f"Replay step {_step_value(step, 'step', 'step')}: {_describe_step(step)}")
    _print_console(f"  locator: {locator_expression}")

    if step_type == "click":
        href = str(_step_value(step, "href", "href") or "")
        return _click_with_fallback(page, locator, navigation_url, href=href or None)

    if step_type == "input":
        value = str(_step_value(step, "value", "value") or "")
        locator.fill(value)
        return None

    if step_type == "select":
        value = str(_step_value(step, "value", "value") or "")
        if value:
            locator.select_option(value)
        return None

    if step_type == "checkbox":
        locator.set_checked(bool(_step_value(step, "checked", "checked")))
        return None

    if step_type == "radio":
        locator.check()
        return None

    if step_type == "element_capture":
        expect(locator).to_be_visible()
        label = str(_step_value(step, "label", "label") or "")
        if label and str(_step_value(step, "tag_name", "tagName") or "") not in {"input", "textarea", "select"}:
            expect(locator).to_contain_text(label)
        return None

    return None


def _build_json_replay_function(json_path: Path) -> Callable[[Page], None]:
    payload = _load_json_payload(json_path)

    def replay_recording(page: Page) -> None:
        steps = _replayable_steps(payload)
        if not steps:
            return

        current_url = ""
        first_url = str(_step_value(steps[0], "page_url", "pageUrl") or "")
        if first_url:
            page.goto(first_url, wait_until="domcontentloaded")
            expect(page).to_have_url(first_url)
            current_url = first_url

        for index, step in enumerate(steps):
            page_url = str(_step_value(step, "page_url", "pageUrl") or "")
            if page_url and page_url != current_url:
                page.goto(page_url, wait_until="domcontentloaded")
                expect(page).to_have_url(page_url)
                current_url = page_url

            next_step = steps[index + 1] if index + 1 < len(steps) else None
            resulting_url = _run_step(page, step, next_step)
            if resulting_url:
                current_url = resulting_url

    return replay_recording


def _candidate_json_paths(input_path: Path) -> list[Path]:
    candidates: list[Path] = []
    if input_path.suffix.lower() == ".json":
        candidates.append(input_path)
    else:
        name = input_path.name
        if name.endswith(".playwright.py"):
            base = name[: -len(".playwright.py")]
            candidates.append(input_path.with_name(f"{base}.json"))
        candidates.extend(
            [
                input_path.with_name("recording.json"),
            ]
        )

    result: list[Path] = []
    seen: set[Path] = set()
    for candidate in candidates:
        resolved = candidate.resolve()
        if resolved in seen or not resolved.exists():
            continue
        seen.add(resolved)
        result.append(resolved)
    return result


def _choose_input_file() -> Path | None:
    if tk is None or filedialog is None:
        return None

    root = tk.Tk()
    root.withdraw()
    root.attributes("-topmost", True)
    try:
        selected = filedialog.askopenfilename(
            title="Select a Playwright export or recording JSON",
            initialdir=str(OUTPUT_DIR),
            filetypes=[
                ("Recording files", "*.json *.py"),
                ("JSON recordings", "*.json"),
                ("Python exports", "*.py"),
                ("All files", "*.*"),
            ],
        )
    finally:
        root.destroy()

    if not selected:
        return None
    return Path(selected).resolve()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Replay a Playwright recording and save a Playwright trace zip."
    )
    parser.add_argument(
        "--input-path",
        default=None,
        help="Path to a generated Playwright export or recording JSON file. If omitted, a file picker opens.",
    )
    parser.add_argument(
        "--trace-path",
        default=str(OUTPUT_DIR / "recording.trace.zip"),
        help="Path for the saved Playwright trace zip.",
    )
    parser.add_argument(
        "--chrome-path",
        default=os.environ.get("CHROME_PATH", str(DEFAULT_CHROME_PATH)),
        help="Path to the locally installed Chrome executable.",
    )
    parser.add_argument(
        "--headless",
        action="store_true",
        help="Run the replay headlessly instead of opening Chrome.",
    )
    parser.add_argument(
        "--prefer-export",
        action="store_true",
        help="If a Python export is selected, run that export directly instead of preferring a sibling JSON recording.",
    )
    return parser.parse_args()


def _resolve_input_path(input_path_arg: str | None) -> Path:
    if input_path_arg:
        return Path(input_path_arg).resolve()

    selected = _choose_input_file()
    if selected is None:
        raise FileNotFoundError("No input file selected.")
    return selected


def _build_replay_plan(input_path: Path, prefer_export: bool) -> tuple[Callable[[Page], None], Path, str]:
    if input_path.suffix.lower() == ".json":
        return _build_json_replay_function(input_path), input_path, "json"

    if not prefer_export:
        for candidate in _candidate_json_paths(input_path):
            return _build_json_replay_function(candidate), candidate, "json"

    return _load_replay_function(input_path), input_path, "export"


def main() -> None:
    args = parse_args()
    input_path = _resolve_input_path(args.input_path)
    trace_path = Path(args.trace_path).resolve()
    chrome_path = Path(args.chrome_path).resolve()

    if not input_path.exists():
        raise FileNotFoundError(f"Input file not found: {input_path}")
    if not chrome_path.exists():
        raise FileNotFoundError(f"Chrome executable not found: {chrome_path}")

    replay_recording, replay_source_path, replay_mode = _build_replay_plan(input_path, args.prefer_export)
    trace_path.parent.mkdir(parents=True, exist_ok=True)

    with sync_playwright() as playwright:
        browser = playwright.chromium.launch(
            executable_path=str(chrome_path),
            headless=args.headless,
            args=["--disable-blink-features=AutomationControlled"],
        )
        context = browser.new_context(viewport=None)
        context.tracing.start(
            name="playwright-action-tracker-replay",
            screenshots=True,
            snapshots=True,
            sources=True,
        )
        page = context.new_page()

        replay_error: Exception | None = None
        try:
            replay_recording(page)
        except Exception as error:
            replay_error = error
        finally:
            context.tracing.stop(path=str(trace_path))
            context.close()
            browser.close()

    _print_console(f"Selected input: {input_path}")
    _print_console(f"Replay source: {replay_source_path} ({replay_mode})")
    _print_console(f"Trace saved: {trace_path}")
    if replay_error is not None:
        raise replay_error


if __name__ == "__main__":
    main()
