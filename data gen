@dataclass(frozen=True)
class ConditionExpression:
    expression: str

    def __str__(self) -> str:
        return self.expression

    def and_(self, other: Union[str, "ConditionExpression"]) -> "ConditionExpression":
        return ConditionExpression(f"({self}) AND ({other})")

    def or_(self, other: Union[str, "ConditionExpression"]) -> "ConditionExpression":
        return ConditionExpression(f"({self}) OR ({other})")

    def not_(self) -> "ConditionExpression":
        return ConditionExpression(f"NOT ({self})")

class ConditionOperator(Enum):
    """Standardized condition operators"""
    AND = "and"
    OR = "or"
    NOT = "not"
    EQUALS = "=="
    NOT_EQUALS = "!="
    LESS_THAN = "<"
    GREATER_THAN = ">"
    LESS_EQUAL = "<="
    GREATER_EQUAL = ">="


class TypeHandler:
    """Handles type conversion and validation for condition evaluation"""

    @staticmethod
    def convert_value(value: Any, target_type: type) -> Any:
        """Safely convert values to target type for comparison operations"""
        if value is None or pd.isna(value):
            return value

        try:
            if target_type == bool:
                if isinstance(value, str):
                    lower_val = value.lower()
                    if lower_val in ['true', 'yes', '1', 't', 'y', 'on']:
                        return True
                    elif lower_val in ['false', 'no', '0', 'f', 'n', 'off']:
                        return False
                return bool(value)
            elif target_type == int:
                return int(value)
            elif target_type == float:
                return float(value)
            elif target_type == str:
                return str(value)
            return value
        except (ValueError, TypeError):
            # If conversion fails, return original value for comparison
            return value

    @staticmethod
    def infer_type_from_values(values: List[Any]) -> type:
        """Infer the expected type from a list of possible values"""
        if not values:
            return str

        non_null_values = [v for v in values if v is not None]
        if not non_null_values:
            return str

        # Check if all values are numeric
        if all(isinstance(v, (int, float)) and not isinstance(v, bool) for v in non_null_values):
            return float if any(isinstance(v, float) for v in non_null_values) else int

        # Check if all values are boolean
        if all(isinstance(v, bool) for v in non_null_values):
            return bool

        return str


class ConditionBuilder:
    """Helper class for building conditions safely"""

    @staticmethod
    def equals(field: str, value: Any) -> ConditionExpression:
        return ConditionExpression(f"{field} == {repr(value)}")

    @staticmethod
    def not_equals(field: str, value: Any) -> ConditionExpression:
        return ConditionExpression(f"{field} != {repr(value)}")

    @staticmethod
    def greater_than(field: str, value: Any) -> ConditionExpression:
        return ConditionExpression(f"{field} > {value}")

    @staticmethod
    def less_than(field: str, value: Any) -> ConditionExpression:
        return ConditionExpression(f"{field} < {value}")

    @staticmethod
    def greater_equal(field: str, value: Any) -> ConditionExpression:
        return ConditionExpression(f"{field} >= {value}")

    @staticmethod
    def less_equal(field: str, value: Any) -> ConditionExpression:
        return ConditionExpression(f"{field} <= {value}")

    @staticmethod
    def and_conditions(*conditions: Union[str, ConditionExpression]) -> ConditionExpression:
        return ConditionExpression(f"({' AND '.join(map(str, conditions))})")

    @staticmethod
    def or_conditions(*conditions: Union[str, ConditionExpression]) -> ConditionExpression:
        return ConditionExpression(f"({' OR '.join(map(str, conditions))})")

    @staticmethod
    def not_condition(condition: Union[str, ConditionExpression]) -> ConditionExpression:
        return ConditionExpression(f"NOT {condition}")


class DatasetGenerator:
    @staticmethod
    def _normalize_answer_options(answers: List[Any]) -> List[Any]:
        """Preserve input order while removing duplicates."""
        normalized = []
        for answer in answers:
            if answer not in normalized:
                normalized.append(answer)
        if not normalized:
            raise ValueError("Answer options cannot be empty")
        return normalized

    def __init__(self, matrix: Dict[str, Any], answers_per_question: Dict[str, List[Any]],
                 helper_info: bool = False, groups: Optional[Dict[str, List[str]]] = None,
                 seed: int = 42, question_configs: Optional[Dict[str, QuestionDefinition]] = None):
        """
        Initialize the DatasetGenerator with question dependencies and answer options.

        Args:
            matrix: Dictionary mapping questions to their conditions/dependencies
            answers_per_question: Dictionary of possible answers for each question
            helper_info: Whether to print debug information
            groups: Dictionary of question groups for permutation handling
        """
        self.matrix = matrix[0] if isinstance(matrix, list) else matrix
        self.answers_per_question = {
            q: self._normalize_answer_options(list(answers))
            for q, answers in answers_per_question.items()
        }
        self.default_values = {q: answers[0] for q, answers in self.answers_per_question.items()}
        self.seed = seed
        self._rng = random.Random(self.seed)
        self.verbose = helper_info
        self.groups = groups or {}
        self.question_configs = question_configs or {}
        self.condition_cache = {}
        self._validate_inputs()
        self._validate_field_references()

    def _sample_answer(self, question: str, row_index: int = 0) -> Any:
        """Choose an answer using the configured generation strategy."""
        answers = self.answers_per_question[question]
        config = self.question_configs.get(question)
        strategy = config.generation_strategy if config else "random"
        weights = config.weights if config else None

        if strategy == "exhaustive":
            return answers[row_index % len(answers)]
        if strategy == "weighted_random" and weights:
            return self._rng.choices(answers, weights=weights, k=1)[0]
        return self._rng.choice(answers)

    def _validate_inputs(self) -> None:
        """Validate the matrix and answers_per_question for consistency."""
        for question, condition in self.matrix.items():
            if question not in self.answers_per_question:
                warnings.warn(f"Question '{question}' in matrix but not in answers_per_question")

            if isinstance(condition, dict):
                if "CP" in condition and condition["CP"] not in self.answers_per_question:
                    raise ValueError(f"Copy source '{condition['CP']}' for question '{question}' not found")

                if "IF" in condition:
                    for cond_val_pair in condition["IF"]:
                        cond, val = list(cond_val_pair.items())[0]
                        if val not in self.answers_per_question[question]:
                            warnings.warn(f"IF condition value '{val}' not in possible answers for '{question}'")

    def _validate_field_references(self) -> None:
        """Validate that all referenced fields exist in the dataset."""
        all_fields = set(self.answers_per_question.keys())

        for question, condition in self.matrix.items():
            if isinstance(condition, dict):
                # Validate dependency references
                if "D" in condition:
                    ref_fields = self._extract_referenced_fields(condition["D"])
                    missing = ref_fields - all_fields
                    if missing:
                        raise ValueError(f"Question '{question}' dependency references missing fields: {missing}")

                # Validate copy_from references
                if "CP" in condition:
                    if condition["CP"] not in all_fields:
                        raise ValueError(f"Question '{question}' copies from missing field: {condition['CP']}")

                # Validate condition references
                if "IF" in condition:
                    for cond_val_pair in condition["IF"]:
                        for condition_str in cond_val_pair.keys():
                            if condition_str != "default_value":
                                ref_fields = self._extract_referenced_fields(condition_str)
                                missing = ref_fields - all_fields
                                if missing:
                                    raise ValueError(
                                        f"Question '{question}' condition references missing fields: {missing}")

    # Update the _extract_referenced_fields method in DatasetGenerator class
    # Update the _extract_referenced_fields method in DatasetGenerator class
    def _extract_referenced_fields(self, condition: str) -> Set[str]:
        """Extract all field references from a condition string, excluding string literals."""
        if not condition:
            return set()

        import re
        # First remove string literals to avoid treating them as field names
        condition_no_strings = re.sub(r'[\'\"][^\'\"]*[\'\"]', '', condition)

        # Now extract field names (valid Python identifiers)
        pattern = r'\b([a-zA-Z_][a-zA-Z0-9_]*)\b'
        fields = set(re.findall(pattern, condition_no_strings))

        # Remove Python keywords, operators, and logical operators
        keywords = {
            'and', 'or', 'not', 'AND', 'OR', 'NOT',
            'True', 'False', 'None', 'in', 'is', 'if', 'else',
            'for', 'while', 'def', 'class', 'import', 'from', 'as',
            'true', 'false'
        }
        return fields - keywords

    # Also add a helper method to validate string literals in conditions
    def _validate_string_literals(self, condition: str) -> None:
        """Validate that string literals are properly quoted."""
        import re
        # Find all quoted strings
        string_literals = re.findall(r'([\"\'])(.*?)\1', condition)

        for quote_char, literal in string_literals:
            # Check if the literal contains the other quote type
            if ('"' in literal and quote_char == "'") or ("'" in literal and quote_char == '"'):
                raise ValueError(f"Mixed quotes in string literal: {literal}")

    # Also update the _validate_and_normalize_condition method to handle uppercase operators
    def _validate_and_normalize_condition(self, condition: str) -> str:
        """Validate condition syntax and normalize operators."""
        if not condition or condition == "default_value":
            return condition

        # Check for balanced parentheses
        if condition.count('(') != condition.count(')'):
            raise ValueError(f"Unbalanced parentheses in condition: {condition}")

        normalized = condition.strip()

        # Normalize logical keywords with word boundaries.
        normalized = re.sub(r'\bAND\b', 'and', normalized, flags=re.IGNORECASE)
        normalized = re.sub(r'\bOR\b', 'or', normalized, flags=re.IGNORECASE)
        normalized = re.sub(r'\bNOT\b', 'not', normalized, flags=re.IGNORECASE)

        # Add spacing around comparison operators without breaking >= or <=.
        normalized = re.sub(r'\s*(==|!=|<=|>=|<|>)\s*', r' \1 ', normalized)

        # Remove extra spaces and clean up.
        normalized = ' '.join(normalized.split())

        return normalized

    def _parse_condition_ast(self, condition: str) -> ast.AST:
        """Parse and validate a condition into a safe AST node."""
        normalized = self._validate_and_normalize_condition(condition)
        try:
            parsed = ast.parse(normalized, mode="eval")
        except SyntaxError as exc:
            raise ValueError(f"Invalid condition syntax: {condition}") from exc

        allowed_nodes = (
            ast.Expression, ast.BoolOp, ast.UnaryOp, ast.Compare, ast.Name, ast.Load,
            ast.Constant, ast.And, ast.Or, ast.Not, ast.Eq, ast.NotEq, ast.Lt,
            ast.LtE, ast.Gt, ast.GtE, ast.Is, ast.IsNot, ast.In, ast.NotIn,
            ast.Tuple, ast.List
        )
        for node in ast.walk(parsed):
            if not isinstance(node, allowed_nodes):
                raise ValueError(f"Unsupported condition expression: {condition}")
        return parsed.body

    def _compare_values(self, left: Any, operator: ast.AST, right: Any) -> bool:
        """Apply one comparison operator safely."""
        if isinstance(operator, ast.Eq):
            return left == right
        if isinstance(operator, ast.NotEq):
            return left != right
        if isinstance(operator, ast.Lt):
            return left < right
        if isinstance(operator, ast.LtE):
            return left <= right
        if isinstance(operator, ast.Gt):
            return left > right
        if isinstance(operator, ast.GtE):
            return left >= right
        if isinstance(operator, ast.Is):
            return left is right
        if isinstance(operator, ast.IsNot):
            return left is not right
        if isinstance(operator, ast.In):
            return left in right
        if isinstance(operator, ast.NotIn):
            return left not in right
        raise ValueError("Unsupported comparison operator")

    def _evaluate_ast_node(self, node: ast.AST, context: Dict[str, Any]) -> Any:
        """Evaluate a previously-validated AST node against the current row context."""
        if isinstance(node, ast.BoolOp):
            values = [self._evaluate_ast_node(value, context) for value in node.values]
            if isinstance(node.op, ast.And):
                return all(values)
            if isinstance(node.op, ast.Or):
                return any(values)
        if isinstance(node, ast.UnaryOp) and isinstance(node.op, ast.Not):
            return not bool(self._evaluate_ast_node(node.operand, context))
        if isinstance(node, ast.Compare):
            left = self._evaluate_ast_node(node.left, context)
            for operator, comparator in zip(node.ops, node.comparators):
                right = self._evaluate_ast_node(comparator, context)
                if not self._compare_values(left, operator, right):
                    return False
                left = right
            return True
        if isinstance(node, ast.Name):
            return context.get(node.id)
        if isinstance(node, ast.Constant):
            return node.value
        if isinstance(node, ast.Tuple):
            return tuple(self._evaluate_ast_node(element, context) for element in node.elts)
        if isinstance(node, ast.List):
            return [self._evaluate_ast_node(element, context) for element in node.elts]
        raise ValueError("Unsupported AST node during evaluation")

    def log(self, message: str, level: str = "INFO") -> None:
        """Log helper messages if verbose mode is enabled."""
        if self.verbose:
            timestamp = datetime.datetime.now().strftime("%H:%M:%S")
            print(f"{timestamp} [{level}] {message}")

    def evaluate_condition(self, condition: str, context: Dict[str, Any]) -> bool:
        """
        Evaluate a logical condition with proper operator and bracket handling.
        FIXED VERSION - Simplified and more reliable.
        """
        try:
            condition = self._validate_and_normalize_condition(condition)
            if condition in ("", None, "default_value"):
                return False

            # Create a clean context with proper values
            safe_context = {}
            for key, value in context.items():
                if pd.isna(value) or value == "SKIP" or value is None:
                    safe_context[key] = None
                else:
                    safe_context[key] = value

            # For debugging
            if self.verbose:
                self.log(f"Evaluating condition: '{condition}'")
                self.log(f"With context: {safe_context}")

            parsed = self.condition_cache.get(condition)
            if parsed is None:
                parsed = self._parse_condition_ast(condition)
                self.condition_cache[condition] = parsed

            result = self._evaluate_ast_node(parsed, safe_context)

            if self.verbose:
                self.log(f"Result: {result}")

            return bool(result)

        except Exception as e:
            if self.verbose:
                self.log(f"Error evaluating condition '{condition}': {e}")
                self.log(f"Context was: {context}")
            return False

    def generate_test_set(self, num_samples: int = 100) -> bool:
        """
        Validate dependencies by testing with random samples.

        Args:
            num_samples: Number of random test cases to generate

        Returns:
            bool: True if all dependencies are satisfiable, False otherwise
        """
        self.log("\nValidating dependencies with sampled cases...")
        dependencies = [
            (q, condition["D"])
            for q, condition in self.matrix.items()
            if isinstance(condition, dict) and "D" in condition
        ]

        for question, dep_str in dependencies:
            valid_samples = 0
            for _ in range(num_samples):
                try:
                    sample_context = {q: self._rng.choice(ans) for q, ans in self.answers_per_question.items()}
                    if self.evaluate_condition(dep_str, sample_context):
                        valid_samples += 1
                except Exception as e:
                    self.log(f"  Error testing dependency '{dep_str}': {e}", "WARNING")
                    continue

            if valid_samples == 0:
                self.log(f"  Unsatisfiable dependency for '{question}': {dep_str}")
                return False

        self.log("Dependencies validated successfully.")
        return True

    def _ensure_default_values(self, row: Dict[str, Any]) -> Dict[str, Any]:
        """Ensure all fields have proper default values."""
        for question in self.answers_per_question.keys():
            if question not in row or pd.isna(row.get(question)) or row.get(question) == "SKIP":
                row[question] = self.default_values.get(question, self.answers_per_question[question][0])
        return row

    def generate_dataset(self, num_rows: int = 500) -> pd.DataFrame:
        """Generate the dataset with comprehensive logging and validation."""
        self.log(f"\nGenerating dataset with {num_rows} rows...")
        data = []
        questions = list(self.answers_per_question.keys())

        for i in range(num_rows):
            if self.verbose and i % 100 == 0:
                self.log(f"Generating row {i + 1}/{num_rows}")

            row = {}
            debug_row = self.verbose and i < 3  # Debug first 3 rows

            # First pass: set all non-conditional questions
            for question in questions:
                condition = self.matrix.get(question)
                if isinstance(condition, dict) and ("IF" in condition or "D" in condition):
                    continue

                if condition is None:
                    row[question] = self._sample_answer(question, i)
                elif isinstance(condition, dict) and "CP" in condition:
                    copy_from = condition["CP"]
                    row[question] = row.get(copy_from, self.default_values[copy_from])
                elif condition == "SKIP":
                    row[question] = "SKIP"
                else:
                    row[question] = self._sample_answer(question, i)

            # Second pass: handle conditional questions
            for question in questions:
                condition = self.matrix.get(question)
                if not isinstance(condition, dict):
                    continue

                # Handle dependency first if it exists
                if "D" in condition:
                    try:
                        if not self.evaluate_condition(condition["D"], row):
                            row[question] = "SKIP"
                            continue
                    except Exception as e:
                        self.log(f"Error processing dependency for '{question}': {e}", "WARNING")
                        row[question] = "SKIP"
                        continue

                # Handle if-conditions if they exist
                if "IF" in condition:
                    matched = False
                    for cond_val_pair in condition["IF"]:
                        if "default_value" in cond_val_pair:
                            continue  # Handle default separately

                        cond, val = list(cond_val_pair.items())[0]
                        try:
                            if self.evaluate_condition(cond, row):
                                row[question] = val
                                matched = True
                                break
                        except Exception as e:
                            self.log(f"Error evaluating condition '{cond}': {e}", "WARNING")
                            continue

                    if not matched:
                        # Check for explicit default in if_conditions
                        for cond_val_pair in condition["IF"]:
                            if "default_value" in cond_val_pair:
                                row[question] = cond_val_pair["default_value"]
                                matched = True
                                break

                        # Fall back to question's default value
                        if not matched and "default" in condition:
                            row[question] = condition["default"]

            # Ensure defaults for all fields
            row = self._ensure_default_values(row)
            data.append(row)

        return pd.DataFrame(data, columns=questions)

    def fill_missing_data(self, df: pd.DataFrame) -> pd.DataFrame:
        """Handle missing data based on question dependencies and requirements."""
        self.log("\nFilling missing data based on dependencies...")

        # First handle REQUIRED fields
        req_fields = [q for q, cond in self.matrix.items() if cond == "REQ"]
        for question in req_fields:
            self.log(f"- Ensuring REQ field '{question}' is filled.")
            df[question] = df[question].fillna(self.default_values[question])

        # Then handle dependencies
        for question, condition in self.matrix.items():
            if not isinstance(condition, dict):
                continue

            if "D" in condition:
                dep_str = condition["D"]
                self.log(f"- Handling dependency for '{question}': {dep_str}")

                for i, row in df.iterrows():
                    context = row.to_dict()
                    try:
                        if self.evaluate_condition(dep_str, context):
                            if pd.isna(row[question]) or row[question] == "SKIP":
                                df.at[i, question] = self.default_values[question]
                        else:
                            df.at[i, question] = "SKIP"
                    except Exception as e:
                        self.log(f"  Error processing dependency for row {i}: {e}", "WARNING")
                        df.at[i, question] = "SKIP"

            elif "CP" in condition:
                copy_from = condition["CP"]
                df[question] = df[copy_from]

        df.fillna("SKIP", inplace=True)
        return df

    def reduce_to_minimum(self, df: pd.DataFrame) -> pd.DataFrame:
        """Reduce dataset to ensure coverage of all answer combinations."""
        self.log("\nReducing dataset to ensure complete coverage...")
        required_rows = []

        for question, orig_answers in self.answers_per_question.items():
            condition = self.matrix.get(question, None)

            # Determine target answers we need coverage for
            if isinstance(condition, dict):
                if "IF" in condition:
                    target_answers = {val for cond_val_pair in condition["IF"]
                                      for val in cond_val_pair.values()}
                    if not target_answers:
                        target_answers.add(self.default_values[question])
                elif "CP" in condition:
                    copy_from = condition["CP"]
                    target_answers = set(self.answers_per_question.get(copy_from, []))
                else:
                    target_answers = set(orig_answers)
            else:
                target_answers = set(orig_answers)

            # Ensure coverage for each target answer
            for answer in target_answers:
                subset = df[df[question] == answer]
                if not subset.empty:
                    required_rows.append(subset.iloc[0].to_dict())
                else:
                    new_row = {q: self._rng.choice(self.answers_per_question[q])
                               for q in self.answers_per_question.keys()}
                    new_row[question] = answer

                    # Handle dependencies for the new row
                    for dep_question, dep_condition in self.matrix.items():
                        if isinstance(dep_condition, dict) and "D" in dep_condition:
                            dep_str = dep_condition["D"]
                            try:
                                if not self.evaluate_condition(dep_str, new_row):
                                    new_row[dep_question] = "SKIP"
                            except Exception:
                                new_row[dep_question] = "SKIP"
                    required_rows.append(new_row)

        # Ensure coverage for dependency conditions
        for question, condition in self.matrix.items():
            if isinstance(condition, dict) and "D" in condition:
                dep_str = condition["D"]
                valid_rows = df[df.apply(lambda row: self.evaluate_condition(dep_str, row.to_dict()), axis=1)]
                if not valid_rows.empty:
                    required_rows.extend(valid_rows.iloc[:1].to_dict("records"))

        reduced_df = pd.DataFrame(required_rows).drop_duplicates()
        self.log(f"Reduced dataset to {len(reduced_df)} rows.")
        return reduced_df

    def _apply_pairwise_coverage(self, df: pd.DataFrame) -> pd.DataFrame:
        """Ensure pairwise coverage for questions marked with the pairwise strategy."""
        pairwise_questions = [
            question for question, config in self.question_configs.items()
            if config.generation_strategy == "pairwise"
        ]
        if len(pairwise_questions) < 2:
            return df

        new_rows = []
        for left_index in range(len(pairwise_questions)):
            for right_index in range(left_index + 1, len(pairwise_questions)):
                left_question = pairwise_questions[left_index]
                right_question = pairwise_questions[right_index]
                combinations = itertools.product(
                    self.answers_per_question[left_question],
                    self.answers_per_question[right_question],
                )
                for left_value, right_value in combinations:
                    mask = (df[left_question] == left_value) & (df[right_question] == right_value)
                    if not mask.any():
                        base_row = (
                            df.iloc[0].to_dict()
                            if not df.empty
                            else {q: self.default_values[q] for q in self.answers_per_question.keys()}
                        )
                        base_row[left_question] = left_value
                        base_row[right_question] = right_value
                        new_rows.append(base_row)

        if new_rows:
            df = pd.concat([df, pd.DataFrame(new_rows)], ignore_index=True).drop_duplicates().reset_index(drop=True)
        return df

    def apply_group_permutations(self, df: pd.DataFrame) -> pd.DataFrame:
        """Ensure coverage of all combinations within question groups."""
        if not self.groups:
            return self._apply_pairwise_coverage(df)

        new_rows = []
        for group_name, group_keys in self.groups.items():
            answer_lists = [self.answers_per_question[q] for q in group_keys]
            combinations = list(itertools.product(*answer_lists))

            for combo in combinations:
                mask = pd.Series([True] * len(df))
                for col, val in zip(group_keys, combo):
                    mask = mask & (df[col] == val)

                if not mask.any():
                    if not df.empty:
                        base_row = df.iloc[0].to_dict()
                    else:
                        base_row = {q: self.default_values[q] for q in self.answers_per_question.keys()}

                    for col, val in zip(group_keys, combo):
                        base_row[col] = val
                    new_rows.append(base_row)

        if new_rows:
            new_df = pd.DataFrame(new_rows)
            df = pd.concat([df, new_df], ignore_index=True).drop_duplicates().reset_index(drop=True)

            # Re-evaluate dependencies for new rows
            for question, condition in self.matrix.items():
                if isinstance(condition, dict) and "D" in condition:
                    dep_str = condition["D"]
                    for i, row in df.iterrows():
                        context = row.to_dict()
                        try:
                            if not self.evaluate_condition(dep_str, context):
                                df.at[i, question] = "SKIP"
                        except Exception:
                            df.at[i, question] = "SKIP"

        return self._apply_pairwise_coverage(df)

    def generate_large_dataset(self, num_rows: int = 10000, chunk_size: int = 1000) -> pd.DataFrame:
        """Generate large datasets in chunks to save memory."""
        chunks = []

        for chunk_num in range(0, num_rows, chunk_size):
            current_chunk_size = min(chunk_size, num_rows - chunk_num)
            self.log(f"Generating chunk {chunk_num // chunk_size + 1}/{(num_rows - 1) // chunk_size + 1}")

            chunk_data = self.generate_dataset(current_chunk_size)
            chunks.append(chunk_data)

        return pd.concat(chunks, ignore_index=True)

    def generate_with_acm(self, filename: Optional[str] = None,
                          acm: Optional['AccessControlManager'] = None,
                          num_rows: int = 500) -> pd.DataFrame:
        """
        Main method to generate and save the dataset with Access Control Manager support.

        Args:
            filename: Output filename (optional, will auto-generate if None)
            acm: AccessControlManager instance

        Returns:
            pd.DataFrame: Generated dataset with ACM metadata if provided
        """
        if not self.generate_test_set(num_samples=500):
            print("\nFailed to validate dependencies. Please review the matrix.")
            return pd.DataFrame()

        # Generate the base dataset
        dataset = self.generate_dataset(num_rows=num_rows)
        dataset = self.fill_missing_data(dataset)
        dataset = self.reduce_to_minimum(dataset)
        dataset = self.apply_group_permutations(dataset)

        # Add ACM metadata if provided
        if acm:
            # Validate that ACM fields match dataset columns
            warnings = acm.validate_permissions()
            if warnings:
                self.log("Access control warnings:")
                for warning in warnings:
                    self.log(f"  - {warning}")

            # Add access control metadata as additional columns
            for role in acm.user_roles:
                for column in dataset.columns:
                    if column in acm.permissions:  # Only add metadata for columns with defined permissions
                        permission = acm.get_permissions(column, role)
                        dataset[f"{column}_permission_{role}"] = permission

        # Generate filename if not provided
        if filename is None:
            date = datetime.datetime.now().strftime("%Y%m%d")
            dataset_type = "with_acm" if acm else "base"
            filename = f"dataset_{dataset_type}_{date}.csv"

        self.save_to_csv(dataset, filename)
        return dataset

    def save_to_csv(self, df: pd.DataFrame, filename: str) -> str:
        """Save generated dataset to CSV file and return the filename."""
        # Create directory if it doesn't exist
        os.makedirs(os.path.dirname(filename) if os.path.dirname(filename) else '.', exist_ok=True)

        df.to_csv(filename, index=False)
        self.log(f"Dataset saved to {filename}")
        return filename

    @classmethod
    def load_from_pickle(cls, filename: str = "dataset.pkl", helper_info: bool = False) -> 'DatasetGenerator':
        """Load generator configuration from pickle file."""
        with open(filename, "rb") as f:
            data = pickle.load(f)
        return cls([data["matrix"]], data["questions_and_answers"], helper_info)

    def generate(self, filename: str = "output.csv", acm: Optional['AccessControlManager'] = None,
                 num_rows: int = 500) -> pd.DataFrame:
        """Main method to generate and save the dataset."""
        return self.generate_with_acm(filename, acm, num_rows=num_rows)


class DataSetCreator:
    def __init__(self):
        """Initialize a dataset creator with empty configuration."""
        self.user_keys: Dict[str, QuestionDefinition] = {}
        self.matrix = {}
        self.answers_per_question = {}
        self.logging = False
        self.groups = {}
        self.question_order = []
        self.logic_rules = []
        self._defined_questions = set()  # Track which questions have been defined
        self.seed = 42
        self._rng = random.Random(self.seed)

    def set_seed(self, seed: int) -> None:
        """Set the deterministic seed used by generated datasets."""
        self.seed = seed
        self._rng = random.Random(self.seed)

    def log(self, message: str) -> None:
        """Log messages if logging is enabled."""
        if self.logging:
            print(message)

    @staticmethod
    def _normalize_condition_value(condition: Union[str, ConditionExpression, None]) -> Optional[str]:
        """Normalize string-like condition inputs into plain strings."""
        if condition is None:
            return None
        return str(condition)

    def _normalize_condition_mapping(
        self, condition_mapping: Dict[Union[str, ConditionExpression], Any]
    ) -> Dict[str, Any]:
        """Normalize a single condition:value mapping to plain-string conditions."""
        normalized = {}
        for condition, value in condition_mapping.items():
            normalized[self._normalize_condition_value(condition) or ""] = value
        return normalized

    def _get_declared_field_type(self, field_name: str) -> type:
        values = self.answers_per_question.get(field_name, [])
        if not values:
            return str
        filtered = [value for value in values if value != "SKIP"]
        if not filtered:
            return str
        return TypeHandler.infer_type_from_values(filtered)

    def _validate_condition_type_compatibility(self, condition: str, target_name: str) -> None:
        if not condition or condition == "default_value":
            return

        normalized = re.sub(r'\bAND\b', 'and', condition, flags=re.IGNORECASE)
        normalized = re.sub(r'\bOR\b', 'or', normalized, flags=re.IGNORECASE)
        normalized = re.sub(r'\bNOT\b', 'not', normalized, flags=re.IGNORECASE)

        direct_pattern = re.compile(r'\b([A-Za-z_][A-Za-z0-9_]*)\b\s*(<=|>=|<|>)\s*(-?\d+(?:\.\d+)?)')
        reverse_pattern = re.compile(r'(-?\d+(?:\.\d+)?)\s*(<=|>=|<|>)\s*\b([A-Za-z_][A-Za-z0-9_]*)\b')

        for match in direct_pattern.finditer(normalized):
            field_name = match.group(1)
            field_type = self._get_declared_field_type(field_name)
            if field_type not in (int, float):
                raise ValueError(
                    f"Invalid numeric comparison in {target_name}: field '{field_name}' is typed as "
                    f"{field_type.__name__}, so condition '{condition}' is not valid."
                )

        for match in reverse_pattern.finditer(normalized):
            field_name = match.group(3)
            field_type = self._get_declared_field_type(field_name)
            if field_type not in (int, float):
                raise ValueError(
                    f"Invalid numeric comparison in {target_name}: field '{field_name}' is typed as "
                    f"{field_type.__name__}, so condition '{condition}' is not valid."
                )
            # Reject quoted field names like 'age' == 10 from slipping through variable extraction silently.
        quoted_field_pattern = re.compile(r"['\"]([A-Za-z_][A-Za-z0-9_]*)['\"]\s*(<=|>=|<|>)")
        if quoted_field_pattern.search(condition):
            raise ValueError(
                f"Invalid condition in {target_name}: field names must not be quoted in '{condition}'."
            )

    def add_question(self, key: str, possible_answers: Optional[List[Any]] = None,
                     default_value: Any = None, dependency: Optional[Union[str, ConditionExpression]] = None,
                     copy_from: Optional[str] = None, skip: bool = False,
                     if_conditions: Optional[List[Dict[Union[str, ConditionExpression], Any]]] = None,
                     group: Optional[str] = None,
                     weights: Optional[List[float]] = None,
                     generation_strategy: str = "random",
                     ui_role: str = "input") -> None:
        """
        Add a question to the dataset configuration.

        Args:
            key: Question identifier
            possible_answers: List of possible answer values (optional if if_conditions provided)
            default_value: Default answer if no conditions match (required if if_conditions provided)
            dependency: Dependency condition string
            copy_from: Question to copy value from
            skip: Whether this question should be skipped
            if_conditions: List of dictionaries with condition:value pairs or {'default_value': value}
            group: Group identifier for question grouping
            weights: Optional sampling weights aligned to possible_answers
            generation_strategy: One of random, weighted_random, exhaustive, pairwise

        Example:
            add_question("q4", if_conditions=[
                {"q1 == 'Yes' AND q2 == 'High'": "Value1"},
                {"q1 == 'No' AND q2 == 'Low'": "Value2"},
                {"default_value": "DefaultValue"}
            ])
        """
        if key in self.user_keys or key in {rule.target for rule in self.logic_rules}:
            raise ValueError(f"Question '{key}' is already defined")

        # Handle if_conditions that might include default_value
        dependency = self._normalize_condition_value(dependency)
        processed_if_conditions = []
        if if_conditions:
            for condition_dict in if_conditions:
                condition_dict = self._normalize_condition_mapping(condition_dict)
                if "default_value" in condition_dict:
                    if default_value is None:
                        default_value = condition_dict["default_value"]
                else:
                    processed_if_conditions.append(condition_dict)
            if_conditions = processed_if_conditions

        # Validate parameters
        if dependency and copy_from:
            raise ValueError("A question cannot have both a dependency and a copy relationship.")
        if skip and (dependency or copy_from):
            raise ValueError("A question marked as 'SKIP' cannot have a dependency or copy relationship.")
        valid_strategies = {"random", "weighted_random", "exhaustive", "pairwise"}
        if generation_strategy not in valid_strategies:
            raise ValueError(f"generation_strategy must be one of {sorted(valid_strategies)}")
        valid_ui_roles = {"input", "calculation", "display"}
        if ui_role not in valid_ui_roles:
            raise ValueError(f"ui_role must be one of {sorted(valid_ui_roles)}")
        if generation_strategy == "weighted_random" and weights is None:
            raise ValueError("generation_strategy 'weighted_random' requires weights")
        if skip and generation_strategy in {"weighted_random", "exhaustive", "pairwise"}:
            raise ValueError("Skipped questions cannot use weighted_random, exhaustive, or pairwise strategies")
        if copy_from:
            if copy_from not in self._defined_questions:
                raise ValueError(f"copy_from source '{copy_from}' must be defined before '{key}'")
            if any(rule.target == copy_from for rule in self.logic_rules):
                raise ValueError(f"copy_from source '{copy_from}' cannot be a calculation field")

        # Handle the case where possible_answers isn't provided but if_conditions are
        if possible_answers is None:
            if not if_conditions:
                raise ValueError("Either possible_answers or if_conditions must be provided")
            if default_value is None:
                raise ValueError("default_value must be provided when using if_conditions without possible_answers")

            # Extract possible answers from if_conditions
            possible_answers = list({val for cond_dict in if_conditions
                                     for val in cond_dict.values()})
            if default_value not in possible_answers:
                possible_answers.append(default_value)
        else:
            if default_value is None:
                default_value = possible_answers[0]
            elif default_value not in possible_answers:
                raise ValueError(f"Default value '{default_value}' not in possible answers")
            possible_answers = DatasetGenerator._normalize_answer_options(list(possible_answers))
        if weights is not None:
            if len(weights) != len(possible_answers):
                raise ValueError("weights length must match possible_answers length")
            if any(weight < 0 for weight in weights):
                raise ValueError("weights must be non-negative")
            if sum(weights) == 0:
                raise ValueError("weights must not all be zero")
            if generation_strategy == "random":
                generation_strategy = "weighted_random"

        if dependency:
            self._validate_condition_type_compatibility(dependency, f"question '{key}' dependency")
        if if_conditions:
            for condition_dict in if_conditions:
                condition = list(condition_dict.keys())[0]
                self._validate_condition_type_compatibility(condition, f"question '{key}' mapping")

        if group is not None:
            self.groups.setdefault(group, []).append(key)

        self.user_keys[key] = QuestionDefinition(
            possible_answers=possible_answers,
            default_value=default_value,
            dependency=dependency,
            copy_from=copy_from,
            skip=skip,
            if_conditions=if_conditions if if_conditions else [],
            group=group,
            weights=weights,
            generation_strategy=generation_strategy,
            ui_role=ui_role,
        )

        self.answers_per_question[key] = ["SKIP"] if skip else possible_answers
        self.question_order.append(key)
        self._defined_questions.add(key)  # Mark question as defined

    def add_base_question(self, key: str, possible_answers: List[Any], default_value: Any = None,
                          group: Optional[str] = None, weights: Optional[List[float]] = None,
                          generation_strategy: str = "random", ui_role: str = "input") -> None:
        """Add a regular question with direct answer choices."""
        self.add_question(
            key=key,
            possible_answers=possible_answers,
            default_value=default_value,
            group=group,
            weights=weights,
            generation_strategy=generation_strategy,
            ui_role=ui_role,
        )

    def add_conditional_question(self, key: str,
                                 if_conditions: List[Dict[Union[str, ConditionExpression], Any]],
                                 possible_answers: Optional[List[Any]] = None,
                                 default_value: Any = None,
                                 dependency: Optional[Union[str, ConditionExpression]] = None,
                                 group: Optional[str] = None,
                                 ui_role: str = "input") -> None:
        """Add a question whose value is chosen from conditional mappings."""
        self.add_question(
            key=key,
            possible_answers=possible_answers,
            default_value=default_value,
            dependency=dependency,
            if_conditions=if_conditions,
            group=group,
            ui_role=ui_role,
        )

    def add_copy_question(self, key: str, possible_answers: List[Any], copy_from: str,
                          default_value: Any = None, ui_role: str = "input") -> None:
        """Add a question that copies its value from another question."""
        self.add_question(
            key=key,
            possible_answers=possible_answers,
            default_value=default_value,
            copy_from=copy_from,
            ui_role=ui_role,
        )

    def add_skipped_question(self, key: str, possible_answers: Optional[List[Any]] = None,
                             ui_role: str = "display") -> None:
        """Add a question that is always populated with SKIP."""
        self.add_question(
            key=key,
            possible_answers=possible_answers or ["SKIP"],
            skip=True,
            ui_role=ui_role,
        )

    def _create_generator(self, helper_info: Optional[bool] = None) -> DatasetGenerator:
        """Create a DatasetGenerator from the current creator state."""
        self._build_matrix()
        return DatasetGenerator(
            [self.matrix],
            self.answers_per_question,
            helper_info=self.logging if helper_info is None else helper_info,
            groups=self.get_groups(),
            seed=self.seed,
            question_configs=self.user_keys,
        )

    def add_logic(self, target_question: str, rules: List[Dict[Union[str, ConditionExpression], Any]],
                  possible_values: Optional[List[Any]] = None, default_value: Optional[Any] = None,
                  position: Optional[int] = None,
                  ui_role: str = "calculation") -> None:
        """
        Add conditional logic rules with full bracket support and validation.

        Args:
            target_question: The question to derive
            rules: List of dictionaries with condition:value pairs or {'default_value': value}
            possible_values: Optional list of possible values
            default_value: Fallback value if no rules match
            position: Insertion position in question order

        Example:
            add_logic("discount", rules=[
                {"(age < 18) OR (age_group == 'child')": "30%"},
                {"(age >= 65) AND (membership == 'free')": "25%"},
                {"membership == 'premium'": "15%"},
                {"default_value": "0%"}
            ])
        """
        if target_question in self.user_keys:
            raise ValueError(f"Question '{target_question}' already exists")
        valid_ui_roles = {"input", "calculation", "display"}
        if ui_role not in valid_ui_roles:
            raise ValueError(f"ui_role must be one of {sorted(valid_ui_roles)}")

        # Validate that all referenced questions in conditions exist
        normalized_rules = [self._normalize_condition_mapping(rule_dict) for rule_dict in rules]
        for rule_dict in normalized_rules:
            if "default_value" in rule_dict:
                continue

            condition, outcome = list(rule_dict.items())[0]
            # Extract all variable names from the condition
            referenced_questions = self._extract_variables_from_condition(condition)

            # Check if all referenced questions have been defined
            missing_questions = [q for q in referenced_questions if q not in self._defined_questions]
            if missing_questions:
                raise ValueError(
                    f"Cannot add logic for '{target_question}': "
                    f"Referenced questions {missing_questions} have not been defined yet. "
                    f"Please add them using add_question() before adding this logic rule."
                )
            self._validate_condition_type_compatibility(condition, f"logic target '{target_question}'")

        processed_rules = []
        seen_values = set()

        for rule_dict in normalized_rules:
            if "default_value" in rule_dict:
                if default_value is None:
                    default_value = rule_dict["default_value"]
                continue

            condition, outcome = list(rule_dict.items())[0]
            # Validate bracket balance
            if condition.count("(") != condition.count(")"):
                raise ValueError(f"Unbalanced brackets in condition: {condition}")

            seen_values.add(outcome)
            processed_rules.append({condition: outcome})

        # Set possible values if not provided
        if possible_values is None:
            possible_values = list(seen_values)
            if not possible_values:
                raise ValueError("Could not determine possible values from rules")
        else:
            possible_values = DatasetGenerator._normalize_answer_options(list(possible_values))

        # Set default value
        final_default = default_value if default_value is not None else possible_values[0]
        if final_default not in possible_values:
            possible_values.append(final_default)

        # Store the rule
        self.logic_rules.append(LogicRuleDefinition(
            target=target_question,
            rules=processed_rules,
            possible_values=possible_values,
            default=final_default,
            position=position,
            ui_role=ui_role,
        ))

        self.answers_per_question[target_question] = possible_values

        if position is not None and 0 <= position <= len(self.question_order):
            self.question_order.insert(position, target_question)
        else:
            self.question_order.append(target_question)

        self._defined_questions.add(target_question)  # Mark logic target as defined

    def _extract_variables_from_condition(self, condition: str) -> List[str]:
        """
        Extract variable names from a condition string, properly handling boolean values, numbers, and strings.
        """
        # First, remove all quoted strings (single and double quotes)
        condition_no_quotes = re.sub(r'(\".*?\"|\'.*?\')', ' ', condition)

        # Remove Python keywords and operators
        operators_and_keywords = [
            'and', 'or', 'not', 'in', 'is',
            '==', '!=', '>=', '<=', '>', '<',
            'True', 'False', 'None'
        ]

        # Create a pattern to remove operators and keywords
        pattern = r'\b(' + '|'.join(operators_and_keywords) + r')\b'
        cleaned = re.sub(pattern, ' ', condition_no_quotes, flags=re.IGNORECASE)

        # Remove parentheses and other symbols
        cleaned = re.sub(r'[\(\)\[\]\{\}]', ' ', cleaned)

        # Extract potential variables
        potential_vars = re.findall(r'[a-zA-Z_][a-zA-Z0-9_]*', cleaned)

        # Filter out any remaining keywords and validate
        variables = []
        for var in potential_vars:
            if (var.lower() not in operators_and_keywords and
                    not var.replace('.', '').isdigit() and  # Not a number
                    not var.startswith('_')):  # Not a special variable
                variables.append(var)

        return list(set(variables))

    def _build_matrix(self) -> None:
        """Build the internal matrix representation from user configuration."""
        self.matrix = {}
        for key, details in self.user_keys.items():
            if details.skip:
                self.matrix[key] = "SKIP"
            elif details.dependency and details.if_conditions:
                # Combined dependency and if_conditions
                self.matrix[key] = {
                    "D": details.dependency,
                    "IF": details.if_conditions,
                    "default": details.default_value
                }
            elif details.dependency:
                self.matrix[key] = {"D": details.dependency}
            elif details.copy_from:
                self.matrix[key] = {"CP": details.copy_from}
            elif details.if_conditions:
                self.matrix[key] = {
                    "IF": details.if_conditions,
                    "default": details.default_value
                }
            else:
                self.matrix[key] = "REQ"

    def get_groups(self) -> Dict[str, List[str]]:
        """Get mapping of group names to question lists."""
        groups_mapping = {}
        for key, details in self.user_keys.items():
            if details.group:
                groups_mapping.setdefault(details.group, []).append(key)
        return groups_mapping

    def _apply_logic_rules(self, df: pd.DataFrame) -> pd.DataFrame:
        """Apply all defined logic rules to the dataset."""
        self._build_matrix()
        evaluator = DatasetGenerator(
            [self.matrix],
            self.answers_per_question,
            helper_info=self.logging,
            groups=self.get_groups()
        )
        for rule in self.logic_rules:
            target = rule.target
            rules = rule.rules
            default = rule.default

            def evaluate_row(row: pd.Series) -> Any:
                context = row.to_dict()
                for rule_dict in rules:
                    condition, outcome = list(rule_dict.items())[0]
                    try:
                        if evaluator.evaluate_condition(condition, context):
                            return outcome
                    except Exception as e:
                        self.log(f"Error evaluating condition '{condition}': {e}")
                        continue
                return default

            df[target] = df.apply(evaluate_row, axis=1)
        return df

    def export_pre_generator_data(self, filename: str = "pre_generator_output.csv") -> None:
        """Export the question configuration before generation."""
        self._build_matrix()
        pre_generator_data = {
            "Key": [],
            "Possible Answers": [],
            "Default Value": [],
            "Logic": [],
            "Group": []
        }

        for key in self.question_order:
            details = self.user_keys.get(key, {})
            pre_generator_data["Key"].append(key)
            pre_generator_data["Possible Answers"].append(
                ", ".join(map(str, getattr(details, "possible_answers", [])))
            )
            pre_generator_data["Default Value"].append(str(getattr(details, "default_value", "")))

            if key in self.matrix:
                condition = self.matrix[key]
                if condition == "SKIP":
                    pre_generator_data["Logic"].append("SKIP")
                elif isinstance(condition, dict):
                    if "D" in condition:
                        pre_generator_data["Logic"].append(f"D: {condition['D']}")
                    elif "CP" in condition:
                        pre_generator_data["Logic"].append(f"CP: {condition['CP']}")
                    elif "IF" in condition:
                        pre_generator_data["Logic"].append(f"IF: {len(condition['IF'])} conditions")
                else:
                    pre_generator_data["Logic"].append(condition)
            else:
                pre_generator_data["Logic"].append("")

            pre_generator_data["Group"].append(getattr(details, "group", ""))

        pd.DataFrame(pre_generator_data).to_csv(filename, index=False)
        self.log(f"Pre-generator data saved to {filename}")

    def _build_acm_view(self, dataset: pd.DataFrame, acm: AccessControlManager) -> Dict[str, Dict[str, Any]]:
        """Build a separate ACM dictionary view for each record."""
        acm.set_dataset_columns(dataset.columns.tolist())
        warnings = acm.validate_permissions()
        if warnings:
            self.log("Access control warnings:")
            for warning in warnings:
                self.log(f"  - {warning}")

        protected_columns = [column for column in dataset.columns if column in acm.permissions]
        acm_view = {}
        for row_index, row in dataset.iterrows():
            record_key = f"record_{row_index}"
            acm_view[record_key] = {
                "data": row.to_dict(),
                "permissions": {},
            }
            for role in sorted(acm.user_roles):
                acm_view[record_key]["permissions"][role] = {
                    column: acm.get_permissions(column, role, record=row.to_dict())
                    for column in protected_columns
                }
        return acm_view

    def _build_acm_view_filename(self, filename: str) -> str:
        """Return an ACM companion filename in the same directory with an 'acm_' prefix."""
        directory, base_name = os.path.split(filename)
        stem, _ext = os.path.splitext(base_name)
        acm_base_name = stem if stem.startswith("acm_") else f"acm_{stem}"
        acm_base_name = f"{acm_base_name}.json"
        return os.path.join(directory, acm_base_name) if directory else acm_base_name

    def export_dataset(self, dataset: pd.DataFrame, filename: str) -> str:
        """Persist a generated dataset to CSV."""
        dataset.to_csv(filename, index=False)
        self.log(f"Dataset saved to {filename}")
        return filename

    def export_acm_view(self, dataset: pd.DataFrame, acm: AccessControlManager, filename: str) -> str:
        """Persist the ACM record dictionary as JSON."""
        acm_filename = self._build_acm_view_filename(filename)
        acm_view = self._build_acm_view(dataset, acm)
        with open(acm_filename, "w", encoding="utf-8") as acm_file:
            json.dump(acm_view, acm_file, indent=2, default=str)
        self.log(f"ACM view saved to {acm_filename}")
        return acm_filename

    def export_to_excel(self, dataset: pd.DataFrame, filename: str,
                        acm: Optional[AccessControlManager] = None) -> str:
        """Export dataset, coverage, and optional ACM views into an Excel workbook."""
        with pd.ExcelWriter(filename) as writer:
            dataset.to_excel(writer, sheet_name="dataset", index=False)
            pd.DataFrame(self.generate_coverage_report(dataset)["answer_coverage"]).to_excel(
                writer, sheet_name="coverage", index=False
            )
            if acm:
                pd.DataFrame(acm.generate_permissions_report()).to_excel(writer, sheet_name="acm_report", index=False)
                for role in sorted(acm.user_roles):
                    acm.apply_permissions_to_dataset(dataset, role).to_excel(writer, sheet_name=f"role_{role}"[:31], index=False)
        self.log(f"Excel workbook saved to {filename}")
        return filename

    @staticmethod
    def filter_dataset(dataset: pd.DataFrame, criteria: Dict[str, Any]) -> pd.DataFrame:
        """Filter a dataset using case-insensitive exact-match criteria."""
        filtered_df = dataset.copy()
        for column, value in criteria.items():
            if column not in filtered_df.columns:
                raise ValueError(f"Column '{column}' not found in dataset.")
            filtered_df = filtered_df[
                filtered_df[column].astype(str).str.lower() == str(value).lower()
            ]
        return filtered_df

    @staticmethod
    def load_dataset(filename: str) -> pd.DataFrame:
        """Load a dataset CSV from disk."""
        return pd.read_csv(filename)

    def build_ui_payload(self, dataset: pd.DataFrame, criteria: Optional[Dict[str, Any]] = None,
                         record_index: int = 0, include_all_matches: bool = True) -> Dict[str, Any]:
        """
        Build a UI-friendly dictionary from a dataset.

        The payload separates direct field values from calculated fields so the UI
        can bind inputs and derived outputs independently.
        """
        filtered_df = self.filter_dataset(dataset, criteria) if criteria else dataset.copy()
        if filtered_df.empty:
            raise ValueError("No scenarios found matching the criteria.")
        if record_index < 0 or record_index >= len(filtered_df):
            raise IndexError("record_index is out of range for the filtered dataset")

        records = filtered_df.to_dict(orient="records")
        selected_record = records[record_index]
        field_roles = {key: definition.ui_role for key, definition in self.user_keys.items()}
        field_roles.update({rule.target: rule.ui_role for rule in self.logic_rules})
        question_fields = [field for field in self.question_order if field in selected_record]

        field_values = {
            field: selected_record[field]
            for field in question_fields
            if field_roles.get(field, "input") == "input"
        }
        calculations = {
            field: selected_record[field]
            for field in question_fields
            if field_roles.get(field) == "calculation"
        }
        display_fields = {
            field: selected_record[field]
            for field in question_fields
            if field_roles.get(field) == "display"
        }

        payload = {
            "criteria": criteria or {},
            "match_count": len(records),
            "selected_index": record_index,
            "field_values": field_values,
            "calculations": calculations,
            "display_fields": display_fields,
            "selected_record": selected_record,
        }
        if include_all_matches:
            payload["records"] = records
        return payload

    def filter_csv_to_ui_payload(self, filename: str, criteria: Dict[str, Any],
                                 record_index: int = 0, include_all_matches: bool = True) -> Dict[str, Any]:
        """Load a CSV, apply the Qt-style filters, and return a UI-oriented dictionary payload."""
        dataset = self.load_dataset(filename)
        return self.build_ui_payload(
            dataset,
            criteria=criteria,
            record_index=record_index,
            include_all_matches=include_all_matches,
        )

    def save_profile(self, filename: str) -> str:
        """Save the current dataset definition to JSON."""
        profile = {
            "seed": self.seed,
            "questions": {
                key: {
                    "possible_answers": value.possible_answers,
                    "default_value": value.default_value,
                    "dependency": value.dependency,
                    "copy_from": value.copy_from,
                    "skip": value.skip,
                    "if_conditions": value.if_conditions,
                    "group": value.group,
                    "weights": value.weights,
                    "generation_strategy": value.generation_strategy,
                    "ui_role": value.ui_role,
                }
                for key, value in self.user_keys.items()
            },
            "logic_rules": [
                {
                    "target": rule.target,
                    "rules": rule.rules,
                    "possible_values": rule.possible_values,
                    "default": rule.default,
                    "position": rule.position,
                    "ui_role": rule.ui_role,
                }
                for rule in self.logic_rules
            ],
            "question_order": self.question_order,
        }
        with open(filename, "w", encoding="utf-8") as file_obj:
            json.dump(profile, file_obj, indent=2, default=str)
        return filename

    @classmethod
    def load_profile(cls, filename: str) -> "DataSetCreator":
        """Load a dataset definition from JSON."""
        with open(filename, "r", encoding="utf-8") as file_obj:
            profile = json.load(file_obj)
        creator = cls()
        creator.set_seed(profile.get("seed", 42))
        for key, config in profile.get("questions", {}).items():
            creator.add_question(
                key,
                possible_answers=config.get("possible_answers"),
                default_value=config.get("default_value"),
                dependency=config.get("dependency"),
                copy_from=config.get("copy_from"),
                skip=config.get("skip", False),
                if_conditions=config.get("if_conditions"),
                group=config.get("group"),
                weights=config.get("weights"),
                generation_strategy=config.get("generation_strategy", "random"),
                ui_role=config.get("ui_role", "input"),
            )
        for rule in profile.get("logic_rules", []):
            creator.add_logic(
                target_question=rule["target"],
                rules=rule["rules"] + [{"default_value": rule["default"]}],
                possible_values=rule.get("possible_values"),
                default_value=rule.get("default"),
                position=rule.get("position"),
                ui_role=rule.get("ui_role", "calculation"),
            )
        creator.question_order = profile.get("question_order", creator.question_order)
        return creator

    def validate(self) -> Dict[str, List[str]]:
        """Return structured validation information before generation."""
        errors = self.validate_question_references()
        warnings_list = []
        try:
            self._validate_logic_rules()
        except ValueError as exc:
            errors.append(str(exc))
        for key, details in self.user_keys.items():
            if details.generation_strategy == "weighted_random" and not details.weights:
                errors.append(f"Question '{key}' uses weighted_random but has no weights")
            if details.skip and details.generation_strategy in {"weighted_random", "exhaustive", "pairwise"}:
                errors.append(
                    f"Question '{key}' is skipped but uses incompatible strategy '{details.generation_strategy}'"
                )
            if details.copy_from and any(rule.target == details.copy_from for rule in self.logic_rules):
                errors.append(
                    f"Question '{key}' copies from calculation field '{details.copy_from}', which is not supported"
                )
            if details.weights and len(details.weights) != len(details.possible_answers):
                errors.append(f"Question '{key}' has weights length different from possible_answers length")
            if details.weights and sum(details.weights) == 0:
                errors.append(f"Question '{key}' has weights that sum to zero")
        for group_name, group_keys in self.get_groups().items():
            if len(group_keys) < 2:
                warnings_list.append(f"Group '{group_name}' has only one question and adds no combination value")
        return {"errors": errors, "warnings": warnings_list}

    def generate_coverage_report(self, dataset: pd.DataFrame) -> Dict[str, Any]:
        """Generate a lightweight coverage report for answers, logic, and dependencies."""
        answer_coverage = []
        for question, answers in self.answers_per_question.items():
            observed = dataset[question].dropna().tolist() if question in dataset.columns else []
            answer_coverage.append({
                "question": question,
                "expected_answers": list(answers),
                "observed_answers": sorted(set(observed), key=str),
                "missing_answers": [answer for answer in answers if answer not in set(observed)],
            })

        logic_coverage = []
        evaluator = self._create_generator()
        for rule in self.logic_rules:
            for rule_dict in rule.rules:
                condition, outcome = list(rule_dict.items())[0]
                hits = int(dataset.apply(lambda row: evaluator.evaluate_condition(condition, row.to_dict()), axis=1).sum())
                logic_coverage.append({
                    "target": rule.target,
                    "condition": condition,
                    "outcome": outcome,
                    "hits": hits,
                })

        dependency_coverage = []
        for key, details in self.user_keys.items():
            if details.dependency and key in dataset.columns:
                skip_count = int((dataset[key] == "SKIP").sum())
                dependency_coverage.append({
                    "question": key,
                    "dependency": details.dependency,
                    "skip_count": skip_count,
                })

        return {
            "answer_coverage": answer_coverage,
            "logic_coverage": logic_coverage,
            "dependency_coverage": dependency_coverage,
        }

    def _validate_logic_rules(self) -> None:
        """Validate logic rule conditions before dataset generation."""
        available_questions = set(self.user_keys.keys())
        for rule in self.logic_rules:
            for rule_dict in rule.rules:
                condition = list(rule_dict.keys())[0]
                try:
                    self._validate_condition_type_compatibility(condition, f"logic target '{rule.target}'")
                    dummy_context = {}
                    for q in available_questions:
                        if q in self.answers_per_question:
                            if all(isinstance(x, (int, float)) for x in self.answers_per_question[q]):
                                dummy_context[q] = sum(self.answers_per_question[q]) / len(
                                    self.answers_per_question[q])
                            else:
                                dummy_context[q] = self.answers_per_question[q][0]
                    evaluator = self._create_generator(helper_info=False)
                    evaluator.evaluate_condition(condition, dummy_context)
                except Exception as e:
                    raise ValueError(
                        f"Invalid condition in logic rule: '{condition}'. Error: {e}\n"
                        f"Make sure all comparisons are valid (e.g., don't compare strings with numbers)"
                    )

    def _generate_dataset_frame(self, helper_info: bool = False,
                                acm: Optional[AccessControlManager] = None,
                                num_rows: int = 500) -> pd.DataFrame:
        """Generate the final dataset frame without writing files."""
        self.logging = helper_info
        self._validate_logic_rules()

        generator = self._create_generator(helper_info=helper_info)
        if not generator.generate_test_set(num_samples=500):
            raise ValueError("Failed to validate dependencies. Please review the matrix.")

        dataset = generator.generate_dataset(num_rows=num_rows)
        dataset = generator.fill_missing_data(dataset)
        dataset = generator.reduce_to_minimum(dataset)
        dataset = generator.apply_group_permutations(dataset)
        dataset = self._apply_logic_rules(dataset)

        final_columns = [col for col in self.question_order if col in dataset.columns]
        remaining_columns = [col for col in dataset.columns if col not in final_columns]
        dataset = dataset[final_columns + remaining_columns]

        return dataset

    def generate_dataset_with_generator(self, filename: Optional[str] = None,
                                        helper_info: bool = False,
                                        acm: Optional[AccessControlManager] = None,
                                        num_rows: int = 500) -> pd.DataFrame:
        """
        Generate the final dataset using the DatasetGenerator with proper column order.

        Args:
            filename: Output CSV filename (optional, will auto-generate)
            helper_info: Whether to show debug information
            acm: Optional AccessControlManager for access control metadata
            num_rows: Number of rows to generate before reduction/permutation steps

        Returns:
            pd.DataFrame: Generated dataset
        """
        if filename is None:
            date = datetime.datetime.now().strftime("%Y%m%d")
            dataset_type = "complex_logic"
            filename = f"{dataset_type}_dataset_{date}.csv"

        dataset = self._generate_dataset_frame(helper_info=helper_info, acm=acm, num_rows=num_rows)
        self.export_dataset(dataset, filename)
        if acm:
            self.export_acm_view(dataset, acm, filename)
        self.log(f"Column order: {list(dataset.columns)}")
        return dataset

    def export_role_specific_dataset(self, role: str, acm: AccessControlManager,
                                     filename: Optional[str] = None,
                                     helper_info: bool = False) -> pd.DataFrame:
        """
        Generate and export a dataset filtered for one role using ACM visibility rules.

        Args:
            role: Role name to export for
            acm: AccessControlManager instance
            filename: Output CSV filename
            helper_info: Whether to enable logging

        Returns:
            pd.DataFrame: Role-filtered dataset
        """
        if role not in acm.user_roles:
            raise ValueError(f"Role '{role}' is not defined in AccessControlManager")

        self.logging = helper_info
        generator = self._create_generator(helper_info=helper_info)

        if filename is None:
            date = datetime.datetime.now().strftime("%Y%m%d")
            filename = f"dataset_role_{role}_{date}.csv"

        dataset = self._generate_dataset_frame(helper_info=helper_info)
        acm.set_dataset_columns(dataset.columns.tolist())
        filtered = acm.apply_permissions_to_dataset(dataset, role)
        filtered.to_csv(filename, index=False)
        self.log(f"Role-specific dataset for '{role}' saved to {filename}")
        return filtered

