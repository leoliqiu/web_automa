    def get_question_order(self) -> List[str]:
        """Get the current question order."""
        return self.question_order.copy()

    def get_defined_questions(self) -> List[str]:
        """Get all currently defined questions."""
        return list(self._defined_questions)

    def validate_question_references(self) -> List[str]:
        """
        Validate that all referenced questions in conditions exist.

        Returns:
            List of error messages, empty if all valid
        """
        errors = []

        # Check user_keys conditions
        for key, details in self.user_keys.items():
            if details.if_conditions:
                for condition_dict in details.if_conditions:
                    if "default_value" not in condition_dict:
                        condition = list(condition_dict.keys())[0]
                        referenced = self._extract_variables_from_condition(condition)
                        missing = [q for q in referenced if q not in self._defined_questions]
                        if missing:
                            errors.append(f"Question '{key}': Referenced questions {missing} not defined")

            if details.dependency:
                referenced = self._extract_variables_from_condition(details.dependency)
                missing = [q for q in referenced if q not in self._defined_questions]
                if missing:
                    errors.append(f"Question '{key}' dependency: Referenced questions {missing} not defined")

        # Check logic rules
        for rule in self.logic_rules:
            for rule_dict in rule.rules:
                if "default_value" not in rule_dict:
                    condition = list(rule_dict.keys())[0]
                    referenced = self._extract_variables_from_condition(condition)
                    missing = [q for q in referenced if q not in self._defined_questions]
                    if missing:
                        errors.append(f"Logic rule '{rule.target}': Referenced questions {missing} not defined")

        return errors

    def reset(self) -> None:
        """Reset the DataSetCreator to its initial state."""
        self.user_keys = {}
        self.matrix = {}
        self.answers_per_question = {}
        self.logging = False
        self.groups = {}
        self.question_order = []
        self.logic_rules = []
        self._defined_questions = set()


